---
import '../styles/deck.css';

import Layout from '../layouts/Layout.astro';
import Slide from '../components/deck/Slide.astro';
import Nav from '../components/deck/Nav.astro';

import IntroSlide from '../slides/IntroSlide.astro';
import MarketSlide from '../slides/MarketSlide.astro';
import AnatomySlide from '../slides/AnatomySlide.astro';
import UniversalRemoteSlide from '../slides/UniversalRemoteSlide.astro';
import DemosSlide from '../slides/DemosSlide.astro';
import MeetOpenCodeSlide from '../slides/MeetOpenCodeSlide.astro';
import RuntimeSlide from '../slides/RuntimeSlide.astro';
import ExtensionsSlide from '../slides/ExtensionsSlide.astro';
import OhMyOpenAgentSlide from '../slides/OhMyOpenAgentSlide.astro';
import HarnessTradeoffsSlide from '../slides/HarnessTradeoffsSlide.astro';
import RtkSlide from '../slides/RtkSlide.astro';
import RtkExampleSlide from '../slides/RtkExampleSlide.astro';
import TokenToolsLandscapeSlide from '../slides/TokenToolsLandscapeSlide.astro';
import AgentOptimizerSlide from '../slides/AgentOptimizerSlide.astro';
import FutureSlide from '../slides/FutureSlide.astro';
import PersonalizationSlide from '../slides/PersonalizationSlide.astro';
import ResourcesSlide from '../slides/ResourcesSlide.astro';
import TakeawaysSlide from '../slides/TakeawaysSlide.astro';
import OpenCodeCheatsheetSlide from '../slides/OpenCodeCheatsheetSlide.astro';
import AppendixDividerSlide from '../slides/AppendixDividerSlide.astro';
import AppendixRoutingSlide from '../slides/AppendixRoutingSlide.astro';
import AppendixContinuationSlide from '../slides/AppendixContinuationSlide.astro';
import AppendixGuardrailsSlide from '../slides/AppendixGuardrailsSlide.astro';

const slides = [
  { id: "intro", label: "Intro", variant: "accent", Component: IntroSlide },
  { id: "what", label: "Who's Who", Component: MarketSlide },
  { id: "landscape", label: "Anatomy", variant: "accent", Component: AnatomySlide },
  { id: "how", label: "Why It Generalizes", variant: "control", Component: UniversalRemoteSlide },
  { id: "demos", label: "See It Work", variant: "dark", Component: DemosSlide },
  { id: "opencode", label: "Meet OpenCode", variant: "accent", Component: MeetOpenCodeSlide },
  { id: "workflows", label: "Runtime", variant: "accent", Component: RuntimeSlide },
  { id: "harness", label: "Extensions", variant: "dark", Component: ExtensionsSlide },
  { id: "extensibility", label: "Oh-My-OpenAgent", variant: "dark", Component: OhMyOpenAgentSlide },
  { id: "harness-power", label: "OmO Tradeoffs", variant: "accent", Component: HarnessTradeoffsSlide },
  { id: "rtk", label: "Token Killer", variant: "accent", Component: RtkSlide },
  { id: "rtk-example", label: "RTK · In Action", variant: "dark", Component: RtkExampleSlide },
  { id: "rtk-landscape", label: "Beyond RTK", variant: "accent", Component: TokenToolsLandscapeSlide },
  { id: "demo", label: "Example · Agent as Optimizer", variant: "dark", Component: AgentOptimizerSlide },
  { id: "future", label: "Where It's Going", variant: "control", Component: FutureSlide },
  { id: "personalization", label: "Own the Harness", variant: "dark", Component: PersonalizationSlide },
  { id: "tradeoffs", label: "Resources", variant: "accent", Component: ResourcesSlide },
  { id: "takeaways", label: "Takeaways", variant: "dark", Component: TakeawaysSlide },
  { id: "opencode-cheatsheet", label: "OpenCode Cheatsheet", variant: "accent", Component: OpenCodeCheatsheetSlide },
  { id: "appendix", label: "Appendix", Component: AppendixDividerSlide },
  { id: "appendix-routing", label: "Appendix · Routing", variant: "accent", Component: AppendixRoutingSlide },
  { id: "appendix-continuation", label: "Appendix · Continuation", variant: "accent", Component: AppendixContinuationSlide },
  { id: "appendix-guardrails", label: "Appendix · Guardrails", variant: "accent", Component: AppendixGuardrailsSlide },
] as const;

const sections = slides.map(({ id, label }) => ({ id, label }));
---

<Layout title="Coding Agents for Everyday Knowledge Work">
  <Nav sections={sections} />

  {slides.map(({ id, variant = 'default', Component }) => (
    <Slide id={id} variant={variant}>
      <Component />
    </Slide>
  ))}
</Layout>
