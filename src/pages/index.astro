---
import Layout from '../layouts/Layout.astro';
import Slide from '../components/Slide.astro';
import Nav from '../components/Nav.astro';
import Card from '../components/Card.astro';
import CodeBlock from '../components/CodeBlock.astro';

const sections = [
  { id: 'intro', label: 'Intro' },
  { id: 'what', label: 'Who\'s Who' },
  { id: 'landscape', label: 'Anatomy' },
  { id: 'how', label: 'Why It Generalizes' },
  { id: 'workflows', label: 'Capabilities' },
  { id: 'demo', label: 'Demo' },
  { id: 'tradeoffs', label: 'Trade-offs' },
  { id: 'takeaways', label: 'Takeaways' },
];
---

<Layout title="Coding Agents for Everyday Knowledge Work">
  <Nav sections={sections} />

  <!-- Slide 1: Title -->
  <Slide id="intro" variant="accent">
    <div class="title-slide">
      <p class="overline">Technical Sharing</p>
      <h1 class="title">Coding Agents for<br /><span class="highlight">Everyday Knowledge Work</span></h1>
      <p class="subtitle">
        They're not just code generators — they're coworkers that solve tasks through code.
        Learn, triage, review, and ship.
      </p>
      <div class="scroll-hint">
        <span class="scroll-hint__arrow">&#8595;</span>
        <span>Scroll to explore</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 2: Coding agents in the market -->
  <Slide id="what">
    <div class="scatter-slide">
      <div class="scatter-text">
        <p class="overline">The Market Right Now</p>
        <h2>Coding Agents Are<br /><span class="highlight">Everywhere</span></h2>
        <p class="scatter-footnote">
          Today we zoom in on <strong>OpenCode</strong> — our agent of choice inside the company.
        </p>
      </div>
      <div class="scatter-logo" style="--x: 8%; --y: 8%; --size: 6rem; --rot: -12deg; --delay: 0s; --float-dur: 5.5s; --float-offset: -0.4s;">
        <img src="/logos/claude.png" alt="Claude Code" />
        <span>Claude Code</span>
      </div>
      <div class="scatter-logo" style="--x: 70%; --y: 3%; --size: 5rem; --rot: 8deg; --delay: 0.1s; --float-dur: 6.5s; --float-offset: -2.1s;">
        <img src="/logos/codex.png" alt="Codex" />
        <span>Codex</span>
      </div>
      <div class="scatter-logo" style="--x: 30%; --y: 72%; --size: 5.5rem; --rot: -5deg; --delay: 0.2s; --float-dur: 4.5s; --float-offset: -3.3s;">
        <img src="/logos/antigravity.png" alt="Antigravity" />
        <span>Antigravity</span>
      </div>
      <div class="scatter-logo" style="--x: 78%; --y: 65%; --size: 4.5rem; --rot: 15deg; --delay: 0.3s; --float-dur: 7s; --float-offset: -1.2s;">
        <img src="/logos/opencode.png" alt="OpenCode" />
        <span>OpenCode</span>
      </div>
      <div class="scatter-logo" style="--x: 3%; --y: 52%; --size: 6.5rem; --rot: 6deg; --delay: 0.4s; --float-dur: 6s; --float-offset: -4.5s;">
        <img src="/logos/copilot.png" alt="GitHub Copilot" />
        <span>Copilot</span>
      </div>
      <div class="scatter-logo" style="--x: 80%; --y: 26%; --size: 6rem; --rot: -10deg; --delay: 0.5s; --float-dur: 5s; --float-offset: -2.8s;">
        <img src="/logos/cursor.svg" alt="Cursor" />
        <span>Cursor</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 3: Anatomy — model + CodeAct + harness -->
  <Slide id="landscape" variant="accent">
    <div class="content-slide anatomy-slide">
      <p class="overline">The Mental Model</p>
      <h2>So What <em>Is</em> a Coding Agent?</h2>
      <p class="lead">
        Strip away the branding and it's simple:
        <strong>a model doing CodeAct, wrapped in a lot of harness.</strong>
      </p>

      <div class="anatomy">
        <!-- Outer shell: the harness -->
        <div class="layer layer--harness">
          <span class="layer__label">Harness</span>
          <div class="layer__tags">
            <!--
              TODO (your call): list the harness responsibilities you want to emphasize.
              These are the bits OF the harness that aren't the model or CodeAct itself.
              Common candidates — pick/tweak the ones that match how OpenCode works:
                context gathering · the agent loop · memory & compaction ·
                permissions & sandboxing · tool wiring · output parsing · session state
            -->
            <span class="tag">context</span>
            <span class="tag">the loop</span>
            <span class="tag">memory</span>
            <span class="tag">permissions</span>
          </div>

          <!-- Middle ring: CodeAct -->
          <div class="layer layer--codeact">
            <span class="layer__label">CodeAct</span>
            <span class="layer__sub">acts by writing &amp; running code</span>

            <!-- Core: the model -->
            <div class="layer layer--model">
              <span class="layer__label">Model</span>
              <span class="layer__sub">reasons &amp; decides</span>
            </div>
          </div>
        </div>
      </div>

      <p class="anatomy-caption">
        Same model, different harness &rarr; a very different agent. That's why the six above
        feel so different despite often sharing the same underlying models.
      </p>
    </div>
  </Slide>

  <!-- Slide 4: Why it generalizes — code as universal interface (mission-control) -->
  <Slide id="how" variant="control">
    <div class="control-slide">
      <p class="overline overline--glow">Why It Generalizes</p>
      <h2 class="control-title">Code Is a <span class="control-title__accent">Universal Remote</span></h2>
      <p class="control-lead">
        The agent acts by writing <strong>code</strong> — and code can touch almost anything.
      </p>

      <!-- Three-column flow: CODE → systems → knowledge work.
           Reads left-to-right as a causal chain — no explanation needed. -->
      <div class="flow">
        <!-- Left: the code hub -->
        <div class="flow__hub">
          <span class="flow__orb">
            <span class="flow__orb-glow"></span>
            <svg class="flow__orb-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M8.5 7.5 4 12l4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.5 7.5 20 12l-4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13.5 6 10.5 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            <span class="flow__orb-label">CODE</span>
          </span>
        </div>

        <!-- Arrow column 1 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">reaches</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Middle: systems column -->
        <div class="flow__col">
          <span class="flow__col-header">Systems</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--sys" style="--i:0">APIs</span>
            <span class="flow__chip flow__chip--sys" style="--i:1">Databases</span>
            <span class="flow__chip flow__chip--sys" style="--i:2">Shell &amp; CLI</span>
            <span class="flow__chip flow__chip--sys" style="--i:3">Git &amp; PRs</span>
            <span class="flow__chip flow__chip--sys" style="--i:4">The web</span>
            <span class="flow__chip flow__chip--sys" style="--i:5">Files</span>
          </div>
        </div>

        <!-- Arrow column 2 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">enables</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Right: knowledge work column (the payoff — visually dominant) -->
        <div class="flow__col">
          <span class="flow__col-header">Knowledge Work</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--work" style="--i:6">Research</span>
            <span class="flow__chip flow__chip--work" style="--i:7">Triage</span>
            <span class="flow__chip flow__chip--work" style="--i:8">Review</span>
            <span class="flow__chip flow__chip--work" style="--i:9">Analysis</span>
            <span class="flow__chip flow__chip--work" style="--i:10">Docs</span>
            <span class="flow__chip flow__chip--work" style="--i:11">Onboarding</span>
          </div>
        </div>
      </div>

      <p class="control-caption">
        One action language. Infinite reach.
      </p>
    </div>
  </Slide>

  <!-- Slide 5: OpenCode architecture — clean centered diagram -->
  <Slide id="workflows" variant="accent">
    <div class="content-slide arc">
      <p class="overline">Inside OpenCode</p>
      <h2>The <span class="highlight">Architecture</span></h2>

      <!-- The diagram — a single centered visual -->
      <div class="arc__diagram">
        <!-- Main pipeline row -->
        <div class="arc__pipeline">
          <div class="arc__stage arc__stage--input">
            <div class="arc__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 12h16m0 0-5-5m5 5-5 5"/></svg>
            </div>
            <span class="arc__name">Input</span>
            <span class="arc__meta">steer &middot; queue</span>
          </div>

          <svg class="arc__connector" viewBox="0 0 40 8"><path d="M0 4h40" stroke="currentColor" stroke-width="1.2" stroke-dasharray="3 3"/></svg>

          <div class="arc__stage arc__stage--ctx">
            <div class="arc__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <span class="arc__name">Context</span>
            <span class="arc__meta">SystemContext &middot; History &middot; Epoch</span>
          </div>

          <svg class="arc__connector" viewBox="0 0 40 8"><path d="M0 4h40" stroke="currentColor" stroke-width="1.2" stroke-dasharray="3 3"/></svg>

          <div class="arc__stage arc__stage--llm">
            <div class="arc__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            </div>
            <span class="arc__name">LLM</span>
            <span class="arc__meta">Anthropic &middot; OpenAI &middot; Bedrock</span>
          </div>

          <svg class="arc__connector" viewBox="0 0 40 8"><path d="M0 4h40" stroke="currentColor" stroke-width="1.2" stroke-dasharray="3 3"/></svg>

          <div class="arc__stage arc__stage--tools">
            <div class="arc__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <span class="arc__name">Tools</span>
            <span class="arc__meta">bash &middot; read &middot; write &middot; edit &middot; MCP</span>
          </div>

          <svg class="arc__connector" viewBox="0 0 40 8"><path d="M0 4h40" stroke="currentColor" stroke-width="1.2" stroke-dasharray="3 3"/></svg>

          <div class="arc__stage arc__stage--persist">
            <div class="arc__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 5v6c0 1.66-4.03 3-9 3s-9-1.34-9-3V5"/><path d="M21 11v6c0 1.66-4.03 3-9 3s-9-1.34-9-3v-6"/></svg>
            </div>
            <span class="arc__name">Persist</span>
            <span class="arc__meta">SQLite &middot; Events &middot; ToolOutput</span>
          </div>
        </div>

        <!-- Loop indicator -->
        <div class="arc__loop-bar">
          <span class="arc__loop-text">&larr; results feed back &middot; up to 25 iterations per session &rarr;</span>
        </div>

        <!-- Supporting systems -->
        <div class="arc__supports">
          <div class="arc__support">
            <span class="arc__support-label">Compaction</span>
            <span class="arc__support-desc">20K&rarr;8K auto-summarize</span>
          </div>
          <div class="arc__support">
            <span class="arc__support-label">Permissions</span>
            <span class="arc__support-desc">allow &middot; ask &middot; deny</span>
          </div>
          <div class="arc__support">
            <span class="arc__support-label">Skills &amp; Plugins</span>
            <span class="arc__support-desc">markdown &middot; hooks</span>
          </div>
          <div class="arc__support">
            <span class="arc__support-label">MCP</span>
            <span class="arc__support-desc">local &middot; remote servers</span>
          </div>
        </div>
      </div>
    </div>
  </Slide>

  <!-- Slide 6: Demo / Code example -->
  <Slide id="demo">
    <div class="content-slide">
      <p class="overline">Example</p>
      <h2>An Agent in Action</h2>
      <p class="lead">A typical interaction with a CLI coding agent:</p>
      <CodeBlock title="Terminal — Claude Code" lang="bash">
{`$ claude

> Fix the race condition in the WebSocket handler
  that causes duplicate messages on reconnect.

◐ Reading src/ws/handler.ts...
◐ Found the issue — reconnect doesn't clear the
  previous listener before attaching a new one.
◐ Editing src/ws/handler.ts...
◐ Running tests: npm test -- ws.test.ts
✓ All 14 tests pass.

> Looks good. Now add a test for the edge case
  where reconnect happens mid-message.

◐ Adding test to src/ws/__tests__/handler.test.ts...
◐ Running tests...
✓ All 15 tests pass.`}
      </CodeBlock>
    </div>
  </Slide>

  <!-- Slide 7: Trade-offs -->
  <Slide id="tradeoffs" variant="accent">
    <div class="content-slide">
      <p class="overline">Honest Take</p>
      <h2>Trade-offs & Limitations</h2>
      <p class="lead">Agents are powerful but not magic. Know the edges.</p>
      <div class="grid grid--2">
        <div class="pros-cons">
          <h3 class="pros-cons__header pros-cons__header--pro">Strengths</h3>
          <ul>
            <li>Massive speedup on well-defined mechanical tasks</li>
            <li>Excellent at exploring unfamiliar codebases</li>
            <li>Tireless at repetitive transformations</li>
            <li>Good at catching things you'd miss (unused imports, typos)</li>
          </ul>
        </div>
        <div class="pros-cons">
          <h3 class="pros-cons__header pros-cons__header--con">Limitations</h3>
          <ul>
            <li>Can hallucinate APIs or invent plausible-but-wrong fixes</li>
            <li>Struggles with large-scale architectural decisions</li>
            <li>Context window limits constrain very large codebases</li>
            <li>Still needs human review — trust but verify</li>
          </ul>
        </div>
      </div>
    </div>
  </Slide>

  <!-- Slide 8: Key takeaways -->
  <Slide id="takeaways" variant="dark">
    <div class="content-slide takeaway-slide">
      <p class="overline">Wrapping Up</p>
      <h2>Key Takeaways</h2>
      <ol class="takeaway-list">
        <li>
          <strong>Agents are a workflow shift, not just a tool.</strong>
          You move from writing code to directing and reviewing it.
        </li>
        <li>
          <strong>Start with bounded tasks.</strong>
          Bug fixes, refactors, and tests are the sweet spot today.
        </li>
        <li>
          <strong>Invest in context.</strong>
          Good project docs (CLAUDE.md, README) make agents dramatically more effective.
        </li>
        <li>
          <strong>Keep humans in the loop.</strong>
          The best workflow is human judgment + agent execution speed.
        </li>
      </ol>
      <div class="closing">
        <p class="closing__text">Thanks for listening.</p>
      </div>
    </div>
  </Slide>
</Layout>

<script>
</script>

<style>
  /* Title slide */
  .title-slide {
    text-align: center;
  }

  .overline {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  .highlight {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto 3rem;
  }

  .scroll-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    animation: bounce 2s infinite;
  }

  .scroll-hint__arrow {
    font-size: 1.2rem;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Content slides */
  .content-slide h2 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 42rem;
    margin-bottom: 2.5rem;
  }

  /* Grid */
  .grid {
    display: grid;
    gap: 1.25rem;
  }

  .grid--2 {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .grid--3 {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  /* Pipeline */
  .pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .pipeline__step {
    flex: 1;
    min-width: 160px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }

  .pipeline__step h3 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }

  .pipeline__step p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .pipeline__num {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent-dim);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .pipeline__arrow {
    color: var(--color-accent);
    font-size: 1.5rem;
    padding-top: 2rem;
    flex-shrink: 0;
  }

  /* Pros/Cons */
  .pros-cons {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .pros-cons__header {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid;
  }

  .pros-cons__header--pro {
    border-color: #34d399;
    color: #34d399;
  }

  .pros-cons__header--con {
    border-color: #fb923c;
    color: #fb923c;
  }

  .pros-cons ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pros-cons li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
  }

  .pros-cons li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-text-muted);
  }

  /* Takeaway list */
  .takeaway-list {
    list-style: none;
    counter-reset: takeaway;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 42rem;
  }

  .takeaway-list li {
    counter-increment: takeaway;
    padding-left: 2.5rem;
    position: relative;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .takeaway-list li strong {
    color: var(--color-text);
    display: block;
    margin-bottom: 0.25rem;
  }

  .takeaway-list li::before {
    content: counter(takeaway);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent-dim);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Closing */
  .closing {
    margin-top: 3rem;
    text-align: center;
  }

  .closing__text {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  /* Scatter logos */
  .scatter-slide {
    position: relative;
    width: 100%;
    height: 80vh;
  }

  .scatter-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
  }

  .scatter-text h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
  }

  .scatter-footnote {
    margin: 1.5rem auto 0;
    max-width: 26rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .scatter-footnote strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .scatter-logo {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: rotate(var(--rot));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 3;
    animation: scatter-pop 0.6s ease both;
    animation-delay: var(--delay);
    transition: transform 0.3s ease;
  }

  .scatter-logo:hover {
    transform: rotate(0deg) scale(1.15);
    z-index: 10;
  }

  .scatter-logo img {
    width: var(--size);
    height: var(--size);
    object-fit: contain;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.1));
    animation: float var(--float-dur, 5s) ease-in-out infinite;
    animation-delay: var(--float-offset, 0s);
  }

  /* Pause the ambient bob while hovering so the lift reads cleanly */
  .scatter-logo:hover img {
    animation-play-state: paused;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
