  /* ===== Appendix A3: Guardrails-specific ===== */
  .appendix--guardrails h2 {
    margin-bottom: 0.55rem;
  }

  .appendix--guardrails .appendix__lead {
    margin-bottom: 0.7rem;
  }

  .hook-ribbon {
