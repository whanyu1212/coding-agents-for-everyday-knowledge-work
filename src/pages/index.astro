    vertical-align: middle;
  }

  .appendix-table tbody tr:last-child td {
    border-bottom: none;
  }

  .appendix-table tbody td code {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.1rem 0.35rem;
    background: rgba(99, 102, 241, 0.08);
    color: #4338ca;
    border-radius: 0.3rem;
    white-space: nowrap;
  }

  .appendix-table__count {
    display: inline-block;
    margin-left: 0.4rem;
    padding: 0.05rem 0.4rem;
    background: rgba(245, 158, 11, 0.15);
    color: #b45309;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .appendix-table--hooks tbody td:first-child {
