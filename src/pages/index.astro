---
import Layout from '../layouts/Layout.astro';
import Slide from '../components/Slide.astro';
import Nav from '../components/Nav.astro';

const sections = [
  { id: 'intro', label: 'Intro' },
  { id: 'what', label: 'Who\'s Who' },
  { id: 'landscape', label: 'Anatomy' },
  { id: 'how', label: 'Why It Generalizes' },
  { id: 'demos', label: 'See It Work' },
  { id: 'opencode', label: 'Meet OpenCode' },
  { id: 'workflows', label: 'Runtime' },
  { id: 'harness', label: 'Extensions' },
  { id: 'extensibility', label: 'Oh-My-OpenAgent' },
  { id: 'harness-power', label: 'OmO Tradeoffs' },
  { id: 'rtk', label: 'Token Killer' },
  { id: 'rtk-example', label: 'RTK · In Action' },
  { id: 'rtk-landscape', label: 'Beyond RTK' },
  { id: 'demo', label: 'Example · Agent as Optimizer' },
  { id: 'future', label: 'Where It\'s Going' },
  { id: 'personalization', label: 'Own the Harness' },
  { id: 'tradeoffs', label: 'Resources' },
  { id: 'takeaways', label: 'Takeaways' },
  { id: 'appendix-routing', label: 'Appendix · Routing' },
  { id: 'appendix-continuation', label: 'Appendix · Continuation' },
  { id: 'appendix-guardrails', label: 'Appendix · Guardrails' },
];
---

<Layout title="Coding Agents for Everyday Knowledge Work">
  <Nav sections={sections} />

  <!-- Slide 1: Title -->
  <Slide id="intro" variant="accent">
    <div class="title-slide">
      <p class="overline">Technical Sharing</p>
      <h1 class="title">Coding Agents for<br /><span class="highlight">Everyday Knowledge Work</span></h1>
      <p class="subtitle">
        They're not just code generators — they're coworkers that solve tasks through code.
        Learn, triage, review, and ship.
      </p>
      <div class="scroll-hint">
        <span class="scroll-hint__arrow">&#8595;</span>
        <span>Scroll to explore</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 2: Coding agents in the market -->
  <Slide id="what">
    <div class="scatter-slide">
      <div class="scatter-text">
        <p class="overline">The Market Right Now</p>
        <h2>Coding Agents Are<br /><span class="highlight">Everywhere</span></h2>
      </div>
      <div class="scatter-logo" style="--x: 8%; --y: 8%; --size: 6rem; --rot: -12deg; --delay: 0s; --float-dur: 5.5s; --float-offset: -0.4s;">
        <img src={`${import.meta.env.BASE_URL}logos/claude.png`} alt="Claude Code" />
        <span>Claude Code</span>
      </div>
      <div class="scatter-logo" style="--x: 70%; --y: 3%; --size: 5rem; --rot: 8deg; --delay: 0.1s; --float-dur: 6.5s; --float-offset: -2.1s;">
        <img src={`${import.meta.env.BASE_URL}logos/codex.png`} alt="Codex" />
        <span>Codex</span>
      </div>
      <div class="scatter-logo" style="--x: 30%; --y: 72%; --size: 5.5rem; --rot: -5deg; --delay: 0.2s; --float-dur: 4.5s; --float-offset: -3.3s;">
        <img src={`${import.meta.env.BASE_URL}logos/antigravity.png`} alt="Antigravity" />
        <span>Antigravity</span>
      </div>
      <div class="scatter-logo" style="--x: 78%; --y: 65%; --size: 4.5rem; --rot: 15deg; --delay: 0.3s; --float-dur: 7s; --float-offset: -1.2s;">
        <img src={`${import.meta.env.BASE_URL}logos/opencode.png`} alt="OpenCode" />
        <span>OpenCode</span>
      </div>
      <div class="scatter-logo" style="--x: 3%; --y: 52%; --size: 6.5rem; --rot: 6deg; --delay: 0.4s; --float-dur: 6s; --float-offset: -4.5s;">
        <img src={`${import.meta.env.BASE_URL}logos/copilot.png`} alt="GitHub Copilot" />
        <span>Copilot</span>
      </div>
      <div class="scatter-logo" style="--x: 80%; --y: 26%; --size: 6rem; --rot: -10deg; --delay: 0.5s; --float-dur: 5s; --float-offset: -2.8s;">
        <img src={`${import.meta.env.BASE_URL}logos/cursor.svg`} alt="Cursor" />
        <span>Cursor</span>
      </div>
      <div class="scatter-logo" style="--x: 43%; --y: 11%; --size: 5rem; --rot: 3deg; --delay: 0.6s; --float-dur: 5.8s; --float-offset: -1.9s;">
        <img src={`${import.meta.env.BASE_URL}logos/pi.svg`} alt="Pi" />
        <span>Pi</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 3: Anatomy — model + CodeAct + harness -->
  <Slide id="landscape" variant="accent">
    <div class="content-slide anatomy-slide">
      <p class="overline">The Mental Model</p>
      <h2>So What <em>Is</em> a Coding Agent?</h2>
      <p class="lead">
        Strip away the branding and it's simple:
        <strong>a model doing CodeAct, wrapped in a harness.</strong>
      </p>

      <div class="anatomy">
        <!-- Outer shell: the harness -->
        <div class="layer layer--harness">
          <span class="layer__label">Harness</span>
          <div class="layer__tags">
            <!--
              TODO (your call): list the harness responsibilities you want to emphasize.
              These are the bits OF the harness that aren't the model or CodeAct itself.
              Common candidates — pick/tweak the ones that match how OpenCode works:
                context gathering · the agent loop · memory & compaction ·
                permissions & sandboxing · tool wiring · output parsing · session state
            -->
            <span class="tag">context</span>
            <span class="tag">the loop</span>
            <span class="tag">memory</span>
            <span class="tag">tools</span>
            <span class="tag">permissions</span>
          </div>

          <!-- Middle ring: CodeAct -->
          <div class="layer layer--codeact">
            <span class="layer__label">CodeAct</span>
            <span class="layer__sub">acts through code &amp; tools</span>

            <!-- Core: the model -->
            <div class="layer layer--model">
              <span class="layer__label">Model</span>
              <span class="layer__sub">reasons &amp; decides</span>
            </div>
          </div>
        </div>
      </div>

      <p class="anatomy-caption">
        Same model, different harness &rarr; a very different agent. That's why the six above
        feel so different despite often sharing the same underlying models.
      </p>
    </div>
  </Slide>

  <!-- Slide 4: Why it generalizes — code as universal interface (mission-control) -->
  <Slide id="how" variant="control">
    <div class="control-slide">
      <p class="overline overline--glow">Why It Generalizes</p>
      <h2 class="control-title">Code Is a <span class="control-title__accent">Universal Remote</span></h2>
      <p class="control-lead">
        The agent acts by writing <strong>code</strong> — and code can touch almost anything. Two examples, coming up next.
      </p>

      <!-- Three-column flow: CODE → systems → knowledge work.
           Reads left-to-right as a causal chain — no explanation needed. -->
      <div class="flow">
        <!-- Left: the code hub -->
        <div class="flow__hub">
          <span class="flow__orb">
            <span class="flow__orb-glow"></span>
            <svg class="flow__orb-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M8.5 7.5 4 12l4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.5 7.5 20 12l-4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13.5 6 10.5 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            <span class="flow__orb-label">CODE</span>
          </span>
        </div>

        <!-- Arrow column 1 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">reaches</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Middle: systems column -->
        <div class="flow__col flow__col--sys">
          <span class="flow__col-header">Systems</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--sys" style="--i:0">APIs</span>
            <span class="flow__chip flow__chip--sys" style="--i:1">Databases</span>
            <span class="flow__chip flow__chip--sys" style="--i:2">Shell &amp; CLI</span>
            <span class="flow__chip flow__chip--sys" style="--i:3">Git &amp; PRs</span>
            <span class="flow__chip flow__chip--sys" style="--i:4">The web</span>
            <span class="flow__chip flow__chip--sys" style="--i:5">Files</span>
          </div>
        </div>

        <!-- Arrow column 2 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">enables</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Right: knowledge work column (the payoff — visually dominant) -->
        <div class="flow__col flow__col--work">
          <span class="flow__col-header">Knowledge Work</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--work" style="--i:6">Research</span>
            <span class="flow__chip flow__chip--work" style="--i:7">Triage</span>
            <span class="flow__chip flow__chip--work" style="--i:8">Review</span>
            <span class="flow__chip flow__chip--work" style="--i:9">Analysis</span>
            <span class="flow__chip flow__chip--work" style="--i:10">Docs</span>
            <span class="flow__chip flow__chip--work" style="--i:11">Onboarding</span>
          </div>
        </div>
      </div>

      <p class="control-caption">
        One action language. Infinite reach.
      </p>
    </div>
  </Slide>

  <!-- Slide 4.5: Demos — prove the "universal remote" claim we just made (placeholders; screenshots/recordings TBD) -->
  <Slide id="demos" variant="dark">
    <div class="content-slide demos-slide">
      <p class="overline">From Theory to Proof</p>
      <h2>Same Trick, <span class="highlight">Two Real Jobs</span></h2>
      <p class="lead demos-slide__lead">
        That's the claim. Here it is for real — two everyday tasks, both done by the agent,
        neither one "writing software." Same action language, very different jobs.
      </p>

      <div class="demos-grid">
        <div class="demo-card demo-card--brief">
          <div class="demo-card__head">
            <span class="demo-card__num">Demo 1</span>
            <span class="demo-card__tag">Research &middot; Synthesize &middot; Publish</span>
          </div>
          <h3 class="demo-card__title">Daily paper brief &rarr; Confluence</h3>
          <p class="demo-card__desc">
            Agent surveys the Hugging Face Daily Papers feed, picks the most relevant paper,
            writes a structured brief, and posts it to our Confluence space.
          </p>
          <div class="demo-card__flow">
            <span class="demo-card__step">HF Daily Papers</span>
            <span class="demo-card__arrow">&rarr;</span>
            <span class="demo-card__step">structured brief</span>
            <span class="demo-card__arrow">&rarr;</span>
            <span class="demo-card__step">Confluence page</span>
          </div>
          <div class="demo-card__prereqs" aria-label="Daily paper brief prerequisites">
            <span class="demo-card__prereq-label">Needs</span>
            <span class="demo-card__prereq">Atlassian MCP connected</span>
            <span class="demo-card__prereq">HF API skill</span>
            <span class="demo-card__prereq">extract + write skill</span>
          </div>
          <p class="demo-card__notice">Watch for: it doesn't just summarize — it <strong>writes into a system we actually read.</strong></p>
          <div class="demo-card__placeholder">
            <span class="demo-card__placeholder-icon" aria-hidden="true">&#9655;</span>
            <span>recording / screenshot goes here</span>
          </div>
        </div>

        <div class="demo-card demo-card--triage">
          <div class="demo-card__head">
            <span class="demo-card__num">Demo 2</span>
            <span class="demo-card__tag">Read &middot; Reason &middot; Act</span>
          </div>
          <h3 class="demo-card__title">Triaging GitHub issues</h3>
          <p class="demo-card__desc">
            Agent reads messy, free-form issues, reasons about each one, and takes
            structured action — label, prioritize, route, or reply.
          </p>
          <div class="demo-card__flow">
            <span class="demo-card__step">raw issues</span>
            <span class="demo-card__arrow">&rarr;</span>
            <span class="demo-card__step">classify + reason</span>
            <span class="demo-card__arrow">&rarr;</span>
            <span class="demo-card__step">labels / routing</span>
          </div>
          <div class="demo-card__prereqs" aria-label="GitHub issue triage prerequisites">
            <span class="demo-card__prereq-label">Needs</span>
            <span class="demo-card__prereq">authenticated <code>gh</code> CLI</span>
            <a class="demo-card__prereq demo-card__prereq--link" href={`${import.meta.env.BASE_URL}samples/github-management-skill.md`} target="_blank" rel="noopener">github-management skill</a>
          </div>
          <p class="demo-card__notice">Watch for: it turns <strong>unstructured human input into structured action.</strong></p>
          <div class="demo-card__placeholder">
            <span class="demo-card__placeholder-icon" aria-hidden="true">&#9655;</span>
            <span>recording / screenshot goes here</span>
          </div>
        </div>
      </div>

      <p class="demos-slide__caption">
        <!-- TODO (decide once recorded): note whether these run on a vanilla agent or through OmO,
             and tweak the line below to match. Vanilla → "and this is before the harness gets opinionated."
             OmO → "the harness is already doing the routing and skill-loading here." -->
        One action language did both. Next: <em>which</em> agent we run to get this &mdash; and what&rsquo;s under its hood.
      </p>
    </div>
  </Slide>

  <!-- Slide 4.75: Meet OpenCode — establishing shot before the runtime deep-dive -->
  <Slide id="opencode" variant="accent">
    <div class="content-slide opencode-intro">
      <p class="overline">Meet OpenCode</p>
      <h2>What&rsquo;s Good About <span class="highlight">OpenCode</span></h2>
      <p class="lead opencode-intro__lead">
        Of the six on that first slide, this is the one we run internally &mdash;
        <strong>&ldquo;the open source AI coding agent.&rdquo;</strong> Three reasons it earns the spot.
      </p>

      <div class="opencode-traits">
        <div class="oc-trait oc-trait--open">
          <span class="oc-trait__icon oc-trait__icon--code" aria-hidden="true">&lt;/&gt;</span>
          <h3 class="oc-trait__title">Open source</h3>
          <p class="oc-trait__desc">The whole runtime is readable. No black box &mdash; you can see exactly how a turn is assembled.</p>
          <span class="oc-trait__tag">terminal-first &middot; MIT</span>
        </div>

        <div class="oc-trait oc-trait--model">
          <span class="oc-trait__icon" aria-hidden="true">&#8644;</span>
          <h3 class="oc-trait__title">Model-agnostic</h3>
          <p class="oc-trait__desc">Bring any provider &mdash; Anthropic, OpenAI, Google, local. Swap freely; the harness isn&rsquo;t welded to one vendor.</p>
          <span class="oc-trait__tag">any LLM, per task</span>
        </div>

        <div class="oc-trait oc-trait--hack">
          <span class="oc-trait__icon" aria-hidden="true">&#9881;</span>
          <h3 class="oc-trait__title">Hackable</h3>
          <p class="oc-trait__desc">A core runtime with clients on top &mdash; TUI, desktop, SDK &mdash; plus skills, plugins, and lifecycle hooks.</p>
          <a class="oc-trait__link" href={`${import.meta.env.BASE_URL}samples/opencode-tool-permissions.json`} target="_blank" rel="noopener">
            Open sample tool-permission config
          </a>
          <span class="oc-trait__tag">plugins &middot; hooks &middot; skills</span>
        </div>
      </div>

      <p class="opencode-intro__limitation">
        <strong>Caveat:</strong> first-party stacks still have an edge &mdash; Opus in Claude Code and GPT in Codex may be post-trained around their own harnesses, so OpenCode is not always 100% behaviorally on par.
      </p>

      <p class="opencode-intro__bridge">
        And because it&rsquo;s open, we can do something the closed agents won&rsquo;t let you:
        <em>look inside the runtime itself.</em>
      </p>
    </div>
  </Slide>

  <!-- Slide 5: OpenCode architecture — grounded in the actual core runtime -->
  <Slide id="workflows" variant="accent">
    <div class="content-slide runtime">
      <p class="overline">Inside OpenCode</p>
      <h2>What the Runtime <span class="highlight">Actually Looks Like</span></h2>
      <p class="lead runtime__lead">
        OpenCode records a prompt, runs one <code>SessionRunner</code> turn, executes tools,
        and persists replayable events.
      </p>

      <div class="runtime__split">
        <div class="runtime__left">
          <figure class="runtime__screenshot">
            <img src={`${import.meta.env.BASE_URL}screenshots/opencode-runtime-search.png`} alt="OpenCode terminal session showing a web search task, tool calls, context usage, and session telemetry." />
            <figcaption>Live run: the harness turns a request into skills, tool calls, context, and state.</figcaption>
          </figure>

          <div class="runtime__flow-stage runtime__flow-stage--admit">
            <div class="runtime__flow-head">
              <span class="runtime__stage-num">1</span>
              <span class="runtime__stage-copy">
                <strong>Receive prompt</strong>
                <small>durable input, then wake the session</small>
              </span>
            </div>
            <div class="runtime__strip" aria-label="Process-global runtime control">
              <span class="runtime__strip-item"><strong>Record prompt</strong><small><code>session_input</code> inbox</small></span>
              <span class="runtime__strip-item"><strong>Schedule run</strong><small>SessionExecution</small></span>
              <span class="runtime__strip-item"><strong>Resolve runtime</strong><small>LocationServiceMap</small></span>
            </div>
          </div>
        </div>

        <div class="runtime__diagram" aria-label="OpenCode runtime flow">
          <div class="runtime__frame">
            <div class="runtime__flow-head runtime__flow-head--frame">
              <span class="runtime__stage-num">2</span>
              <span class="runtime__stage-copy">
                <strong>Run in workspace runtime</strong>
                <small>location-scoped services</small>
              </span>
            </div>
            <div class="runtime__compact">
              <div class="runtime__core">
                <div class="runtime__core-head">
                  <span class="runtime__stage-num runtime__stage-num--small">3</span>
                  <span class="runtime__core-copy">
                    <span class="runtime__kicker">Assemble one model turn</span>
                    <span class="runtime__core-title">SessionRunner</span>
                  </span>
                </div>
                <span class="runtime__core-sub">one <code>llm.stream(request)</code> call</span>
                <div class="runtime__loop" aria-label="Per-turn loop">
                  <span class="runtime__loop-step">gather context</span>
                  <span class="runtime__loop-arrow" aria-hidden="true">&#8594;</span>
                  <span class="runtime__loop-step">call model</span>
                  <span class="runtime__loop-arrow" aria-hidden="true">&#8594;</span>
                  <span class="runtime__loop-step">execute tools</span>
                  <span class="runtime__loop-arrow" aria-hidden="true">&#8594;</span>
                  <span class="runtime__loop-step">write events</span>
                  <span class="runtime__loop-arrow" aria-hidden="true">&#8594;</span>
                  <span class="runtime__loop-step runtime__loop-step--decision">continue?</span>
                </div>
                <span class="runtime__loop-note">If work remains, the next turn reloads history and continues.</span>
              </div>

              <div class="runtime__support-rail">
                <span class="runtime__support-label">Inputs to each turn</span>
                <div class="runtime__support-grid">
                  <div class="runtime__support">
                    <span class="runtime__kicker">SessionStore</span>
                    <span class="runtime__support-title">Session history</span>
                    <span class="runtime__support-meta">what happened before</span>
                  </div>
                  <div class="runtime__support">
                    <span class="runtime__kicker">Catalog</span>
                    <span class="runtime__support-title">Model + provider</span>
                    <span class="runtime__support-meta">provider + model</span>
                  </div>
                  <div class="runtime__support">
                    <span class="runtime__kicker">ToolRegistry</span>
                    <span class="runtime__support-title">Available tools</span>
                    <span class="runtime__support-meta">what it can do</span>
                  </div>
                  <div class="runtime__support">
                    <span class="runtime__kicker">Compaction</span>
                    <span class="runtime__support-title">Context budget</span>
                    <span class="runtime__support-meta">stay under context</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <span class="runtime__downlink" aria-hidden="true">&#8595;</span>

          <div class="runtime__store-card runtime__store-card--compact">
            <div class="runtime__flow-head runtime__flow-head--store">
              <span class="runtime__stage-num">4</span>
              <span class="runtime__stage-copy">
                <strong>Persist replayable events</strong>
                <small>EventV2 &middot; SessionProjector &middot; SQLite</small>
              </span>
            </div>
            <span class="runtime__store-title">Durable state for resume / replay</span>
          </div>

          <p class="runtime__caption">
            Each turn streams once, settles tools, writes events, then decides whether to continue.
          </p>
        </div>
      </div>
    </div>
  </Slide>

  <!-- Slide 6: How OpenCode loads extensions -->
  <Slide id="harness" variant="dark">
    <div class="content-slide deep-slide deep-slide--usage">
      <p class="overline">Runtime Extension Points</p>
      <h2>How OpenCode Loads <span class="highlight">Extensions</span></h2>
      <p class="lead deep-slide__lead">
        Skills are discovered and pulled into context on demand. Plugins are loaded into the
        runtime and called back through hooks.
      </p>

      <div class="loader-grid">
        <div class="loader-card loader-card--skill">
          <div class="loader-card__header">
            <span class="loader-card__kicker">Prompted Behavior</span>
            <h3>Skills</h3>
          </div>
          <p class="loader-card__text">
            Configured sources and conventional <code>skill/</code> or <code>skills/</code> dirs are scanned
            for <code>SKILL.md</code>. OpenCode advertises names + descriptions; the full body enters context only when selected.
          </p>
          <div class="loader-flow">
            <span class="loader-step">skill sources</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">scan SKILL.md</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">advertise summary</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">load via tool</span>
          </div>

          <div class="intervenes intervenes--skill">
            <span class="intervenes__label">How it loads</span>
            <p class="intervenes__when">Guidance lists available skills in context by name and description</p>
            <p class="intervenes__touches">The model calls the built-in <code>skill</code> tool to inject the chosen <code>SKILL.md</code></p>
            <span class="intervenes__direction">discovered upfront &middot; pulled on demand</span>
          </div>

          <p class="loader-card__note">Best for recurring playbooks, checklists, and domain habits inside one agent.</p>
          <a class="loader-card__link" href="https://github.com/sst/opencode/blob/dev/packages/core/src/skill.ts" target="_blank" rel="noopener">
            <span class="loader-card__link-icon" aria-hidden="true">&#8599;</span>
            <span>See a real <code>SKILL.md</code> + the loader</span>
          </a>
        </div>

        <div class="loader-card loader-card--plugin">
          <div class="loader-card__header">
            <span class="loader-card__kicker">Runtime Hook Layer</span>
            <h3>Plugins</h3>
          </div>
          <p class="loader-card__text">
            OpenCode boots internal plugins and resolves configured plugin packages. Loaded plugins
            return hooks that receive mutable envelopes at model and tool boundaries.
          </p>
          <div class="loader-flow">
            <span class="loader-step">plugin config</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">resolve + import</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">return hooks</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">mutate envelopes</span>
          </div>

          <div class="intervenes intervenes--plugin">
            <span class="intervenes__label">What a plugin can change</span>
            <div class="plugin-impact" aria-label="Plugin hook mutation surfaces">
              <div class="plugin-impact__row">
                <code>chat.params</code>
                <strong>Model input</strong>
                <span>temperature, max tokens, provider options before <code>llm.stream(request)</code></span>
              </div>
              <div class="plugin-impact__row">
                <code>tool.definition</code>
                <strong>Tool schema</strong>
                <span>description + parameters the model sees before it chooses tools</span>
              </div>
              <div class="plugin-impact__row">
                <code>tool.execute.before</code>
                <strong>Tool input</strong>
                <span>inspect, mutate, or guard args before the tool executes</span>
              </div>
              <div class="plugin-impact__row">
                <code>tool.execute.after</code>
                <strong>Tool output</strong>
                <span>truncate, annotate, or recover output before it re-enters context</span>
              </div>
              <div class="plugin-impact__row plugin-impact__row--wide">
                <code>experimental.text.complete</code>
                <strong>Model output</strong>
                <span>last chance to transform completed assistant text</span>
              </div>
            </div>
            <span class="intervenes__direction">Examples: model fallback via <code>chat.params</code>; output compaction via <code>tool.execute.after</code></span>
          </div>

          <p class="loader-card__example">Think of a plugin as middleware around the model request and every tool call.</p>
          <p class="loader-card__note">Good for provider defaults, org integrations, review UX, and workflow-layer extensions.</p>
          <a class="loader-card__link" href="https://github.com/sst/opencode/blob/dev/packages/plugin/src/index.ts" target="_blank" rel="noopener">
            <span class="loader-card__link-icon" aria-hidden="true">&#8599;</span>
            <span>See OpenCode&rsquo;s plugin hook contract</span>
          </a>
        </div>
      </div>
    </div>
  </Slide>

