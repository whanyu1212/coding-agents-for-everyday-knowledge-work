    height: 1.4rem;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #ffffff;
    border-radius: 50%;
    font-size: 0.74rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .appendix-group__list {
    margin: 0;
    padding-left: 0.25rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
  }

  .appendix-group__list li {
    font-size: 0.78rem;
    color: var(--color-text);
    line-height: 1.45;
  }

  .appendix-group__list strong {
    color: #4338ca;
    font-weight: 600;
  }

  .appendix-group__list code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.05rem 0.3rem;
    background: rgba(15, 23, 42, 0.05);
    border-radius: 0.25rem;
