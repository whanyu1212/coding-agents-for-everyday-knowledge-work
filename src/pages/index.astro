    background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(30, 41, 59, 0.96));
    text-align: center;
    box-shadow: 0 24px 48px -32px rgba(15, 23, 42, 0.5);
  }

  .roads__destination-line {
    margin: 0;
    font-size: 1.12rem;
    font-weight: 600;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.92);
  }

  .roads__destination-line em {
    font-style: normal;
    color: #5eead4;
  }

  .roads__destination-sub {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    color: rgba(226, 232, 240, 0.72);
    line-height: 1.5;
  }

  /* ===== Appendix slides (A1-A3) ===== */
  .appendix {
    max-width: 72rem;
  }

  .overline--appendix {
    color: #6d28d9;
  }

  .appendix__lead {
    max-width: 48rem;
    margin-bottom: 1.2rem;
    font-size: 1rem;
  }

  .appendix__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: 1.4rem;
    align-items: stretch;
  }

  /* Stretched asides pool extra space at the bottom, before the source line */
  .appendix__aside .appendix-aside__source {
    margin-top: auto;
  }

  .appendix__main {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .appendix__aside {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 0.95rem 1rem 1rem;
    border-radius: 0.9rem;
    background: rgba(139, 92, 246, 0.06);
    border: 1px solid rgba(139, 92, 246, 0.16);
  }

  .appendix-aside__block {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .appendix-aside__title {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6d28d9;
  }

  .appendix-aside__text {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .appendix-aside__text em {
    font-style: italic;
    color: #6d28d9;
  }

  .appendix-aside__list {
    margin: 0;
    padding-left: 1rem;
    font-size: 0.78rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .appendix-aside__list li {
    margin-bottom: 0.25rem;
  }

  .appendix-aside__list code,
  .appendix-aside__text code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.06rem 0.3rem;
    background: rgba(15, 23, 42, 0.05);
    border-radius: 0.25rem;
  }

  .appendix-aside__code {
    margin: 0;
    padding: 0.55rem 0.65rem;
    background: rgba(15, 23, 42, 0.92);
    color: #e2e8f0;
    border-radius: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1.5;
    overflow-x: auto;
  }

  .appendix-aside__code code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .appendix-aside__source {
    margin: 0;
    padding-top: 0.5rem;
