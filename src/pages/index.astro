    border: 1px solid rgba(99, 102, 241, 0.14);
  }

  .demo-card--triage .demo-card__prereqs {
    background: rgba(20, 184, 166, 0.06);
    border-color: rgba(20, 184, 166, 0.18);
  }

  .demo-card__prereq-label {
    margin-right: 0.05rem;
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-dim);
  }

  .demo-card--triage .demo-card__prereq-label {
    color: #0f766e;
  }

  .demo-card__prereq {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.14rem 0.42rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(226, 232, 240, 0.9);
    color: var(--color-text);
    font-size: 0.7rem;
    line-height: 1.25;
  }

  .demo-card__prereq code {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: inherit;
    background: transparent;
  }

  .demo-card__prereq--link {
    color: #0f766e;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .demo-card__prereq--link:hover {
    transform: translateY(-1px);
    background: rgba(240, 253, 250, 0.95);
    border-color: rgba(20, 184, 166, 0.34);
  }

  .demo-card__notice {
    font-size: 0.82rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .demo-card__notice strong {
    color: var(--color-accent-dim);
  }

  .demo-card--triage .demo-card__notice strong { color: #0f766e; }

  .demo-card__placeholder {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.3rem 1rem;
    border-radius: 0.7rem;
    border: 1.5px dashed var(--color-border);
    background: repeating-linear-gradient(
      45deg,
      rgba(148, 163, 184, 0.04),
      rgba(148, 163, 184, 0.04) 10px,
      transparent 10px,
      transparent 20px
    );
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .demo-card__placeholder-icon {
    font-size: 0.9rem;
    font-style: normal;
  }

  .demos-slide__caption {
    margin-top: 1.2rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .demos-slide__caption em {
    color: var(--color-text);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .demos-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Meet OpenCode: establishing shot before the runtime deep-dive ===== */
  .opencode-intro {
    max-width: 64rem;
    margin: 0 auto;
  }

  .opencode-intro__lead {
    max-width: 46rem;
    margin-bottom: 1.6rem;
  }

  .opencode-traits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .oc-trait {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.3rem 1.2rem 1.35rem;
    border-radius: 1.1rem;
    background: #ffffff;
    border: 1px solid var(--color-border);
    box-shadow: 0 18px 34px -30px rgba(15, 23, 42, 0.16);
    overflow: hidden;
  }

  .oc-trait::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--oc-accent, rgba(148, 163, 184, 0.5));
  }

  .oc-trait--open { --oc-accent: linear-gradient(90deg, #4f46e5, #7c3aed); }
  .oc-trait--model { --oc-accent: linear-gradient(90deg, #0ea5e9, #6366f1); }
  .oc-trait--hack { --oc-accent: linear-gradient(90deg, #14b8a6, #0f766e); }

  .oc-trait__icon {
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-accent-dim);
  }

  .oc-trait--model .oc-trait__icon { color: #0284c7; }
  .oc-trait--hack .oc-trait__icon { color: #0f766e; }

  .oc-trait__icon--code {
    font-family: var(--font-mono);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .oc-trait__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .oc-trait__desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  .oc-trait__tag {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    padding-top: 0.4rem;
    letter-spacing: 0.01em;
  }

  .oc-trait__link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin-top: 0.15rem;
    padding: 0.42rem 0.65rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    border: 1px solid rgba(15, 118, 110, 0.18);
    color: #0f766e;
    font-size: 0.76rem;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .oc-trait__link:hover {
    transform: translateY(-1px);
    background: rgba(15, 118, 110, 0.12);
    border-color: rgba(15, 118, 110, 0.28);
  }

  .opencode-intro__limitation {
    margin-top: 1rem;
    max-width: 50rem;
    padding: 0.65rem 0.8rem;
    border-radius: 0.75rem;
    background: rgba(245, 158, 11, 0.08);
    border: 1px solid rgba(245, 158, 11, 0.22);
    color: #92400e;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .opencode-intro__limitation strong {
    color: #78350f;
    font-weight: 700;
  }

  .opencode-intro__bridge {
    margin-top: 1rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    max-width: 46rem;
  }

  .opencode-intro__bridge em {
    color: var(--color-text);
    font-style: italic;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .opencode-traits {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Flow diagram: CODE → systems → knowledge work ===== */
  .control-slide {
    position: relative;
    text-align: center;
    max-width: 64rem;
    margin: 0 auto;
  }

  .control-slide::before,
  .control-slide::after {
    content: '';
    position: absolute;
    pointer-events: none;
    filter: blur(24px);
    z-index: 0;
    opacity: 0.45;
  }

  .control-slide::before {
    top: -4rem;
    left: 16%;
    width: 15rem;
    height: 15rem;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.09), transparent 72%);
  }

  .control-slide::after {
    right: 8%;
    bottom: -3rem;
    width: 11rem;
    height: 11rem;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.08), transparent 74%);
  }

  .control-slide > * {
    position: relative;
    z-index: 1;
  }

  .overline--glow {
    color: var(--color-accent);
    display: inline-block;
  }

  .control-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: var(--color-text);
    max-width: 13ch;
    margin: 0.95rem auto 1.1rem;
  }

  .control-title__accent {
    background: linear-gradient(100deg, #4f46e5, #7c3aed 60%, #a855f7);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .control-lead {
    font-size: clamp(1rem, 1.45vw, 1.14rem);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.55;
  }

  .control-lead strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .control-caption {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    font-weight: 500;
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Three-column flow layout */
  .flow {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.7rem, 1.5vw, 1rem);
    max-width: 64rem;
    margin: 2.75rem auto 1.5rem;
    padding: 2rem clamp(1.2rem, 3vw, 1.8rem);
    border-radius: 1.5rem;
    border: 1px solid rgba(99, 102, 241, 0.06);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 249, 255, 0.98));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 18px 40px -34px rgba(15, 23, 42, 0.12);
    overflow: hidden;
    isolation: isolate;
  }

  .flow::before {
    content: '';
    position: absolute;
    inset: 1rem;
    inset: 1.1rem;
    border-radius: 0;
    border: 0;
    pointer-events: none;
  }

  .flow::after {
    content: '';
    position: absolute;
    left: 14%;
    right: 14%;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(203, 213, 225, 0), rgba(203, 213, 225, 0.9) 28%, rgba(203, 213, 225, 0.9) 72%, rgba(203, 213, 225, 0));
    opacity: 0.8;
    pointer-events: none;
  }

  .flow > * {
    position: relative;
    z-index: 1;
  }

  /* Left hub: the code orb */
  .flow__hub {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.45rem 0 0.25rem;
  }

  .flow__orb {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    width: clamp(6.1rem, 10vw, 7rem);
    height: clamp(6.1rem, 10vw, 7rem);
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0) 42%),
      radial-gradient(circle at 38% 32%, #8b93ff 0%, #5b63e8 42%, #4338ca 78%, #3730a3 100%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.9),
      0 0 0 4px rgba(99, 102, 241, 0.05),
      0 0 28px -14px rgba(99, 102, 241, 0.18),
      0 14px 24px -18px rgba(67, 56, 202, 0.24),
      inset 0 3px 16px rgba(255, 255, 255, 0.4),
      inset 0 -8px 18px rgba(55, 48, 140, 0.5);
  }

  .flow__orb::after {
    content: '';
    position: absolute;
    inset: -7%;
    border-radius: 50%;
    border: 1px solid rgba(99, 102, 241, 0.08);
    pointer-events: none;
  }

  .flow__orb-glow {
    position: absolute;
    inset: 20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 70%);
    filter: blur(3px);
    pointer-events: none;
  }

  .flow__orb-icon {
    position: relative;
    width: clamp(2rem, 5vw, 2.6rem);
    height: clamp(2rem, 5vw, 2.6rem);
    color: #ffffff;
    filter: drop-shadow(0 2px 4px rgba(40, 33, 120, 0.5));
  }

  .flow__orb-label {
    position: relative;
    font-family: var(--font-mono);
    font-size: clamp(0.6rem, 1.4vw, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 1px 3px rgba(40, 33, 120, 0.5);
  }

  /* Arrow columns between hub → systems → work */
  .flow__arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 4.5rem;
    padding: 0 clamp(0.3rem, 1.6vw, 0.85rem);
    flex-shrink: 0;
  }

  .flow__arrow-label {
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    padding: 0;
  }

  .flow__arrow-svg {
    width: 2.35rem;
    color: #94a3b8;
    opacity: 1;
    filter: none;
  }

  /* Middle + right columns */
  .flow__col {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 1.05rem 1.05rem 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(229, 231, 235, 0.95);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 10px 24px -24px rgba(15, 23, 42, 0.16);
    min-width: min(16rem, 100%);
  }

  .flow__col--sys {
    background: #ffffff;
  }

  .flow__col--work {
    border-color: rgba(99, 102, 241, 0.1);
    background: rgba(248, 247, 255, 0.96);
    box-shadow: 0 12px 24px -24px rgba(79, 70, 229, 0.12);
    min-width: min(17rem, 100%);
  }

  .flow__col-header {
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin-bottom: 0.05rem;
  }

  .flow__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.55rem;
    width: 100%;
    max-width: none;
  }

  /* Base chip */
  .flow__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1;
    min-height: 2.2rem;
    padding: 0.58rem 0.92rem;
    border-radius: 999px;
    white-space: nowrap;
    transition: transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
    opacity: 0;
    animation: chip-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.3s + var(--i) * 0.06s);
  }

  .flow__chip:hover {
    transform: translateY(-2px);
  }

  /* Systems chips (the plumbing) — quieter */
  .flow__chip--sys {
    color: var(--color-text-muted);
    background: #f8fafc;
    border: 1px solid rgba(229, 231, 235, 0.95);
    box-shadow: none;
  }

  .flow__chip--sys:hover {
    box-shadow: 0 8px 18px -12px rgba(15, 23, 42, 0.22);
    color: var(--color-text);
  }

  /* Work chips (the payoff) — visually dominant */
  .flow__chip--work {
    color: var(--color-accent-dim);
    background: #f5f3ff;
    border: 1px solid rgba(99, 102, 241, 0.22);
    box-shadow: none;
  }

  .flow__chip--work:hover {
    box-shadow: 0 8px 16px -16px rgba(79, 70, 229, 0.18);
  }

  @keyframes chip-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow__chip { animation: none; opacity: 1; }
  }

  @media (max-width: 640px) {
    .flow {
      flex-direction: column;
      gap: 0.95rem;
      padding: 1.35rem 0.95rem 1.5rem;
    }

    .flow::after {
      display: none;
    }

    .flow__arrow {
      flex-direction: row;
      min-width: 0;
      padding: 0;
    }

    .flow__arrow-svg {
      transform: rotate(90deg);
      width: 2.25rem;
    }

    .flow__col {
      align-items: center;
      width: min(100%, 24rem);
    }

    .flow__col--work {
      transform: none;
    }

    .flow__col-header {
      align-self: center;
    }

    .flow__chips {
      justify-content: center;
      max-width: none;
    }
  }

  /* ===== Slide 5: OpenCode runtime architecture ===== */
  .runtime {
    position: relative;
    text-align: center;
    width: min(92vw, 80rem);
    max-width: none;
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .runtime::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 4.5rem;
    width: 36rem;
    height: 14rem;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12), transparent 70%);
    filter: blur(36px);
    pointer-events: none;
  }

  .runtime > * {
    position: relative;
    z-index: 1;
  }

  .runtime__lead {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0;
  }

  .runtime__split {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    align-items: stretch;
    gap: 1.15rem;
    margin-top: 1.05rem;
  }

  .runtime__left {
    display: flex;
    flex-direction: column;
    gap: 0.62rem;
    min-width: 0;
    min-height: 100%;
  }

  .runtime__screenshot {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1 1 auto;
    min-height: 0;
    margin: 0;
    padding: 0.55rem;
    border-radius: 1.15rem;
    background: linear-gradient(180deg, #202436, #161927);
    border: 1px solid rgba(15, 23, 42, 0.16);
    box-shadow: 0 24px 50px -36px rgba(15, 23, 42, 0.45);
    overflow: hidden;
  }

  .runtime__screenshot img {
    display: block;
    width: 100%;
    flex: 1 1 auto;
    min-height: 0;
    height: clamp(21rem, 45vh, 31rem);
    object-fit: cover;
    object-position: left top;
    border-radius: 0.75rem;
  }

  .runtime__screenshot figcaption {
    padding: 0 0.25rem 0.1rem;
    color: #c7d2fe;
    font-size: 0.78rem;
    line-height: 1.4;
    text-align: left;
  }

  .runtime__diagram {
    margin-top: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    min-width: 0;
    min-height: 100%;
    gap: 0.42rem;
  }

  .runtime__split .runtime__support-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .runtime__flow-stage {
    width: 100%;
    margin: 0 auto;
    padding: 0.72rem;
    border-radius: 1.15rem;
    text-align: left;
    background: linear-gradient(180deg, #ffffff, #fbfcff);
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 14px 28px -26px rgba(15, 23, 42, 0.18);
  }

  .runtime__flow-head {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.55rem;
  }

  .runtime__flow-head--frame {
    position: relative;
    z-index: 1;
    margin-bottom: 0.7rem;
  }

  .runtime__flow-head--store {
    margin-bottom: 0.35rem;
  }

  .runtime__stage-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    flex: 0 0 auto;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-accent), #7c3aed);
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1;
    box-shadow: 0 8px 18px -12px rgba(79, 70, 229, 0.9);
  }

  .runtime__stage-num--small {
    width: 1.45rem;
    height: 1.45rem;
    font-size: 0.72rem;
  }

  .runtime__stage-copy,
  .runtime__core-copy {
    display: flex;
    flex-direction: column;
    gap: 0.02rem;
    min-width: 0;
  }

  .runtime__stage-copy strong {
    color: var(--color-text);
    font-size: 0.84rem;
    line-height: 1.18;
    letter-spacing: -0.01em;
  }

  .runtime__stage-copy small {
    color: var(--color-text-muted);
    font-size: 0.67rem;
    line-height: 1.25;
  }

  .runtime__strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
    gap: 0.45rem;
    width: 100%;
    margin: 0;
    padding: 0.25rem;
    border-radius: 0.95rem;
    background: rgba(248, 250, 252, 0.8);
    border: 1px solid rgba(226, 232, 240, 0.78);
  }

  .runtime__strip-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.08rem;
    min-height: 3.45rem;
    padding: 0.48rem 0.55rem;
    border-radius: 0.78rem;
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.9);
    transition: background 0.2s ease;
  }

  .runtime__strip-item:hover {
    background: rgba(248, 250, 252, 0.92);
  }

  .runtime__strip-item:not(:last-child) {
    border-right: 0;
  }

  .runtime__strip-item:not(:last-child)::after {
    content: '\2192';
    position: absolute;
    right: -0.64rem;
    top: 50%;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.9rem;
    height: 0.9rem;
    transform: translateY(-50%);
    border-radius: 999px;
    color: #64748b;
    background: #ffffff;
    border: 1px solid rgba(203, 213, 225, 0.9);
    font-size: 0.62rem;
    font-weight: 800;
  }

  .runtime__strip-item strong {
    font-size: 0.86rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .runtime__strip-item small {
    font-size: 0.67rem;
    color: var(--color-text-muted);
  }

  .runtime__strip-arrow {
    display: none;
  }

  .runtime__downlink {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    width: 1.65rem;
    height: 1.28rem;
    margin: -0.1rem 0;
    border-radius: 999px;
    color: var(--color-accent-dim);
    background: rgba(238, 242, 255, 0.86);
    border: 1px solid rgba(99, 102, 241, 0.12);
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1;
  }

  .runtime__band {
    margin-bottom: 0.9rem;
  }

  .runtime__band-label,
  .runtime__frame-label,
  .runtime__store-label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    margin-bottom: 0.65rem;
  }

  .runtime__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 0.8rem;
  }

  .runtime__top-arrow {
    width: 2.4rem;
    height: 0.75rem;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .runtime__node,
  .runtime__support,
  .runtime__store-card {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 10px 24px -22px rgba(15, 23, 42, 0.14);
  }

  .runtime__node {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.95rem 1rem;
    border-radius: 1.05rem;
    min-height: 6.5rem;
    justify-content: center;
  }

  .runtime__node--plain {
    text-align: left;
  }

  .runtime__node-title,
  .runtime__support-title,
  .runtime__store-title,
  .runtime__core-title {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.25;
  }

  .runtime__kicker {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-accent);
  }

  .runtime__node-meta,
  .runtime__support-meta,
  .runtime__store-meta,
  .runtime__core-sub {
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .runtime__node-meta code,
  .runtime__support-meta code,
  .runtime__core-sub code {
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .runtime__frame {
    position: relative;
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    width: min(100%, 44rem);
    margin: 0 auto;
    padding: 0.78rem 0.85rem 0.88rem;
    border-radius: 1.35rem;
    border: 1px solid rgba(226, 232, 240, 0.9);
    background: linear-gradient(180deg, #fcfcff, #fafbff);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 18px 38px -34px rgba(15, 23, 42, 0.18);
    overflow: hidden;
    isolation: isolate;
  }

  .runtime__frame-label {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(99, 102, 241, 0.08);
    color: var(--color-accent-dim);
  }

  .runtime__frame::before {
    display: none;
  }

  .runtime__frame::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 46%;
    width: 28rem;
    height: 12rem;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.1), transparent 68%);
    pointer-events: none;
    z-index: 0;
  }

  .runtime__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.45fr) minmax(0, 1.05fr);
    grid-template-areas:
      '. top .'
      'left core right'
      '. bottom .';
    align-items: center;
    gap: 0.85rem;
  }

  .runtime__compact {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    position: relative;
    z-index: 1;
  }

  .runtime__support-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    width: 100%;
    gap: 0.55rem;
  }

  .runtime__support {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.22rem;
    justify-content: center;
    min-height: 4.8rem;
    padding: 0.68rem 0.58rem;
    border-radius: 0.85rem;
    text-align: center;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    box-shadow: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .runtime__support:hover {
    transform: translateY(-1px);
    border-color: rgba(203, 213, 225, 0.95);
  }

  .runtime__support::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    border-radius: 999px;
    background: var(--runtime-support-accent, rgba(148, 163, 184, 0.5));
  }

  .runtime__support:nth-child(1) { --runtime-support-accent: rgba(99, 102, 241, 0.5); }
  .runtime__support:nth-child(2) { --runtime-support-accent: rgba(139, 92, 246, 0.45); }
  .runtime__support:nth-child(3) { --runtime-support-accent: rgba(45, 212, 191, 0.5); }
  .runtime__support:nth-child(4) { --runtime-support-accent: rgba(251, 191, 36, 0.55); }

  .runtime__support .runtime__kicker {
    color: var(--color-text-muted);
  }

  .runtime__support-title {
    font-size: 0.82rem;
  }

  .runtime__support-meta {
    font-size: 0.62rem;
    line-height: 1.3;
  }

  .runtime__support-rail {
    width: 100%;
    text-align: center;
  }

  .runtime__support-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.45rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    color: #64748b;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(226, 232, 240, 0.85);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    line-height: 1;
    text-transform: uppercase;
  }

  .runtime__support--top { grid-area: top; }
  .runtime__support--left { grid-area: left; }
  .runtime__support--right { grid-area: right; }
  .runtime__support--bottom { grid-area: bottom; }

  .runtime__core {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    justify-content: center;
    width: min(100%, 32rem);
    padding: 0.95rem 1rem 0.85rem;
    border-radius: 1.08rem;
    background: linear-gradient(180deg, #ffffff, #f8f6ff);
    border: 1px solid rgba(129, 140, 248, 0.2);
    box-shadow:
      0 20px 42px -34px rgba(79, 70, 229, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    overflow: hidden;
  }

  .runtime__core-head {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
  }

  .runtime__core-copy {
    align-items: flex-start;
    text-align: left;
  }

  .runtime__core .runtime__core-title {
    font-size: 1.16rem;
  }

  .runtime__core::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 35%);
    pointer-events: none;
  }

  .runtime__core .runtime__kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    position: relative;
    z-index: 1;
  }

  .runtime__core::before {
    display: none;
  }

  .runtime__pipeline {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
    max-width: 20rem;
  }

  .runtime__loop {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.25rem 0.32rem;
    width: 100%;
    margin-top: 0.05rem;
  }

  .runtime__loop-step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.62rem;
    padding: 0.3rem 0.5rem;
    border-radius: 999px;
    color: var(--color-accent-dim);
    background: #f8f7ff;
    border: 1px solid rgba(99, 102, 241, 0.14);
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1.15;
    white-space: nowrap;
  }

  .runtime__loop-step--decision {
    color: #0f766e;
    background: rgba(240, 253, 250, 0.9);
    border-color: rgba(20, 184, 166, 0.2);
  }

  .runtime__loop-arrow {
    color: #94a3b8;
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1;
  }

  .runtime__loop-note {
    position: relative;
    z-index: 1;
    display: inline-flex;
    padding: 0.28rem 0.58rem;
    border-radius: 999px;
    color: #64748b;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(226, 232, 240, 0.72);
    font-size: 0.64rem;
    line-height: 1.25;
  }

  .runtime__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.7rem;
    padding: 0.34rem 0.58rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-accent-dim);
    background: #f8f7ff;
    border: 1px solid rgba(99, 102, 241, 0.12);
  }

  .runtime__store {
    position: relative;
    margin-top: 0.95rem;
  }

  .runtime__store::before {
    display: none;
  }

  .runtime__store-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.85rem 1rem;
    border-radius: 1rem;
    max-width: 40rem;
    margin: 0 auto;
  }

  .runtime__store-card--compact {
    align-items: stretch;
    width: min(100%, 34rem);
    max-width: 34rem;
    padding: 0.72rem 0.85rem;
    background: linear-gradient(180deg, #eef2ff, #ffffff);
    border-color: rgba(99, 102, 241, 0.18);
    box-shadow: 0 14px 28px -24px rgba(79, 70, 229, 0.22);
  }

  .runtime__store-card--compact .runtime__store-title {
    align-self: center;
    font-size: 0.9rem;
  }

  .runtime__caption {
    margin-top: 0.15rem;
    font-size: 0.86rem;
    color: #64748b;
    max-width: 44rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== Slide 6-7: Advanced usage ===== */
  .deep-slide {
    position: relative;
    max-width: 66rem;
    margin: 0 auto;
  }

  .deep-slide::before {
    content: '';
    position: absolute;
    top: 5rem;
    right: 8%;
    width: 15rem;
    height: 15rem;
    border-radius: 50%;
    filter: blur(36px);
    pointer-events: none;
    opacity: 0.72;
  }

  .deep-slide--usage::before {
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12), transparent 70%);
  }

  .deep-slide--practice::before {
    background: radial-gradient(circle, rgba(20, 184, 166, 0.12), transparent 70%);
  }

  .deep-slide > * {
    position: relative;
    z-index: 1;
  }

  .deep-slide__lead {
    max-width: 43rem;
    margin-bottom: 0;
  }

  .deep-slide--usage h2,
  .omo-slide h2 {
    margin-bottom: 0.55rem;
  }

  .deep-slide--usage .deep-slide__lead,
  .omo-slide .deep-slide__lead {
    font-size: 0.98rem;
    line-height: 1.45;
  }

  .deep-slide__takeaway {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.8rem;
    border-radius: 999px;
    margin-top: 0.8rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-accent-dim);
    border: 1px solid rgba(99, 102, 241, 0.12);
    background: rgba(255, 255, 255, 0.82);
  }

  .deep-slide--practice .deep-slide__takeaway {
    color: #0f766e;
    border-color: rgba(20, 184, 166, 0.16);
  }

  .loader-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 0.85rem;
  }

  .loader-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.82rem 0.86rem 0.88rem;
    border-radius: 1.15rem;
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 18px 34px -30px rgba(15, 23, 42, 0.16);
    overflow: hidden;
  }

  .loader-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--loader-accent, rgba(148, 163, 184, 0.5));
  }

  .loader-card--skill { --loader-accent: linear-gradient(90deg, #6366f1, #8b5cf6); }
  .loader-card--plugin { --loader-accent: linear-gradient(90deg, #14b8a6, #0f766e); }

  .loader-card__header {
    display: grid;
    gap: 0.18rem;
  }

  .loader-card__kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-accent);
  }

  .loader-card__header h3 {
    font-size: 1rem;
    line-height: 1.2;
  }

  .loader-card__text,
  .loader-card__note {
    font-size: 0.77rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .loader-card__link {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0;
    padding: 0.24rem 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-accent-dim);
    background: rgba(99, 102, 241, 0.07);
    border: 1px solid rgba(99, 102, 241, 0.16);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .loader-card--plugin .loader-card__link {
    color: #0f766e;
    background: rgba(20, 184, 166, 0.08);
    border-color: rgba(20, 184, 166, 0.2);
  }

  .loader-card__link:hover {
    transform: translateY(-1px);
    background: rgba(99, 102, 241, 0.12);
    border-color: rgba(99, 102, 241, 0.3);
  }

  .loader-card--plugin .loader-card__link:hover {
    background: rgba(20, 184, 166, 0.14);
    border-color: rgba(20, 184, 166, 0.32);
  }

  .loader-card__link code {
    font-family: var(--font-mono);
    font-size: 0.92em;
  }

  .loader-card__link-icon {
    font-size: 0.85rem;
    line-height: 1;
  }

  .loader-card__text code {
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--color-text);
  }

  .loader-card__example {
    align-self: flex-start;
    padding: 0.24rem 0.5rem;
    border-radius: 0.5rem;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.18);
    font-size: 0.7rem;
    color: #0f766e;
    line-height: 1.4;
  }

  /* Intervention block: when + what + direction */
  .intervenes {
    margin-top: 0.05rem;
    padding: 0.48rem 0.55rem 0.52rem;
    border-radius: 0.7rem;
    background: rgba(15, 23, 42, 0.03);
    border: 1px solid rgba(15, 23, 42, 0.08);
    display: grid;
    gap: 0.22rem;
  }

  .intervenes__label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  .intervenes__when {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-text);
    line-height: 1.32;
    font-weight: 600;
  }

  .intervenes__when code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    padding: 0.04em 0.3em;
    border-radius: 0.3em;
    background: rgba(99, 102, 241, 0.1);
    color: var(--color-accent-dim);
    font-weight: 500;
  }

  .intervenes__touches {
    margin: 0;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.34;
  }

  .intervenes__hooks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .intervenes__hooks code {
    display: inline-flex;
    align-items: center;
    padding: 0.14rem 0.4rem;
    border-radius: 0.35rem;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.16);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #0f766e;
    line-height: 1.2;
    white-space: nowrap;
  }

  .intervenes__hooks-more {
    display: inline-flex;
    align-items: center;
    padding: 0.14rem 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .plugin-impact {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.28rem;
  }

  .plugin-impact__row {
    display: grid;
    gap: 0.12rem;
    padding: 0.35rem 0.42rem;
    border-radius: 0.56rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(20, 184, 166, 0.14);
  }

  .plugin-impact__row--wide {
    grid-column: 1 / -1;
  }

  .plugin-impact__row code {
    justify-self: start;
    padding: 0.12rem 0.36rem;
    border-radius: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.56rem;
    line-height: 1.2;
    color: #0f766e;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.15);
  }

  .plugin-impact__row strong {
    color: var(--color-text);
    font-size: 0.67rem;
    line-height: 1.2;
  }

  .plugin-impact__row span {
    color: var(--color-text-muted);
    font-size: 0.61rem;
    line-height: 1.24;
  }

  .plugin-impact__row span code,
  .intervenes__direction code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: #0f766e;
  }

  .intervenes__direction {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .intervenes--skill .intervenes__direction {
    color: #6366f1;
  }

  .intervenes--plugin .intervenes__direction {
    color: #0f766e;
  }

  .loader-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
  }

  .loader-step,
  .loader-connector {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.58rem;
    border-radius: 999px;
    font-size: 0.66rem;
    font-weight: 600;
  }

  .loader-step {
    padding: 0.25rem 0.5rem;
    color: var(--color-accent-dim);
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.12);
  }

  .loader-card--plugin .loader-step {
    color: #0f766e;
    background: rgba(20, 184, 166, 0.08);
    border-color: rgba(20, 184, 166, 0.14);
  }

  .loader-connector {
    min-width: 1.4rem;
    color: #94a3b8;
  }

  .mini-code {
    border-radius: 0.95rem;
    overflow: hidden;
    background: #0f172a;
    border: 1px solid rgba(30, 41, 59, 0.95);
    box-shadow: 0 18px 36px -30px rgba(15, 23, 42, 0.34);
  }

  .mini-code__header {
    position: relative;
    padding: 0.6rem 0.85rem 0.6rem 3.7rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #a5b4fc;
    background: rgba(15, 23, 42, 0.96);
    border-bottom: 1px solid rgba(51, 65, 85, 0.9);
  }

  .mini-code__header::before {
    content: '';
    position: absolute;
    left: 0.95rem;
    top: 50%;
    width: 1.9rem;
    height: 0.52rem;
    transform: translateY(-50%);
    background:
      radial-gradient(circle, #fb7185 55%, transparent 56%) 0 50% / 0.52rem 0.52rem no-repeat,
      radial-gradient(circle, #fbbf24 55%, transparent 56%) 0.7rem 50% / 0.52rem 0.52rem no-repeat,
      radial-gradient(circle, #34d399 55%, transparent 56%) 1.4rem 50% / 0.52rem 0.52rem no-repeat;
  }

  .mini-code__pre {
    margin: 0;
    padding: 0.75rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.5;
    color: #e2e8f0;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(17, 24, 39, 1));
  }

  /* ===== Slide 7: Oh-My-OpenAgent deep dive ===== */
  .omo-slide {
    position: relative;
    width: min(92vw, 74rem);
    max-width: none;
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .omo-slide .deep-slide__lead {
    max-width: 52rem;
    margin-bottom: 0;
  }

  .omo-deep-grid {
    display: grid;
    grid-template-columns: minmax(18rem, 0.9fr) minmax(0, 1.55fr);
    gap: 0.62rem;
    align-items: stretch;
    margin-top: 0.62rem;
  }

  .omo-build-card,
  .omo-detail-card {
    position: relative;
    border-radius: 1rem;
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 18px 34px -30px rgba(15, 23, 42, 0.16);
    overflow: hidden;
  }

  .omo-build-card {
    padding: 0.66rem 0.75rem 0.72rem;
  }

  .omo-build-card::before,
  .omo-detail-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--omo-detail-accent, linear-gradient(90deg, #6366f1, #14b8a6));
  }

  .omo-build-card__kicker,
  .omo-detail-card__kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: var(--color-text-muted);
  }

  .omo-build-card h3 {
    margin: 0.16rem 0 0.45rem;
    color: var(--color-text);
    font-size: 0.9rem;
    line-height: 1.25;
  }

  .omo-boot-steps {
    display: grid;
    gap: 0.3rem;
  }

  .omo-boot-step {
    display: grid;
    grid-template-columns: 1.35rem 1fr;
    gap: 0.28rem 0.42rem;
    align-items: start;
    padding: 0.34rem 0.45rem;
    border-radius: 0.65rem;
    background: rgba(248, 250, 252, 0.86);
    border: 1px solid rgba(226, 232, 240, 0.85);
  }

  .omo-boot-step__num {
    grid-row: span 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.08rem;
    height: 1.08rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.12);
    color: var(--color-accent-dim);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 800;
  }

  .omo-boot-step strong {
    color: var(--color-text);
    font-size: 0.72rem;
    line-height: 1.2;
  }

  .omo-boot-step small {
    color: var(--color-text-muted);
    font-size: 0.62rem;
    line-height: 1.28;
  }

  .omo-boot-step code,
  .omo-detail-card code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--color-accent-dim);
  }

  .omo-detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.46rem;
  }

  .omo-detail-card {
    display: grid;
    gap: 0.2rem;
    padding: 0.58rem 0.68rem 0.64rem;
  }

  .omo-detail-card--agents { --omo-detail-accent: linear-gradient(90deg, #6366f1, #8b5cf6); }
  .omo-detail-card--tools { --omo-detail-accent: linear-gradient(90deg, #14b8a6, #0f766e); }
  .omo-detail-card--hooks { --omo-detail-accent: linear-gradient(90deg, #f59e0b, #f97316); }
  .omo-detail-card--state { --omo-detail-accent: linear-gradient(90deg, #0ea5e9, #2563eb); }

  .omo-detail-card strong {
    color: var(--color-text);
    font-size: 0.8rem;
    line-height: 1.25;
  }

  .omo-detail-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.66rem;
    line-height: 1.32;
  }

  /* Three-layer architecture: planning | execution | workers (workers wider) */
  .omo-architecture {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 0.8fr) auto minmax(0, 1.6fr);
    gap: 0.5rem;
    align-items: stretch;
    margin-top: 0.5rem;
  }

  .omo-layer {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
    padding: 0.52rem 0.62rem 0.58rem;
    border-radius: 1.1rem;
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 18px 34px -30px rgba(15, 23, 42, 0.14);
    overflow: hidden;
  }

  .omo-layer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--omo-accent, rgba(148, 163, 184, 0.5));
  }

  .omo-layer--planning { --omo-accent: linear-gradient(90deg, #6366f1, #8b5cf6); }
  .omo-layer--execution { --omo-accent: linear-gradient(90deg, #f59e0b, #f97316); }
  .omo-layer--workers { --omo-accent: linear-gradient(90deg, #14b8a6, #0f766e); }

  .omo-layer__kicker {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .omo-layer__agents {
    display: flex;
    flex-wrap: wrap;
    gap: 0.32rem;
  }

  .omo-layer__agents--grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(6.4rem, 1fr));
    gap: 0.3rem;
  }

  .omo-agent {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.4rem;
    border-radius: 0.55rem;
    background: rgba(248, 250, 252, 0.95);
    border: 1px solid rgba(226, 232, 240, 0.9);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .omo-agent--lead {
    background: rgba(255, 255, 255, 1);
    border-color: rgba(99, 102, 241, 0.32);
    color: var(--color-text);
    font-weight: 600;
    box-shadow: 0 4px 10px -8px rgba(99, 102, 241, 0.35);
  }

  .omo-layer--execution .omo-agent--lead {
    border-color: rgba(245, 158, 11, 0.38);
    box-shadow: 0 4px 10px -8px rgba(245, 158, 11, 0.4);
  }

  .omo-layer--workers .omo-agent--lead {
    border-color: rgba(20, 184, 166, 0.38);
    box-shadow: 0 4px 10px -8px rgba(20, 184, 166, 0.4);
  }

  .omo-layer__note {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .omo-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    color: rgba(148, 163, 184, 0.85);
    font-weight: 300;
  }

  /* Runtime echo — compressed reference back to slide 5 */
  .omo-runtime-base {
    margin-top: 0.6rem;
    padding: 0.55rem 0.95rem 0.6rem;
    border-radius: 0.95rem;
    background: rgba(15, 23, 42, 0.035);
    border: 1px dashed rgba(15, 23, 42, 0.12);
    display: grid;
    gap: 0.3rem;
  }

  .omo-runtime-base__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .omo-runtime-base__strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text);
  }

  .omo-runtime-base__strip span {
    position: relative;
  }

  .omo-runtime-base__strip span:not(:last-child)::after {
    content: '·';
    position: absolute;
    right: -0.75rem;
    color: rgba(148, 163, 184, 0.7);
  }

  .omo-runtime-base__caption {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Workflow narrative — numbered steps showing how a task flows through OmO */
  .omo-workflow {
    margin-top: 0.45rem;
    padding: 0.46rem 0.62rem 0.52rem;
    border-radius: 1rem;
    background: rgba(99, 102, 241, 0.04);
    border: 1px solid rgba(99, 102, 241, 0.1);
  }

  .omo-workflow__kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .omo-workflow__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.16rem;
  }

  .omo-workflow__steps li {
    display: grid;
    grid-template-columns: 1.35rem 1fr;
    gap: 0.42rem;
    align-items: baseline;
    font-size: 0.7rem;
    color: var(--color-text);
    line-height: 1.3;
  }

  .omo-workflow__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #ffffff;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 1;
  }

  .omo-workflow__text code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    padding: 0.05em 0.32em;
    border-radius: 0.3em;
    background: rgba(99, 102, 241, 0.1);
    color: var(--color-accent-dim);
  }

  /* Routing strip — concrete category→model evidence */
  .omo-routing {
    margin-top: 0.65rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.55rem;
  }

  .omo-routing__label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .omo-routing__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.18);
    font-size: 0.78rem;
    color: #0f766e;
  }

  .omo-routing__chip code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    color: #0f766e;
    font-weight: 600;
  }

  /* Punchline — replaces the inline pill takeaway for this slide only */
  .omo-takeaway {
    margin-top: 0.52rem;
    padding: 0.56rem 0.78rem 0.62rem;
    border-radius: 1.1rem;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
    color: #ffffff;
    box-shadow: 0 24px 48px -32px rgba(15, 23, 42, 0.5);
  }

  .omo-takeaway__line {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.92);
  }

  .omo-takeaway__accent {
    color: #5eead4;
  }

  .omo-takeaway__sub {
    margin: 0.18rem 0 0;
    font-size: 0.7rem;
    color: rgba(226, 232, 240, 0.7);
    line-height: 1.5;
  }

  /* ===== Slide 8: What the harness gives you ===== */
  .harness-power {
    max-width: 72rem;
  }

  .harness-power__lead {
    max-width: 48rem;
    margin-bottom: 1.4rem;
  }

  .harness-power__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }

  .pillar {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.15rem 1.05rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 18px 40px -28px rgba(15, 23, 42, 0.35);
    overflow: hidden;
  }

  .pillar::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--pillar-accent, linear-gradient(90deg, #6366f1, #8b5cf6));
  }

  .pillar--routing { --pillar-accent: linear-gradient(90deg, #06b6d4, #0891b2); --pillar-chip-bg: rgba(6, 182, 212, 0.08); --pillar-chip-border: rgba(6, 182, 212, 0.18); --pillar-chip-text: #0e7490; }
  .pillar--continuation { --pillar-accent: linear-gradient(90deg, #8b5cf6, #6d28d9); --pillar-chip-bg: rgba(139, 92, 246, 0.08); --pillar-chip-border: rgba(139, 92, 246, 0.18); --pillar-chip-text: #6d28d9; }
  .pillar--guardrails { --pillar-accent: linear-gradient(90deg, #f59e0b, #d97706); --pillar-chip-bg: rgba(245, 158, 11, 0.08); --pillar-chip-border: rgba(245, 158, 11, 0.22); --pillar-chip-text: #b45309; }

  .pillar__head {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    margin-bottom: 0.7rem;
  }

  .pillar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 0.55rem;
    background: var(--pillar-chip-bg);
    border: 1px solid var(--pillar-chip-border);
    color: var(--pillar-chip-text);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    flex-shrink: 0;
  }

  .pillar__head-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .pillar__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .pillar__sub {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .pillar__mechanism {
    margin: 0 0 0.75rem;
    padding: 0.4rem 0.55rem;
    border-radius: 0.5rem;
    background: rgba(15, 23, 42, 0.04);
    border: 1px solid rgba(15, 23, 42, 0.06);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .pillar__mechanism code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text);
    background: transparent;
    padding: 0;
  }

  .pillar__chips {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.8rem;
    flex-grow: 1;
  }

  .pillar__chip {
    display: block;
    padding: 0.35rem 0.55rem;
    border-radius: 0.45rem;
    background: var(--pillar-chip-bg);
    border: 1px solid var(--pillar-chip-border);
    font-size: 0.74rem;
    color: var(--color-text);
    line-height: 1.35;
  }

  .pillar__chip strong {
    color: var(--pillar-chip-text);
    font-weight: 600;
  }

  .pillar__chip code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.05rem 0.3rem;
    border-radius: 0.25rem;
    background: rgba(255, 255, 255, 0.6);
    color: var(--pillar-chip-text);
  }

  .pillar__before-after {
    margin: 0;
    padding-top: 0.65rem;
    border-top: 1px dashed rgba(15, 23, 42, 0.12);
    font-size: 0.78rem;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .harness-power__strip {
    margin-top: 1.1rem;
    padding: 0.9rem 1.2rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
    color: #ffffff;
    text-align: center;
    box-shadow: 0 24px 48px -32px rgba(15, 23, 42, 0.5);
  }

  .harness-power__strip-line {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.85);
  }

  .harness-power__strip-line--accent {
    color: #5eead4;
    font-size: 1.25rem;
    margin-top: 0.2rem;
  }

  /* ===== Slide 9.5: RTK — Rust Token Killer ===== */
  .rtk {
    max-width: 72rem;
  }

  .rtk__lead {
    max-width: 52rem;
    margin-bottom: 1.3rem;
  }

  .rtk__body {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 1.1rem;
    align-items: start;
  }

  .rtk__col-kicker {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
  }

  /* Left column: four mechanisms */
  .rtk__mechanisms {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rtk-mech {
    position: relative;
    padding: 0.6rem 0.75rem 0.6rem 0.85rem;
    border-radius: 0.6rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 12px 28px -24px rgba(15, 23, 42, 0.4);
    overflow: hidden;
  }

  .rtk-mech::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 3px;
    background: var(--rtk-mech-accent, #6366f1);
  }

  .rtk-mech--filter { --rtk-mech-accent: linear-gradient(180deg, #6366f1, #4338ca); }
  .rtk-mech--group { --rtk-mech-accent: linear-gradient(180deg, #0ea5e9, #0284c7); }
  .rtk-mech--dedup { --rtk-mech-accent: linear-gradient(180deg, #14b8a6, #0f766e); }
  .rtk-mech--truncate { --rtk-mech-accent: linear-gradient(180deg, #f59e0b, #d97706); }

  .rtk-mech__tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.15rem;
  }

  .rtk-mech p {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* Right column: token ledger */
  .rtk__ledger {
    display: flex;
    flex-direction: column;
  }

  .rtk-ledger__rows {
    display: flex;
    flex-direction: column;
    border-radius: 0.7rem;
    border: 1px solid rgba(15, 23, 42, 0.1);
    background: rgba(255, 255, 255, 0.92);
    overflow: hidden;
    box-shadow: 0 14px 32px -26px rgba(15, 23, 42, 0.4);
  }

  .rtk-ledger__row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 0.8rem;
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }

  .rtk-ledger__row:last-child {
    border-bottom: none;
  }

  .rtk-ledger__cmd {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text);
  }

  .rtk-ledger__nums {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    justify-self: end;
  }

  .rtk-ledger__pct {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: #0f766e;
    min-width: 3.2rem;
    text-align: right;
  }

  .rtk-ledger__total {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 0.8rem;
    margin-top: 0.55rem;
    padding: 0.7rem 0.85rem;
    border-radius: 0.7rem;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
    box-shadow: 0 18px 38px -28px rgba(15, 23, 42, 0.55);
  }

  .rtk-ledger__total-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }

  .rtk-ledger__total-nums {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.7);
    white-space: nowrap;
    justify-self: end;
  }

  .rtk-ledger__total-pct {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    color: #5eead4;
    min-width: 3.2rem;
    text-align: right;
  }

  /* Footer: strength + install */
  .rtk__footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
    margin-top: 1.2rem;
  }

  .rtk__strength,
  .rtk__install {
    padding: 0.85rem 1rem;
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
  }

  .rtk__strength-kicker,
  .rtk__install-kicker {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-bottom: 0.45rem;
  }

  .rtk__strength p,
  .rtk__install-note {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .rtk__strength code,
  .rtk__install-note code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.05rem 0.3rem;
    border-radius: 0.25rem;
    background: rgba(15, 23, 42, 0.05);
    color: var(--color-text);
  }

  .rtk__install-code {
    margin: 0 0 0.5rem;
    padding: 0.5rem 0.7rem;
    border-radius: 0.5rem;
    background: #1a1a2e;
    overflow-x: auto;
  }

  .rtk__install-code code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #5eead4;
  }

  /* ===== Slide 9.6: RTK in action — pytest before/after ===== */
  .rtk-ex {
    max-width: 74rem;
  }

  .rtk-ex__cmd,
  .rtk-ex h2 code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.05rem 0.35rem;
    border-radius: 0.3rem;
    background: rgba(99, 102, 241, 0.12);
    color: var(--color-accent-dim);
  }

  .rtk-ex__lead {
    max-width: 54rem;
    margin-bottom: 1.4rem;
  }

  .rtk-ex__diff {
    display: grid;
    grid-template-columns: 1fr auto 0.78fr;
    gap: 0.9rem;
    align-items: stretch;
  }

  /* terminal panes */
  .rtk-pane {
    display: flex;
    flex-direction: column;
    border-radius: 0.7rem;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: #11131f;
    box-shadow: 0 24px 50px -34px rgba(0, 0, 0, 0.8);
  }

  .rtk-pane--after {
    border-color: rgba(94, 234, 212, 0.3);
  }

  .rtk-pane__bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.7rem;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
  }

  .rtk-pane__dots {
    display: inline-flex;
    gap: 0.28rem;
    flex-shrink: 0;
  }

  .rtk-pane__dots i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: rgba(148, 163, 184, 0.35);
  }

  .rtk-pane__dots i:nth-child(1) { background: #f87171; }
  .rtk-pane__dots i:nth-child(2) { background: #fbbf24; }
  .rtk-pane__dots i:nth-child(3) { background: #34d399; }

  .rtk-pane__title {
    font-size: 0.72rem;
    color: rgba(226, 232, 240, 0.7);
    flex-grow: 1;
  }

  .rtk-pane__title code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(226, 232, 240, 0.92);
    background: transparent;
    padding: 0;
  }

  .rtk-pane__cost {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.12rem 0.45rem;
    border-radius: 0.3rem;
    flex-shrink: 0;
  }

  .rtk-pane__cost--high {
    color: #fca5a5;
    background: rgba(248, 113, 113, 0.12);
  }

  .rtk-pane__cost--low {
    color: #5eead4;
    background: rgba(94, 234, 212, 0.12);
  }

  .rtk-pane__body {
    margin: 0;
    padding: 0.75rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.5;
    color: #e2e8f0;
    overflow-x: auto;
    flex-grow: 1;
    white-space: pre;
  }

  .rtk-pane__body code {
    font-family: inherit;
    color: inherit;
  }

  .rtk-pane--after .rtk-pane__body {
    font-size: 0.78rem;
    line-height: 1.7;
  }

  /* token classes inside the terminals */
  .rtk-dim { color: rgba(148, 163, 184, 0.42); }
  .rtk-fail { color: #f87171; font-weight: 500; }
  .rtk-ok { color: #5eead4; font-weight: 500; }
  .rtk-key { color: #c7d2fe; font-weight: 500; }

  .rtk-pane__note {
    margin: 0;
    padding: 0.5rem 0.85rem 0.7rem;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-style: italic;
    color: rgba(94, 234, 212, 0.8);
    line-height: 1.4;
    border-top: 1px dashed rgba(94, 234, 212, 0.2);
  }

  /* the arrow between panes */
  .rtk-ex__arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0 0.1rem;
  }

  .rtk-ex__arrow-glyph {
    font-size: 1.6rem;
    color: #0f766e;
    line-height: 1;
  }

  .rtk-ex__arrow-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-align: center;
    color: var(--color-text-muted);
    max-width: 4.5rem;
    line-height: 1.3;
  }

  .rtk-ex__rule {
    margin: 1rem 0 0;
    padding: 0.7rem 0.95rem;
    border-radius: 0.7rem;
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid rgba(99, 102, 241, 0.2);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--color-text);
  }

  .rtk-ex__rule-tag {
    display: inline-block;
    margin-right: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #ffffff;
    padding: 0.1rem 0.45rem;
    border-radius: 0.3rem;
    background: var(--color-accent);
    vertical-align: 1px;
  }

  .rtk-ex__rule strong {
    color: #0f766e;
  }

  .rtk-ex__rule code {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.05rem 0.3rem;
    border-radius: 0.25rem;
    background: rgba(15, 23, 42, 0.06);
    color: var(--color-accent-dim);
  }

  /* ===== Slide 9.7: RTK vs. peers (CodeGraph / cocoindex-code / Headroom) ===== */
  .rtk-land {
    width: min(94vw, 78rem);
    max-width: none;
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .rtk-land__lead {
    max-width: 52rem;
    margin-bottom: 1rem;
  }

  .rtk-land__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.72rem;
    align-items: stretch;
  }

  .land-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 0.82rem 0.82rem 0.78rem;
    border-radius: 0.92rem;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 18px 40px -28px rgba(15, 23, 42, 0.35);
    overflow: hidden;
  }

  .land-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--land-accent, linear-gradient(90deg, #6366f1, #8b5cf6));
  }

  .land-card--find { --land-accent: linear-gradient(90deg, #0ea5e9, #0284c7); --land-tint: #0284c7; }
  .land-card--run { --land-accent: linear-gradient(90deg, #6366f1, #4338ca); --land-tint: #4338ca; }
  .land-card--semantic { --land-accent: linear-gradient(90deg, #f59e0b, #d97706); --land-tint: #b45309; }
  .land-card--compress { --land-accent: linear-gradient(90deg, #14b8a6, #0f766e); --land-tint: #0f766e; }

  /* subtle "we run this" inline marker on the RTK card */
  .land-card__ours-tag {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    padding: 0.1rem 0.4rem;
    border-radius: 0.3rem;
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid rgba(15, 23, 42, 0.1);
    vertical-align: 0.18rem;
    margin-left: 0.35rem;
  }

  .land-card__stage {
    display: flex;
    align-items: center;
    gap: 0.36rem;
    margin-bottom: 0.48rem;
  }

  .land-card__stage-num {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--land-tint, var(--color-accent));
    background: color-mix(in srgb, var(--land-tint, #4338ca) 10%, transparent);
    padding: 0.1rem 0.4rem;
    border-radius: 0.3rem;
  }

  .land-card__stage-name {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .land-card__tool {
    margin: 0 0 0.34rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--land-tint, var(--color-text));
  }

  .land-card__how {
    margin: 0 0 0.58rem;
    font-size: 0.68rem;
    color: var(--color-text);
    line-height: 1.4;
    flex-grow: 1;
  }

  .land-card__how code {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    padding: 0.02rem 0.28rem;
    border-radius: 0.25rem;
    background: rgba(15, 23, 42, 0.06);
    color: var(--color-text);
  }

  .land-card__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.55rem;
  }

  .land-card__stat {
    font-size: 0.64rem;
    color: var(--color-text-muted);
    padding: 0.22rem 0.4rem;
    border-radius: 0.4rem;
    background: color-mix(in srgb, var(--land-tint, #4338ca) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--land-tint, #4338ca) 18%, transparent);
  }

  .land-card__stat strong {
    font-family: var(--font-mono);
    color: var(--land-tint, var(--color-text));
    font-weight: 600;
  }

  .land-card__meta {
    margin: 0;
    padding-top: 0.5rem;
    border-top: 1px dashed rgba(15, 23, 42, 0.12);
    font-size: 0.58rem;
    color: var(--color-text-muted);
    line-height: 1.34;
  }

  .land-card__meta code {
    font-family: var(--font-mono);
    font-size: 0.56rem;
    color: var(--color-text);
  }

  .rtk-land__why {
    margin-top: 0.8rem;
    padding: 0.62rem 0.78rem;
    border-radius: 0.9rem;
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid rgba(99, 102, 241, 0.2);
  }

  .rtk-land__why-tag {
    display: inline-block;
    margin-right: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #ffffff;
    padding: 0.1rem 0.45rem;
    border-radius: 0.3rem;
    background: var(--color-accent);
    vertical-align: 1px;
  }

  .rtk-land__why p {
    display: inline;
    font-size: 0.72rem;
    color: var(--color-text);
    line-height: 1.42;
  }

  .rtk-land__why code {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.05rem 0.3rem;
    border-radius: 0.25rem;
    background: rgba(15, 23, 42, 0.06);
    color: var(--color-accent-dim);
  }

  /* ===== Demo: an agent that optimizes agents ===== */
  .aeval {
    max-width: 74rem;
  }

  .aeval__lead {
    max-width: 56rem;
    margin-bottom: 1.1rem;
  }

  /* the two actors */
  .aeval__cast {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .aeval-actor {
    position: relative;
    padding: 0.85rem 1rem;
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 16px 36px -28px rgba(15, 23, 42, 0.35);
    overflow: hidden;
  }

  .aeval-actor::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 3px;
    background: var(--aeval-accent, #6366f1);
  }

  .aeval-actor--subject { --aeval-accent: linear-gradient(180deg, #0ea5e9, #0284c7); --aeval-tint: #0284c7; }
  .aeval-actor--optimizer { --aeval-accent: linear-gradient(180deg, #6366f1, #4338ca); --aeval-tint: #4338ca; }

  .aeval-actor__role {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--aeval-tint, var(--color-accent));
    margin-bottom: 0.3rem;
  }

  .aeval-actor h3 {
    margin: 0 0 0.3rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .aeval-actor h3 code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--aeval-tint, var(--color-accent));
    background: transparent;
    padding: 0;
  }

  .aeval-actor p {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .aeval-actor__file {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.1rem 0.4rem;
    border-radius: 0.3rem;
    background: rgba(15, 23, 42, 0.05);
    color: var(--color-text);
  }

  .aeval__cast-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .aeval__cast-glyph {
    font-size: 1.7rem;
    color: var(--color-accent);
    line-height: 1;
  }

  .aeval__cast-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    color: var(--color-text-muted);
  }

  /* the six-phase loop */
  .aeval__loop {
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.85rem;
    border-radius: 0.85rem;
    background: rgba(99, 102, 241, 0.05);
    border: 1px solid rgba(99, 102, 241, 0.16);
    margin-bottom: 1rem;
  }

  .aeval-phase {
    flex: 1;
    min-width: 7rem;
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    padding: 0.5rem 0.55rem;
    border-radius: 0.55rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.07);
  }

  .aeval-phase--gate {
    border-color: rgba(20, 184, 166, 0.35);
    background: rgba(20, 184, 166, 0.07);
  }

  .aeval-phase__n {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    color: #ffffff;
    background: var(--color-accent);
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aeval-phase--gate .aeval-phase__n {
    background: #0f766e;
  }

  .aeval-phase__name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 0.15rem;
  }

  .aeval-phase__d {
    font-size: 0.66rem;
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .aeval-phase__d code {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-text);
  }

  .aeval-phase__arr {
    align-self: center;
    color: rgba(99, 102, 241, 0.6);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .aeval-phase__loopback {
    align-self: center;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    color: #0f766e;
    padding: 0.2rem 0.5rem;
    border-radius: 0.4rem;
    background: rgba(20, 184, 166, 0.1);
    border: 1px dashed rgba(20, 184, 166, 0.4);
    flex-shrink: 0;
  }

  /* footer: trust + link */
  .aeval__footer {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1rem;
    align-items: stretch;
  }

  .aeval__trust {
    padding: 0.8rem 1rem;
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
  }

  .aeval__trust-tag {
    display: inline-block;
    margin-right: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ffffff;
    padding: 0.1rem 0.45rem;
    border-radius: 0.3rem;
    background: #0f766e;
    vertical-align: 1px;
  }

  .aeval__trust p {
    display: inline;
    font-size: 0.8rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .aeval__trust code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.03rem 0.28rem;
    border-radius: 0.25rem;
    background: rgba(15, 23, 42, 0.06);
    color: var(--color-accent-dim);
  }

  .aeval__link {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.8rem 1rem;
    border-radius: 0.8rem;
    text-decoration: none;
    background: linear-gradient(135deg, rgba(67, 56, 202, 0.95), rgba(79, 70, 229, 0.95));
    box-shadow: 0 18px 38px -26px rgba(67, 56, 202, 0.6);
    transition: transform 0.15s ease;
    position: relative;
  }

  .aeval__link:hover {
    transform: translateY(-2px);
  }

  .aeval__link-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #ffffff;
  }

  .aeval__link-repo {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: #c7d2fe;
  }

  .aeval__link-icon {
    position: absolute;
    top: 0.7rem;
    right: 0.8rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .aeval__takeaway {
    margin: 0.75rem auto 0;
    max-width: 52rem;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.86rem;
    font-weight: 500;
    line-height: 1.5;
    text-align: center;
  }

  .aeval__takeaway::first-line {
    color: rgba(255, 255, 255, 0.92);
  }

  /* ===== Resources (placeholder) ===== */
  .resources {
    max-width: 66rem;
  }

  .resources__lead {
    max-width: 48rem;
    margin-bottom: 1.4rem;
  }

  .resources__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .resource-cat {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 1.1rem 1.2rem 1.2rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 16px 36px -28px rgba(15, 23, 42, 0.32);
    overflow: hidden;
  }

  .resource-cat::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--res-accent, linear-gradient(90deg, #6366f1, #8b5cf6));
  }

  .resource-cat--docs { --res-accent: linear-gradient(90deg, #6366f1, #4338ca); }
  .resource-cat--tools { --res-accent: linear-gradient(90deg, #0ea5e9, #0284c7); }
  .resource-cat--examples { --res-accent: linear-gradient(90deg, #14b8a6, #0f766e); }
  .resource-cat--community { --res-accent: linear-gradient(90deg, #f59e0b, #d97706); }

  .resource-cat__icon {
    font-size: 1.4rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .resource-cat h3 {
    margin: 0 0 0.7rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .resource-cat__slot {
    margin-top: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 0.9rem 1rem;
    border-radius: 0.6rem;
    border: 1.5px dashed var(--color-border);
    background: repeating-linear-gradient(
      45deg,
      rgba(148, 163, 184, 0.04),
      rgba(148, 163, 184, 0.04) 10px,
      transparent 10px,
      transparent 20px
    );
    font-size: 0.78rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .resource-cat__slot--filled {
    display: block;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    font-style: normal;
  }

  .resource-list {
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-size: 0.64rem;
    line-height: 1.34;
  }

  .resource-list li + li {
    margin-top: 0.18rem;
  }

  .resource-list a {
    color: #0369a1;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(3, 105, 161, 0.24);
  }

  .resource-list a:hover {
    color: #0284c7;
    border-bottom-color: currentColor;
  }

  .resources__note {
    margin-top: 1.1rem;
    font-size: 0.8rem;
    font-style: italic;
    color: var(--color-text-muted);
    text-align: center;
  }

  /* ===== Where this is going (forward look) ===== */
  .future {
    max-width: 72rem;
  }

  .future__lead {
    max-width: 56rem;
    margin-bottom: 1.05rem;
  }

  .future__lead strong {
    color: var(--color-accent-dim);
  }

  /* Clean future map: one settled action rail, then three harness layers. */
  .orbit {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-areas:
      "core core core"
      "bridge bridge bridge"
      "judgment context trust";
    gap: 0.72rem;
    margin-top: 0.85rem;
  }

  .orbit__core {
    grid-area: core;
    position: relative;
    justify-self: center;
  }

  .orbit .core {
    position: relative;
    display: inline-grid;
    grid-template-columns: auto auto auto;
    align-items: center;
    gap: 0.68rem;
    padding: 0.42rem 0.68rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(99, 102, 241, 0.14);
    box-shadow: 0 12px 28px -30px rgba(15, 23, 42, 0.28);
  }

  .orbit .core__tag {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-dim);
    padding: 0.16rem 0.48rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.06);
  }

  .orbit .core__title {
    font-size: 1.08rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .orbit .core__sub {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.3;
    white-space: nowrap;
  }

  .orbit__bridge {
    grid-area: bridge;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 0.7rem;
    width: min(100%, 58rem);
    justify-self: center;
    color: #94a3b8;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    line-height: 1;
    text-transform: uppercase;
  }

  .orbit__bridge::before,
  .orbit__bridge::after {
    content: '';
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.42));
  }

  .orbit__bridge::after {
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.42), transparent);
  }

  /* Verb-first cards. The examples are intentionally muted so the structure is
     what reads first from the back of the room. */
  .orbit .layer {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
    width: auto;
    max-width: 100%;
    min-height: 10.7rem;
    padding: 0.9rem 0.95rem 0.92rem;
    border-radius: 0.95rem;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.075);
    border-left: 3px solid var(--layer-tint);
    box-shadow: 0 14px 30px -30px rgba(15, 23, 42, 0.35);
  }

  .orbit .layer--judgment {
    grid-area: judgment;
    --layer-tint: #4338ca;
  }

  .orbit .layer--context {
    grid-area: context;
    --layer-tint: #0284c7;
  }

  .orbit .layer--trust {
    grid-area: trust;
    --layer-tint: #0f766e;
  }

  .orbit .layer__head {
    display: flex;
    align-items: center;
    gap: 0.62rem;
    width: 100%;
  }

  .orbit .layer__heading {
    min-width: 0;
  }

  /* numbered node: small index marker, not another competing icon */
  .orbit .layer__node {
    flex: none;
    display: grid;
    place-items: center;
    width: 1.62rem;
    height: 1.62rem;
    border-radius: 0.45rem;
    background: #ffffff;
    border: 1px solid color-mix(in srgb, var(--layer-tint) 32%, rgba(15, 23, 42, 0.08));
    color: var(--layer-tint);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .orbit .layer__body {
    display: flex;
    flex-direction: column;
    gap: 0.52rem;
    min-width: 0;
  }

  .orbit .layer__verb {
    margin: 0 0 0.12rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--layer-tint);
    line-height: 1;
  }

  .orbit .layer__title {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .orbit .layer__claim {
    margin: 0;
    font-size: 0.75rem;
    color: #334155;
    line-height: 1.42;
  }

  .orbit .layer__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.28rem;
  }

  .orbit .layer__chips span {
    display: inline-flex;
    align-items: center;
    min-height: 1.24rem;
    padding: 0.16rem 0.38rem;
    border-radius: 999px;
    color: #64748b;
    background: rgba(15, 23, 42, 0.025);
    border: 1px solid rgba(15, 23, 42, 0.055);
    font-size: 0.61rem;
    font-weight: 600;
    line-height: 1;
  }

  .future__kicker {
    max-width: 48rem;
    margin: 1rem auto 0;
    padding: 0.62rem 0 0;
    border-top: 1px solid rgba(99, 102, 241, 0.18);
    text-align: center;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .future__kicker strong {
    color: var(--color-accent-dim);
    font-weight: 700;
  }

  /* ===== Reusable slide citation line ===== */
  .slide-cite {
    margin: 1rem 0 0;
    font-size: 0.68rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .slide-cite__tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-right: 0.45rem;
  }

  .slide-cite a {
    color: var(--color-accent-dim);
    text-decoration: none;
    border-bottom: 1px dotted rgba(67, 56, 202, 0.4);
  }

  .slide-cite a:hover {
    border-bottom-style: solid;
  }

  .slide-cite__sep {
    margin: 0 0.4rem;
    color: rgba(15, 23, 42, 0.25);
  }

  /* ===== Slide 9: Own your agent setup ===== */
  .personalization {
    max-width: 70rem;
  }

  .personalization__lead {
    max-width: 56rem;
    margin-bottom: 1.15rem;
  }

  .ownership {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 1rem;
    align-items: stretch;
  }

  .ownership__thesis,
  .ownership-path {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 18px 40px -28px rgba(15, 23, 42, 0.32);
  }

  .ownership__thesis {
    padding: 1.15rem 1.25rem 1.2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ownership__thesis::before,
  .ownership-path::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--ownership-accent, linear-gradient(90deg, #6366f1, #8b5cf6));
  }

  .ownership__kicker,
  .ownership-path__badge {
    display: inline-flex;
    align-self: flex-start;
    margin-bottom: 0.65rem;
    padding: 0.16rem 0.55rem;
    border-radius: 999px;
    background: var(--ownership-tint, rgba(99, 102, 241, 0.1));
    color: var(--ownership-ink, #4338ca);
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .ownership__thesis h3,
  .ownership-path h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    line-height: 1.2;
    color: var(--color-text);
  }

  .ownership__thesis p,
  .ownership-path p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .ownership__line {
    margin-top: 0.85rem !important;
    padding-top: 0.75rem;
    border-top: 1px dashed rgba(15, 23, 42, 0.12);
    color: #4338ca !important;
    font-weight: 600;
  }

  .ownership__paths {
    display: grid;
    gap: 0.75rem;
  }

  .ownership-path {
    padding: 0.95rem 1rem 0.98rem;
  }

  .ownership-path--adopt {
    --ownership-accent: linear-gradient(90deg, #f59e0b, #d97706);
    --ownership-tint: rgba(245, 158, 11, 0.1);
    --ownership-ink: #b45309;
  }

  .ownership-path--build {
    --ownership-accent: linear-gradient(90deg, #14b8a6, #0d9488);
    --ownership-tint: rgba(20, 184, 166, 0.1);
    --ownership-ink: #0f766e;
  }

  .ownership-path__trade {
    display: block;
    margin-top: 0.75rem;
    padding-top: 0.65rem;
    border-top: 1px dashed rgba(15, 23, 42, 0.12);
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }

  /* ===== Appendix slides (A1-A3) ===== */
  .appendix {
    max-width: 72rem;
  }

  .overline--appendix {
    color: #6d28d9;
  }

  .appendix__lead {
    max-width: 48rem;
    margin-bottom: 1.2rem;
    font-size: 1rem;
  }

  .appendix__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: 1.4rem;
    align-items: stretch;
  }

  /* Stretched asides pool extra space at the bottom, before the source line */
  .appendix__aside .appendix-aside__source {
    margin-top: auto;
  }

  .appendix__main {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .appendix__aside {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 0.95rem 1rem 1rem;
    border-radius: 0.9rem;
    background: rgba(139, 92, 246, 0.06);
    border: 1px solid rgba(139, 92, 246, 0.16);
  }

  .appendix-aside__block {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .appendix-aside__title {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6d28d9;
  }

  .appendix-aside__text {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .appendix-aside__text em {
    font-style: italic;
    color: #6d28d9;
  }

  .appendix-aside__list {
    margin: 0;
    padding-left: 1rem;
    font-size: 0.78rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .appendix-aside__list li {
    margin-bottom: 0.25rem;
  }

  .appendix-aside__list code,
  .appendix-aside__text code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.06rem 0.3rem;
    background: rgba(15, 23, 42, 0.05);
    border-radius: 0.25rem;
  }

  .appendix-aside__code {
    margin: 0;
    padding: 0.55rem 0.65rem;
    background: rgba(15, 23, 42, 0.92);
    color: #e2e8f0;
    border-radius: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1.5;
    overflow-x: auto;
  }

  .appendix-aside__code code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .appendix-aside__source {
    margin: 0;
    padding-top: 0.5rem;
    border-top: 1px dashed rgba(139, 92, 246, 0.24);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .appendix-aside__source code {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: #6d28d9;
    background: transparent;
    padding: 0;
  }

  .appendix-table {
    width: 100%;
    height: 100%;
    border-collapse: collapse;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 0.7rem;
    overflow: hidden;
    box-shadow: 0 14px 36px -28px rgba(15, 23, 42, 0.3);
  }

  .appendix-table thead th {
    text-align: left;
    padding: 0.55rem 0.75rem;
    background: rgba(15, 23, 42, 0.04);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .appendix-table tbody td {
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text);
    border-bottom: 1px solid rgba(15, 23, 42, 0.05);
    line-height: 1.4;
    vertical-align: middle;
  }

  .appendix-table tbody tr:last-child td {
    border-bottom: none;
  }

  .appendix-table tbody td code {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.1rem 0.35rem;
    background: rgba(99, 102, 241, 0.08);
    color: #4338ca;
    border-radius: 0.3rem;
    white-space: nowrap;
  }

  .appendix-table__count {
    display: inline-block;
    margin-left: 0.4rem;
    padding: 0.05rem 0.4rem;
    background: rgba(245, 158, 11, 0.15);
    color: #b45309;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .appendix-table--hooks tbody td:first-child {
    width: 9rem;
  }

  .appendix-group {
    padding: 0.85rem 1rem;
    background: rgba(255, 255, 255, 0.85);
    border-radius: 0.7rem;
    border: 1px solid rgba(15, 23, 42, 0.06);
  }

  .appendix-group__title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 0.5rem;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .appendix-group__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #ffffff;
    border-radius: 50%;
    font-size: 0.74rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .appendix-group__list {
    margin: 0;
    padding-left: 0.25rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
  }

  .appendix-group__list li {
    font-size: 0.78rem;
    color: var(--color-text);
    line-height: 1.45;
  }

  .appendix-group__list strong {
    color: #4338ca;
    font-weight: 600;
  }

  .appendix-group__list code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.05rem 0.3rem;
    background: rgba(15, 23, 42, 0.05);
    border-radius: 0.25rem;
  }

  .appendix-group__sep {
    color: var(--color-text-muted);
    margin: 0 0.15rem;
  }

  .appendix__footnote {
    margin: 0.4rem 0 0;
    font-size: 0.74rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.5;
  }

  .appendix__footnote code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.05rem 0.3rem;
    background: rgba(15, 23, 42, 0.05);
    border-radius: 0.25rem;
    font-style: normal;
  }

  /* ===== Appendix A3: Guardrails-specific ===== */
  .appendix--guardrails h2 {
    margin-bottom: 0.55rem;
  }

  .appendix--guardrails .appendix__lead {
    margin-bottom: 0.7rem;
  }

  .hook-ribbon {
    display: flex;
    align-items: stretch;
    flex-wrap: nowrap;
    gap: 0.3rem;
    margin-bottom: 0.85rem;
    padding: 0.5rem 0.65rem;
    border-radius: 0.7rem;
    background: rgba(15, 23, 42, 0.03);
    border: 1px solid rgba(15, 23, 42, 0.07);
    overflow-x: auto;
  }

  .hook-ribbon__label {
    display: flex;
    align-items: center;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    white-space: nowrap;
    padding-right: 0.2rem;
    flex-shrink: 0;
  }

  .hook-ribbon__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.3rem 0.45rem;
    border-radius: 0.5rem;
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid rgba(99, 102, 241, 0.14);
    flex: 1;
    min-width: 0;
  }

  .hook-ribbon__step code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: #4338ca;
    background: transparent;
    padding: 0;
    white-space: nowrap;
  }

  .hook-ribbon__step em {
    font-style: normal;
    font-size: 0.62rem;
    color: var(--color-text-muted);
    line-height: 1.2;
    text-align: center;
    white-space: nowrap;
  }

  .hook-ribbon__arrow {
    display: flex;
    align-items: center;
    color: rgba(99, 102, 241, 0.5);
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .appendix__grid--guardrails {
    grid-template-columns: minmax(0, 1fr) 15rem;
  }

  .appendix-table--hooks tbody td:first-child {
    width: 11rem;
  }

  .hook-job {
    vertical-align: middle;
  }

  .hook-job__name {
    display: inline;
    font-weight: 700;
    font-size: 0.86rem;
    color: var(--color-text);
  }

  .appendix-table--hooks tbody td {
    font-size: 0.8rem;
    line-height: 1.55;
    padding: 0.62rem 0.8rem;
  }

  .appendix-table--hooks tbody td:last-child code {
    white-space: normal;
    background: rgba(99, 102, 241, 0.07);
    color: #4338ca;
    font-weight: 600;
  }

  .appendix-aside__stats {
    margin: 0 0 0.5rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
  }

  .appendix-aside__stats li {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.76rem;
    color: var(--color-text);
  }

  .appendix-aside__stat-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.7rem;
    padding: 0.05rem 0.35rem;
    background: rgba(139, 92, 246, 0.12);
    color: #6d28d9;
    border-radius: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
  }

  .appendix-aside__text strong {
    color: #6d28d9;
    font-weight: 700;
  }

  .appendix-aside__text--tight {
    margin-top: 0.4rem;
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .appendix-aside__text--tight code {
    font-size: 0.64rem;
    word-break: break-word;
  }

  .appendix--guardrails .appendix__aside {
    gap: 0.6rem;
    padding: 0.85rem 0.9rem 0.9rem;
  }

  /* Plain footer captions, matching the runtime slide caption. */
  .omo-takeaway,
  .harness-power__strip,
  .roads__destination {
    margin: 0.85rem auto 0;
    max-width: 44rem;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    color: #64748b;
    text-align: center;
  }

  .omo-takeaway__line,
  .harness-power__strip-line,
  .roads__destination-line {
    margin: 0;
    font-size: 0.86rem;
    font-weight: 400;
    line-height: 1.5;
    color: #64748b;
  }

  .omo-takeaway__accent,
  .harness-power__strip-line--accent,
  .roads__destination-line em {
    color: inherit;
    font-weight: 600;
  }

  .omo-takeaway__sub,
  .roads__destination-sub {
    margin: 0.2rem 0 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: #94a3b8;
  }

  .harness-power__strip-line--accent {
    margin-top: 0.15rem;
  }

  @media (max-width: 1100px) {
    .runtime {
      width: 100%;
      margin-left: auto;
      transform: none;
    }

    .runtime__split {
      grid-template-columns: 1fr;
    }

    .runtime__screenshot img {
      height: clamp(16rem, 42vh, 24rem);
    }

    .loader-grid {
      grid-template-columns: 1fr;
    }

    .omo-architecture {
      grid-template-columns: 1fr;
    }

    .omo-deep-grid {
      grid-template-columns: 1fr;
    }

    .omo-arrow {
      transform: rotate(90deg);
      padding: 0.2rem 0;
    }

    .rtk__body,
    .rtk__footer {
      grid-template-columns: 1fr;
    }

    .rtk-ex__diff {
      grid-template-columns: 1fr;
    }

    .rtk-ex__arrow {
      flex-direction: row;
      gap: 0.6rem;
    }

    .rtk-ex__arrow-glyph {
      transform: rotate(90deg);
    }

    .rtk-ex__arrow-label {
      max-width: none;
    }

    .rtk-land__grid {
      grid-template-columns: 1fr;
    }

    .aeval__cast {
      grid-template-columns: 1fr;
    }

    .aeval__cast-link {
      flex-direction: row;
