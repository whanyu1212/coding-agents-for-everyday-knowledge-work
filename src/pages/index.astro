---
import Layout from '../layouts/Layout.astro';
import Slide from '../components/Slide.astro';
import Nav from '../components/Nav.astro';
import CodeBlock from '../components/CodeBlock.astro';

const sections = [
  { id: 'intro', label: 'Intro' },
  { id: 'what', label: 'Who\'s Who' },
  { id: 'landscape', label: 'Anatomy' },
  { id: 'how', label: 'Why It Generalizes' },
  { id: 'workflows', label: 'Runtime' },
  { id: 'harness', label: 'Harness' },
  { id: 'extensibility', label: 'Extensions' },
  { id: 'demo', label: 'Demo' },
  { id: 'tradeoffs', label: 'Trade-offs' },
  { id: 'takeaways', label: 'Takeaways' },
];
---

<Layout title="Coding Agents for Everyday Knowledge Work">
  <Nav sections={sections} />

  <!-- Slide 1: Title -->
  <Slide id="intro" variant="accent">
    <div class="title-slide">
      <p class="overline">Technical Sharing</p>
      <h1 class="title">Coding Agents for<br /><span class="highlight">Everyday Knowledge Work</span></h1>
      <p class="subtitle">
        They're not just code generators — they're coworkers that solve tasks through code.
        Learn, triage, review, and ship.
      </p>
      <div class="scroll-hint">
        <span class="scroll-hint__arrow">&#8595;</span>
        <span>Scroll to explore</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 2: Coding agents in the market -->
  <Slide id="what">
    <div class="scatter-slide">
      <div class="scatter-text">
        <p class="overline">The Market Right Now</p>
        <h2>Coding Agents Are<br /><span class="highlight">Everywhere</span></h2>
      </div>
      <div class="scatter-logo" style="--x: 8%; --y: 8%; --size: 6rem; --rot: -12deg; --delay: 0s; --float-dur: 5.5s; --float-offset: -0.4s;">
        <img src="/logos/claude.png" alt="Claude Code" />
        <span>Claude Code</span>
      </div>
      <div class="scatter-logo" style="--x: 70%; --y: 3%; --size: 5rem; --rot: 8deg; --delay: 0.1s; --float-dur: 6.5s; --float-offset: -2.1s;">
        <img src="/logos/codex.png" alt="Codex" />
        <span>Codex</span>
      </div>
      <div class="scatter-logo" style="--x: 30%; --y: 72%; --size: 5.5rem; --rot: -5deg; --delay: 0.2s; --float-dur: 4.5s; --float-offset: -3.3s;">
        <img src="/logos/antigravity.png" alt="Antigravity" />
        <span>Antigravity</span>
      </div>
      <div class="scatter-logo" style="--x: 78%; --y: 65%; --size: 4.5rem; --rot: 15deg; --delay: 0.3s; --float-dur: 7s; --float-offset: -1.2s;">
        <img src="/logos/opencode.png" alt="OpenCode" />
        <span>OpenCode</span>
      </div>
      <div class="scatter-logo" style="--x: 3%; --y: 52%; --size: 6.5rem; --rot: 6deg; --delay: 0.4s; --float-dur: 6s; --float-offset: -4.5s;">
        <img src="/logos/copilot.png" alt="GitHub Copilot" />
        <span>Copilot</span>
      </div>
      <div class="scatter-logo" style="--x: 80%; --y: 26%; --size: 6rem; --rot: -10deg; --delay: 0.5s; --float-dur: 5s; --float-offset: -2.8s;">
        <img src="/logos/cursor.svg" alt="Cursor" />
        <span>Cursor</span>
      </div>
      <div class="scatter-logo" style="--x: 43%; --y: 11%; --size: 5rem; --rot: 3deg; --delay: 0.6s; --float-dur: 5.8s; --float-offset: -1.9s;">
        <img src="/logos/pi.svg" alt="Pi" />
        <span>Pi</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 3: Anatomy — model + CodeAct + harness -->
  <Slide id="landscape" variant="accent">
    <div class="content-slide anatomy-slide">
      <p class="overline">The Mental Model</p>
      <h2>So What <em>Is</em> a Coding Agent?</h2>
      <p class="lead">
        Strip away the branding and it's simple:
        <strong>a model doing CodeAct, wrapped in a harness.</strong>
      </p>

      <div class="anatomy">
        <!-- Outer shell: the harness -->
        <div class="layer layer--harness">
          <span class="layer__label">Harness</span>
          <div class="layer__tags">
            <!--
              TODO (your call): list the harness responsibilities you want to emphasize.
              These are the bits OF the harness that aren't the model or CodeAct itself.
              Common candidates — pick/tweak the ones that match how OpenCode works:
                context gathering · the agent loop · memory & compaction ·
                permissions & sandboxing · tool wiring · output parsing · session state
            -->
            <span class="tag">context</span>
            <span class="tag">the loop</span>
            <span class="tag">memory</span>
            <span class="tag">tools</span>
            <span class="tag">permissions</span>
          </div>

          <!-- Middle ring: CodeAct -->
          <div class="layer layer--codeact">
            <span class="layer__label">CodeAct</span>
            <span class="layer__sub">acts through code &amp; tools</span>

            <!-- Core: the model -->
            <div class="layer layer--model">
              <span class="layer__label">Model</span>
              <span class="layer__sub">reasons &amp; decides</span>
            </div>
          </div>
        </div>
      </div>

      <p class="anatomy-caption">
        Same model, different harness &rarr; a very different agent. That's why the six above
        feel so different despite often sharing the same underlying models.
      </p>
    </div>
  </Slide>

  <!-- Slide 4: Why it generalizes — code as universal interface (mission-control) -->
  <Slide id="how" variant="control">
    <div class="control-slide">
      <p class="overline overline--glow">Why It Generalizes</p>
      <h2 class="control-title">Code Is a <span class="control-title__accent">Universal Remote</span></h2>
      <p class="control-lead">
        The agent acts by writing <strong>code</strong> — and code can touch almost anything.
      </p>

      <!-- Three-column flow: CODE → systems → knowledge work.
           Reads left-to-right as a causal chain — no explanation needed. -->
      <div class="flow">
        <!-- Left: the code hub -->
        <div class="flow__hub">
          <span class="flow__orb">
            <span class="flow__orb-glow"></span>
            <svg class="flow__orb-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M8.5 7.5 4 12l4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.5 7.5 20 12l-4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13.5 6 10.5 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            <span class="flow__orb-label">CODE</span>
          </span>
        </div>

        <!-- Arrow column 1 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">reaches</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Middle: systems column -->
        <div class="flow__col flow__col--sys">
          <span class="flow__col-header">Systems</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--sys" style="--i:0">APIs</span>
            <span class="flow__chip flow__chip--sys" style="--i:1">Databases</span>
            <span class="flow__chip flow__chip--sys" style="--i:2">Shell &amp; CLI</span>
            <span class="flow__chip flow__chip--sys" style="--i:3">Git &amp; PRs</span>
            <span class="flow__chip flow__chip--sys" style="--i:4">The web</span>
            <span class="flow__chip flow__chip--sys" style="--i:5">Files</span>
          </div>
        </div>

        <!-- Arrow column 2 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">enables</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Right: knowledge work column (the payoff — visually dominant) -->
        <div class="flow__col flow__col--work">
          <span class="flow__col-header">Knowledge Work</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--work" style="--i:6">Research</span>
            <span class="flow__chip flow__chip--work" style="--i:7">Triage</span>
            <span class="flow__chip flow__chip--work" style="--i:8">Review</span>
            <span class="flow__chip flow__chip--work" style="--i:9">Analysis</span>
            <span class="flow__chip flow__chip--work" style="--i:10">Docs</span>
            <span class="flow__chip flow__chip--work" style="--i:11">Onboarding</span>
          </div>
        </div>
      </div>

      <p class="control-caption">
        One action language. Infinite reach.
      </p>
    </div>
  </Slide>

  <!-- Slide 5: OpenCode architecture — grounded in the actual core runtime -->
  <Slide id="workflows" variant="accent">
    <div class="content-slide runtime">
      <p class="overline">Inside OpenCode</p>
      <h2>What the Runtime <span class="highlight">Actually Looks Like</span></h2>
      <p class="lead runtime__lead">
        OpenCode is split three ways: process-global session scheduling, a cached runtime per
        location, and one durable <code>SessionRunner</code> loop that assembles context, model,
        and tools for each provider turn.
      </p>

      <div class="runtime__diagram">
        <div class="runtime__strip" aria-label="Process-global runtime control">
          <span class="runtime__strip-item"><strong>Session API</strong><small>admit / resume</small></span>
          <span class="runtime__strip-item"><strong>Drain Coordinator</strong><small>one active run</small></span>
          <span class="runtime__strip-item"><strong>Location Runtime</strong><small>cached per workspace</small></span>
        </div>

        <div class="runtime__frame">
          <span class="runtime__frame-label">Location-scoped runtime</span>
          <div class="runtime__compact">
            <div class="runtime__core">
              <span class="runtime__kicker">Per-turn loop</span>
              <span class="runtime__core-title">SessionRunner</span>
              <span class="runtime__core-sub">one <code>llm.stream(...)</code> turn at a time</span>
              <div class="runtime__pipeline">
                <span class="runtime__pill">context</span>
                <span class="runtime__pill">model</span>
                <span class="runtime__pill">tools</span>
                <span class="runtime__pill">events</span>
                <span class="runtime__pill">continue</span>
              </div>
            </div>

            <div class="runtime__support-grid">
              <div class="runtime__support">
                <span class="runtime__kicker">SessionStore</span>
                <span class="runtime__support-title">History</span>
              </div>
              <div class="runtime__support">
                <span class="runtime__kicker">Catalog</span>
                <span class="runtime__support-title">Models</span>
              </div>
              <div class="runtime__support">
                <span class="runtime__kicker">ToolRegistry</span>
                <span class="runtime__support-title">Tools</span>
              </div>
              <div class="runtime__support">
                <span class="runtime__kicker">Compaction</span>
                <span class="runtime__support-title">Memory</span>
              </div>
            </div>
          </div>
        </div>

        <div class="runtime__store-card runtime__store-card--compact">
          <span class="runtime__kicker">EventV2 &middot; SessionProjector &middot; SQLite</span>
          <span class="runtime__store-title">Replayable durable state</span>
        </div>

        <p class="runtime__caption">
          One idea: admit work globally, execute inside a location runtime, persist every turn as replayable state.
        </p>
      </div>
    </div>
  </Slide>

  <!-- Slide 6: How OpenCode loads extensions -->
  <Slide id="harness" variant="dark">
    <div class="content-slide deep-slide deep-slide--usage">
      <p class="overline">Advanced Usage</p>
      <h2>How OpenCode Loads <span class="highlight">Extensions</span></h2>
      <p class="lead deep-slide__lead">
        Skills and plugins enter OpenCode through different loading paths, but both extend the stock runtime.
      </p>

      <div class="loader-grid">
        <div class="loader-card loader-card--skill">
          <div class="loader-card__header">
            <span class="loader-card__kicker">Behavior Layer</span>
            <h3>Skills</h3>
          </div>
          <p class="loader-card__text">
            <code>skills[]</code> points to local roots or URLs. The skill loader discovers
            <code>SKILL.md</code>, parses frontmatter, and exposes those skills for intentional loading.
          </p>
          <div class="loader-flow">
            <span class="loader-step">skills[]</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">discover</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">SKILL.md</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">skill tool</span>
          </div>
          <div class="mini-code">
            <div class="mini-code__header">Example: GitHub issues / PRs</div>
            <pre class="mini-code__pre"><code>{`{
  "skills": ["./team-skills/github"]
}

---
name: github-triage
description: Triage issues and PRs
---`}</code></pre>
          </div>
          <p class="loader-card__note">Best for recurring playbooks, checklists, and domain habits inside one agent.</p>
        </div>

        <div class="loader-card loader-card--plugin">
          <div class="loader-card__header">
            <span class="loader-card__kicker">Runtime Seam Layer</span>
            <h3>Plugins</h3>
          </div>
          <p class="loader-card__text">
            <code>PluginBoot</code> loads packages, plugins register ordered hooks,
            and those hooks mutate narrow seams like catalog defaults, SDK wiring, or review flows.
          </p>
          <div class="loader-flow">
            <span class="loader-step">PluginBoot</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">PluginV2</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">hooks</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">runtime seams</span>
          </div>
          <div class="mini-code">
            <div class="mini-code__header">Example package</div>
            <pre class="mini-code__pre"><code>{`@plannotator/opencode

plan review
annotations
feedback loop`}</code></pre>
          </div>
          <p class="loader-card__note">Good for provider defaults, org integrations, review UX, and workflow-layer extensions.</p>
        </div>
      </div>

      <p class="deep-slide__takeaway">Skills and plugins both plug into the stock runtime. That still does not tell you how much of the agent experience they own.</p>
    </div>
  </Slide>

  <!-- Slide 7: Packaging vs control scope -->
  <Slide id="extensibility">
    <div class="content-slide deep-slide deep-slide--usage deep-slide--practice">
      <p class="overline">Key Distinction</p>
      <h2>Packaging vs <span class="highlight">Control Scope</span></h2>
      <p class="lead deep-slide__lead">
        <code>plugin</code> says how something installs. <code>harness</code> says how much of the agent loop it owns.
      </p>

      <div class="scope-compare">
        <div class="scope-compare__card scope-compare__card--plugin">
          <span class="scope-compare__eyebrow">Installs as a plugin</span>
          <h3>Runtime Plugin</h3>
          <p class="scope-compare__summary">
            Extends the stock runtime without taking over orchestration.
          </p>
          <ul class="scope-compare__list">
            <li>hooks like <code>catalog.transform</code> and <code>aisdk.sdk</code></li>
            <li>provider defaults, SDK wiring, workflow-layer UX</li>
            <li>OpenCode still owns delegation and control flow</li>
          </ul>
          <p class="scope-compare__example">Examples: provider plugins, Plannotator</p>
        </div>

        <div class="scope-compare__divider">vs</div>

        <div class="scope-compare__card scope-compare__card--harness">
          <span class="scope-compare__eyebrow">May also ship as a plugin</span>
          <h3>Harness Pack</h3>
          <p class="scope-compare__summary">
            Owns orchestration, delegation, and the working style itself.
          </p>
          <ul class="scope-compare__list">
            <li>subagents, planner/executor loops, reviewer flows</li>
            <li><code>steer</code> / <code>queue</code>, <code>run</code> / <code>wake</code>, retry / resume policy</li>
            <li>the extension now decides how the agent loop behaves</li>
          </ul>
          <p class="scope-compare__example">Example: Oh-My-OpenAgent</p>
        </div>
      </div>

      <div class="scope-compare__note">
        Same packaging shape, different scope: once orchestration becomes the customization, you are effectively shipping a harness pack.
      </div>

      <p class="deep-slide__takeaway">Plugin is packaging. Harness is scope of control.</p>
    </div>
  </Slide>

  <!-- Slide 8: Demo / Code example -->
  <Slide id="demo">
    <div class="content-slide">
      <p class="overline">Example</p>
      <h2>An Agent in Action</h2>
      <p class="lead">A typical interaction with a CLI coding agent:</p>
      <CodeBlock title="Terminal — Claude Code" lang="bash">
{`$ claude

> Fix the race condition in the WebSocket handler
  that causes duplicate messages on reconnect.

◐ Reading src/ws/handler.ts...
◐ Found the issue — reconnect doesn't clear the
  previous listener before attaching a new one.
◐ Editing src/ws/handler.ts...
◐ Running tests: npm test -- ws.test.ts
✓ All 14 tests pass.

> Looks good. Now add a test for the edge case
  where reconnect happens mid-message.

◐ Adding test to src/ws/__tests__/handler.test.ts...
◐ Running tests...
✓ All 15 tests pass.`}
      </CodeBlock>
    </div>
  </Slide>

  <!-- Slide 9: Trade-offs -->
  <Slide id="tradeoffs" variant="accent">
    <div class="content-slide">
      <p class="overline">Honest Take</p>
      <h2>Trade-offs & Limitations</h2>
      <p class="lead">Agents are powerful but not magic. Know the edges.</p>
      <div class="grid grid--2">
        <div class="pros-cons">
          <h3 class="pros-cons__header pros-cons__header--pro">Strengths</h3>
          <ul>
            <li>Massive speedup on well-defined mechanical tasks</li>
            <li>Excellent at exploring unfamiliar codebases</li>
            <li>Tireless at repetitive transformations</li>
            <li>Good at catching things you'd miss (unused imports, typos)</li>
          </ul>
        </div>
        <div class="pros-cons">
          <h3 class="pros-cons__header pros-cons__header--con">Limitations</h3>
          <ul>
            <li>Can hallucinate APIs or invent plausible-but-wrong fixes</li>
            <li>Struggles with large-scale architectural decisions</li>
            <li>Context window limits constrain very large codebases</li>
            <li>Still needs human review — trust but verify</li>
          </ul>
        </div>
      </div>
    </div>
  </Slide>

  <!-- Slide 10: Key takeaways -->
  <Slide id="takeaways" variant="dark">
    <div class="content-slide takeaway-slide">
      <p class="overline">Wrapping Up</p>
      <h2>Key Takeaways</h2>
      <ol class="takeaway-list">
        <li>
          <strong>Agents are a workflow shift, not just a tool.</strong>
          You move from writing code to directing and reviewing it.
        </li>
        <li>
          <strong>Start with bounded tasks.</strong>
          Bug fixes, refactors, and tests are the sweet spot today.
        </li>
        <li>
          <strong>Invest in context.</strong>
          Good project docs (CLAUDE.md, README) make agents dramatically more effective.
        </li>
        <li>
          <strong>Keep humans in the loop.</strong>
          The best workflow is human judgment + agent execution speed.
        </li>
      </ol>
      <div class="closing">
        <p class="closing__text">Thanks for listening.</p>
      </div>
    </div>
  </Slide>
</Layout>

<script>
</script>

<style>
  /* Title slide */
  .title-slide {
    text-align: center;
  }

  .overline {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  .highlight {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto 3rem;
  }

  .scroll-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    animation: bounce 2s infinite;
  }

  .scroll-hint__arrow {
    font-size: 1.2rem;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Content slides */
  .content-slide h2 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 42rem;
    margin-bottom: 2.5rem;
  }

  /* Grid */
  .grid {
    display: grid;
    gap: 1.25rem;
  }

  .grid--2 {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .grid--3 {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  /* Pipeline */
  .pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .pipeline__step {
    flex: 1;
    min-width: 160px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }

  .pipeline__step h3 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }

  .pipeline__step p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .pipeline__num {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent-dim);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .pipeline__arrow {
    color: var(--color-accent);
    font-size: 1.5rem;
    padding-top: 2rem;
    flex-shrink: 0;
  }

  /* Pros/Cons */
  .pros-cons {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .pros-cons__header {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid;
  }

  .pros-cons__header--pro {
    border-color: #34d399;
    color: #34d399;
  }

  .pros-cons__header--con {
    border-color: #fb923c;
    color: #fb923c;
  }

  .pros-cons ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pros-cons li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
  }

  .pros-cons li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-text-muted);
  }

  /* Takeaway list */
  .takeaway-list {
    list-style: none;
    counter-reset: takeaway;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 42rem;
  }

  .takeaway-list li {
    counter-increment: takeaway;
    padding-left: 2.5rem;
    position: relative;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .takeaway-list li strong {
    color: var(--color-text);
    display: block;
    margin-bottom: 0.25rem;
  }

  .takeaway-list li::before {
    content: counter(takeaway);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent-dim);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Closing */
  .closing {
    margin-top: 3rem;
    text-align: center;
  }

  .closing__text {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  /* Scatter logos */
  .scatter-slide {
    position: relative;
    width: 100%;
    height: 80vh;
  }

  .scatter-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
  }

  .scatter-text h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
  }

  .scatter-footnote {
    margin: 1.5rem auto 0;
    max-width: 26rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .scatter-footnote strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .scatter-logo {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: rotate(var(--rot));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 3;
    animation: scatter-pop 0.6s ease both;
    animation-delay: var(--delay);
    transition: transform 0.3s ease;
  }

  .scatter-logo:hover {
    transform: rotate(0deg) scale(1.15);
    z-index: 10;
  }

  .scatter-logo img {
    width: var(--size);
    height: var(--size);
    object-fit: contain;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.1));
    animation: float var(--float-dur, 5s) ease-in-out infinite;
    animation-delay: var(--float-offset, 0s);
  }

  /* Pause the ambient bob while hovering so the lift reads cleanly */
  .scatter-logo:hover img {
    animation-play-state: paused;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scatter-logo img {
      animation: none;
    }
  }

  .scatter-logo span {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .scatter-logo:hover span {
    opacity: 1;
  }

  @keyframes scatter-pop {
    from {
      opacity: 0;
      transform: rotate(var(--rot)) scale(0.5);
    }
    to {
      opacity: 1;
      transform: rotate(var(--rot)) scale(1);
    }
  }

  /* Anatomy: nested model / CodeAct / harness layers */
  .anatomy-slide {
    text-align: center;
  }

  .anatomy-slide .lead {
    margin-left: auto;
    margin-right: auto;
  }

  .anatomy-slide em {
    font-style: italic;
    color: var(--color-accent);
  }

  .anatomy {
    display: flex;
    justify-content: center;
    margin: 2.5rem 0;
    perspective: 1000px;
  }

  /*
    Each layer is a labeled box; nesting the DOM mirrors the concept.
    Depth comes from soft colored shadows (not gradient borders, which would
    flood a translucent fill). Layers cascade in outer -> inner on entry.
  */
  .layer {
    position: relative;
    border-radius: 1.25rem;
    border: 1.5px solid;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    opacity: 0;
    animation: layer-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .layer__label {
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .layer__sub {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  /* Outer shell — the harness */
  .layer--harness {
    border-color: rgba(99, 102, 241, 0.45);
    background: linear-gradient(180deg, #eef0fe, #f6f7fe);
    padding: 1.4rem 2rem 2.2rem;
    width: 100%;
    max-width: 34rem;
    box-shadow:
      0 18px 40px -12px rgba(79, 70, 229, 0.28),
      0 4px 14px rgba(79, 70, 229, 0.08);
    animation-delay: 0.05s;
  }

  .layer--harness > .layer__label {
    color: var(--color-accent);
    font-size: 0.95rem;
  }

  .layer__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    margin: 0.7rem 0 1.4rem;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-accent);
    background: rgba(79, 70, 229, 0.08);
    border: 1px solid rgba(79, 70, 229, 0.2);
    padding: 0.18rem 0.65rem;
    border-radius: 999px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .tag:hover {
    transform: translateY(-2px);
    background: rgba(79, 70, 229, 0.16);
  }

  /* Middle ring — CodeAct */
  .layer--codeact {
    border-color: rgba(124, 58, 237, 0.5);
    background: linear-gradient(180deg, #f3edfd, #faf7fe);
    padding: 1.25rem 2rem 1.9rem;
    width: 100%;
    box-shadow: 0 12px 28px -10px rgba(124, 58, 237, 0.3);
    animation-delay: 0.2s;
  }

  .layer--codeact > .layer__label {
    color: #7c3aed;
    font-size: 1rem;
  }

  /* Core — the model */
  .layer--model {
    border-color: rgba(26, 26, 46, 0.85);
    background: linear-gradient(180deg, #ffffff, #f4f4fb);
    padding: 1.4rem 2.5rem;
    margin-top: 1.1rem;
    width: 100%;
    box-shadow:
      0 10px 30px -8px rgba(0, 0, 0, 0.18),
      0 0 0 5px rgba(255, 255, 255, 0.7);
    animation-delay: 0.38s;
  }

  .layer--model > .layer__label {
    color: var(--color-text);
    font-size: 1.1rem;
  }

  @keyframes layer-in {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .layer {
      animation: none;
      opacity: 1;
    }
  }

  .anatomy-caption {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ===== Flow diagram: CODE → systems → knowledge work ===== */
  .control-slide {
    position: relative;
    text-align: center;
    max-width: 64rem;
    margin: 0 auto;
  }

  .control-slide::before,
  .control-slide::after {
    content: '';
    position: absolute;
    pointer-events: none;
    filter: blur(24px);
    z-index: 0;
    opacity: 0.45;
  }

  .control-slide::before {
    top: -4rem;
    left: 16%;
    width: 15rem;
    height: 15rem;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.09), transparent 72%);
  }

  .control-slide::after {
    right: 8%;
    bottom: -3rem;
    width: 11rem;
    height: 11rem;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.08), transparent 74%);
  }

  .control-slide > * {
    position: relative;
    z-index: 1;
  }

  .overline--glow {
    color: var(--color-accent);
    display: inline-block;
  }

  .control-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: var(--color-text);
    max-width: 13ch;
    margin: 0.95rem auto 1.1rem;
  }

  .control-title__accent {
    background: linear-gradient(100deg, #4f46e5, #7c3aed 60%, #a855f7);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .control-lead {
    font-size: clamp(1rem, 1.45vw, 1.14rem);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.55;
  }

  .control-lead strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .control-caption {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    font-weight: 500;
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Three-column flow layout */
  .flow {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.7rem, 1.5vw, 1rem);
    max-width: 64rem;
    margin: 2.75rem auto 1.5rem;
    padding: 2rem clamp(1.2rem, 3vw, 1.8rem);
    border-radius: 1.5rem;
    border: 1px solid rgba(99, 102, 241, 0.06);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 249, 255, 0.98));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 18px 40px -34px rgba(15, 23, 42, 0.12);
    overflow: hidden;
    isolation: isolate;
  }

  .flow::before {
    content: '';
    position: absolute;
    inset: 1rem;
    inset: 1.1rem;
    border-radius: 0;
    border: 0;
    pointer-events: none;
  }

  .flow::after {
    content: '';
    position: absolute;
    left: 14%;
    right: 14%;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(203, 213, 225, 0), rgba(203, 213, 225, 0.9) 28%, rgba(203, 213, 225, 0.9) 72%, rgba(203, 213, 225, 0));
    opacity: 0.8;
    pointer-events: none;
  }

  .flow > * {
    position: relative;
    z-index: 1;
  }

  /* Left hub: the code orb */
  .flow__hub {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.45rem 0 0.25rem;
  }

  .flow__orb {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    width: clamp(6.1rem, 10vw, 7rem);
    height: clamp(6.1rem, 10vw, 7rem);
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0) 42%),
      radial-gradient(circle at 38% 32%, #8b93ff 0%, #5b63e8 42%, #4338ca 78%, #3730a3 100%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.9),
      0 0 0 4px rgba(99, 102, 241, 0.05),
      0 0 28px -14px rgba(99, 102, 241, 0.18),
      0 14px 24px -18px rgba(67, 56, 202, 0.24),
      inset 0 3px 16px rgba(255, 255, 255, 0.4),
      inset 0 -8px 18px rgba(55, 48, 140, 0.5);
  }

  .flow__orb::after {
    content: '';
    position: absolute;
    inset: -7%;
    border-radius: 50%;
    border: 1px solid rgba(99, 102, 241, 0.08);
    pointer-events: none;
  }

  .flow__orb-glow {
    position: absolute;
    inset: 20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 70%);
    filter: blur(3px);
    pointer-events: none;
  }

  .flow__orb-icon {
    position: relative;
    width: clamp(2rem, 5vw, 2.6rem);
    height: clamp(2rem, 5vw, 2.6rem);
    color: #ffffff;
    filter: drop-shadow(0 2px 4px rgba(40, 33, 120, 0.5));
  }

  .flow__orb-label {
    position: relative;
    font-family: var(--font-mono);
    font-size: clamp(0.6rem, 1.4vw, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 1px 3px rgba(40, 33, 120, 0.5);
  }

  /* Arrow columns between hub → systems → work */
  .flow__arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 4.5rem;
    padding: 0 clamp(0.3rem, 1.6vw, 0.85rem);
    flex-shrink: 0;
  }

  .flow__arrow-label {
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    padding: 0;
  }

  .flow__arrow-svg {
    width: 2.35rem;
    color: #94a3b8;
    opacity: 1;
    filter: none;
  }

  /* Middle + right columns */
  .flow__col {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 1.05rem 1.05rem 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(229, 231, 235, 0.95);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 10px 24px -24px rgba(15, 23, 42, 0.16);
    min-width: min(16rem, 100%);
  }

  .flow__col--sys {
    background: #ffffff;
  }

  .flow__col--work {
    border-color: rgba(99, 102, 241, 0.1);
    background: rgba(248, 247, 255, 0.96);
    box-shadow: 0 12px 24px -24px rgba(79, 70, 229, 0.12);
    min-width: min(17rem, 100%);
  }

  .flow__col-header {
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin-bottom: 0.05rem;
  }

  .flow__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.55rem;
    width: 100%;
    max-width: none;
  }

  /* Base chip */
  .flow__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1;
    min-height: 2.2rem;
    padding: 0.58rem 0.92rem;
    border-radius: 999px;
    white-space: nowrap;
    transition: transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
    opacity: 0;
    animation: chip-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.3s + var(--i) * 0.06s);
  }

  .flow__chip:hover {
    transform: translateY(-2px);
  }

  /* Systems chips (the plumbing) — quieter */
  .flow__chip--sys {
    color: var(--color-text-muted);
    background: #f8fafc;
    border: 1px solid rgba(229, 231, 235, 0.95);
    box-shadow: none;
  }

  .flow__chip--sys:hover {
    box-shadow: 0 8px 18px -12px rgba(15, 23, 42, 0.22);
    color: var(--color-text);
  }

  /* Work chips (the payoff) — visually dominant */
  .flow__chip--work {
    color: var(--color-accent-dim);
    background: #f5f3ff;
    border: 1px solid rgba(99, 102, 241, 0.22);
    box-shadow: none;
  }

  .flow__chip--work:hover {
    box-shadow: 0 8px 16px -16px rgba(79, 70, 229, 0.18);
  }

  @keyframes chip-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow__chip { animation: none; opacity: 1; }
  }

  @media (max-width: 640px) {
    .flow {
      flex-direction: column;
      gap: 0.95rem;
      padding: 1.35rem 0.95rem 1.5rem;
    }

    .flow::after {
      display: none;
    }

    .flow__arrow {
      flex-direction: row;
      min-width: 0;
      padding: 0;
    }

    .flow__arrow-svg {
      transform: rotate(90deg);
      width: 2.25rem;
    }

    .flow__col {
      align-items: center;
      width: min(100%, 24rem);
    }

    .flow__col--work {
      transform: none;
    }

    .flow__col-header {
      align-self: center;
    }

    .flow__chips {
      justify-content: center;
      max-width: none;
    }
  }

  /* ===== Slide 5: OpenCode runtime architecture ===== */
  .runtime {
    position: relative;
    text-align: center;
    max-width: 64rem;
    margin: 0 auto;
  }

  .runtime::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 4.5rem;
    width: 36rem;
    height: 14rem;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12), transparent 70%);
    filter: blur(36px);
    pointer-events: none;
  }

  .runtime > * {
    position: relative;
    z-index: 1;
  }

  .runtime__lead {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0;
  }

  .runtime__diagram {
    margin-top: 1.45rem;
  }

  .runtime__strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
    width: min(100%, 44rem);
    margin: 0 auto;
    padding: 0.35rem;
    border-radius: 1.1rem;
    background: linear-gradient(180deg, #ffffff, #fbfcff);
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 12px 24px -24px rgba(15, 23, 42, 0.14);
  }

  .runtime__strip-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.08rem;
    min-height: 4rem;
    padding: 0.55rem 0.8rem;
    border-radius: 0.85rem;
    background: transparent;
    transition: background 0.2s ease;
  }

  .runtime__strip-item:hover {
    background: rgba(248, 250, 252, 0.92);
  }

  .runtime__strip-item:not(:last-child) {
    border-right: 1px solid rgba(226, 232, 240, 0.9);
  }

  .runtime__strip-item strong {
    font-size: 0.86rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .runtime__strip-item small {
    font-size: 0.67rem;
    color: var(--color-text-muted);
  }

  .runtime__strip-arrow {
    display: none;
  }

  .runtime__band {
    margin-bottom: 0.9rem;
  }

  .runtime__band-label,
  .runtime__frame-label,
  .runtime__store-label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    margin-bottom: 0.65rem;
  }

  .runtime__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 0.8rem;
  }

  .runtime__top-arrow {
    width: 2.4rem;
    height: 0.75rem;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .runtime__node,
  .runtime__support,
  .runtime__store-card {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 10px 24px -22px rgba(15, 23, 42, 0.14);
  }

  .runtime__node {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.95rem 1rem;
    border-radius: 1.05rem;
    min-height: 6.5rem;
    justify-content: center;
  }

  .runtime__node--plain {
    text-align: left;
  }

  .runtime__node-title,
  .runtime__support-title,
  .runtime__store-title,
  .runtime__core-title {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.25;
  }

  .runtime__kicker {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-accent);
  }

  .runtime__node-meta,
  .runtime__support-meta,
  .runtime__store-meta,
  .runtime__core-sub {
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .runtime__node-meta code,
  .runtime__support-meta code,
  .runtime__core-sub code {
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .runtime__frame {
    position: relative;
    margin: 1rem auto 0.75rem;
    padding: 1rem 1rem 0.95rem;
    border-radius: 1.35rem;
    border: 1px solid rgba(226, 232, 240, 0.9);
    background: linear-gradient(180deg, #fcfcff, #fafbff);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 18px 38px -34px rgba(15, 23, 42, 0.18);
    overflow: hidden;
    isolation: isolate;
  }

  .runtime__frame-label {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(99, 102, 241, 0.08);
    color: var(--color-accent-dim);
  }

  .runtime__frame::before {
    display: none;
  }

  .runtime__frame::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 46%;
    width: 28rem;
    height: 12rem;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.1), transparent 68%);
    pointer-events: none;
