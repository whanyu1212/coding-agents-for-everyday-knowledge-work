---
import Layout from '../layouts/Layout.astro';
import Slide from '../components/Slide.astro';
import Nav from '../components/Nav.astro';
import CodeBlock from '../components/CodeBlock.astro';

const sections = [
  { id: 'intro', label: 'Intro' },
  { id: 'what', label: 'Who\'s Who' },
  { id: 'landscape', label: 'Anatomy' },
  { id: 'how', label: 'Why It Generalizes' },
  { id: 'workflows', label: 'Runtime' },
  { id: 'harness', label: 'Extensions' },
  { id: 'extensibility-code', label: 'In Code' },
  { id: 'extensibility', label: 'Oh-My-OpenAgent' },
  { id: 'harness-power', label: 'What It Gives You' },
  { id: 'personalization', label: 'Own Your Harness' },
  { id: 'personalization-how', label: 'Two Roads' },
  { id: 'demo', label: 'Demo' },
  { id: 'tradeoffs', label: 'Trade-offs' },
  { id: 'takeaways', label: 'Takeaways' },
  { id: 'appendix-routing', label: 'Appendix · Routing' },
  { id: 'appendix-continuation', label: 'Appendix · Continuation' },
  { id: 'appendix-guardrails', label: 'Appendix · Guardrails' },
];
---

<Layout title="Coding Agents for Everyday Knowledge Work">
  <Nav sections={sections} />

  <!-- Slide 1: Title -->
  <Slide id="intro" variant="accent">
    <div class="title-slide">
      <p class="overline">Technical Sharing</p>
      <h1 class="title">Coding Agents for<br /><span class="highlight">Everyday Knowledge Work</span></h1>
      <p class="subtitle">
        They're not just code generators — they're coworkers that solve tasks through code.
        Learn, triage, review, and ship.
      </p>
      <div class="scroll-hint">
        <span class="scroll-hint__arrow">&#8595;</span>
        <span>Scroll to explore</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 2: Coding agents in the market -->
  <Slide id="what">
    <div class="scatter-slide">
      <div class="scatter-text">
        <p class="overline">The Market Right Now</p>
        <h2>Coding Agents Are<br /><span class="highlight">Everywhere</span></h2>
      </div>
      <div class="scatter-logo" style="--x: 8%; --y: 8%; --size: 6rem; --rot: -12deg; --delay: 0s; --float-dur: 5.5s; --float-offset: -0.4s;">
        <img src="/logos/claude.png" alt="Claude Code" />
        <span>Claude Code</span>
      </div>
      <div class="scatter-logo" style="--x: 70%; --y: 3%; --size: 5rem; --rot: 8deg; --delay: 0.1s; --float-dur: 6.5s; --float-offset: -2.1s;">
        <img src="/logos/codex.png" alt="Codex" />
        <span>Codex</span>
      </div>
      <div class="scatter-logo" style="--x: 30%; --y: 72%; --size: 5.5rem; --rot: -5deg; --delay: 0.2s; --float-dur: 4.5s; --float-offset: -3.3s;">
        <img src="/logos/antigravity.png" alt="Antigravity" />
        <span>Antigravity</span>
      </div>
      <div class="scatter-logo" style="--x: 78%; --y: 65%; --size: 4.5rem; --rot: 15deg; --delay: 0.3s; --float-dur: 7s; --float-offset: -1.2s;">
        <img src="/logos/opencode.png" alt="OpenCode" />
        <span>OpenCode</span>
      </div>
      <div class="scatter-logo" style="--x: 3%; --y: 52%; --size: 6.5rem; --rot: 6deg; --delay: 0.4s; --float-dur: 6s; --float-offset: -4.5s;">
        <img src="/logos/copilot.png" alt="GitHub Copilot" />
        <span>Copilot</span>
      </div>
      <div class="scatter-logo" style="--x: 80%; --y: 26%; --size: 6rem; --rot: -10deg; --delay: 0.5s; --float-dur: 5s; --float-offset: -2.8s;">
        <img src="/logos/cursor.svg" alt="Cursor" />
        <span>Cursor</span>
      </div>
      <div class="scatter-logo" style="--x: 43%; --y: 11%; --size: 5rem; --rot: 3deg; --delay: 0.6s; --float-dur: 5.8s; --float-offset: -1.9s;">
        <img src="/logos/pi.svg" alt="Pi" />
        <span>Pi</span>
      </div>
    </div>
  </Slide>

  <!-- Slide 3: Anatomy — model + CodeAct + harness -->
  <Slide id="landscape" variant="accent">
    <div class="content-slide anatomy-slide">
      <p class="overline">The Mental Model</p>
      <h2>So What <em>Is</em> a Coding Agent?</h2>
      <p class="lead">
        Strip away the branding and it's simple:
        <strong>a model doing CodeAct, wrapped in a harness.</strong>
      </p>

      <div class="anatomy">
        <!-- Outer shell: the harness -->
        <div class="layer layer--harness">
          <span class="layer__label">Harness</span>
          <div class="layer__tags">
            <!--
              TODO (your call): list the harness responsibilities you want to emphasize.
              These are the bits OF the harness that aren't the model or CodeAct itself.
              Common candidates — pick/tweak the ones that match how OpenCode works:
                context gathering · the agent loop · memory & compaction ·
                permissions & sandboxing · tool wiring · output parsing · session state
            -->
            <span class="tag">context</span>
            <span class="tag">the loop</span>
            <span class="tag">memory</span>
            <span class="tag">tools</span>
            <span class="tag">permissions</span>
          </div>

          <!-- Middle ring: CodeAct -->
          <div class="layer layer--codeact">
            <span class="layer__label">CodeAct</span>
            <span class="layer__sub">acts through code &amp; tools</span>

            <!-- Core: the model -->
            <div class="layer layer--model">
              <span class="layer__label">Model</span>
              <span class="layer__sub">reasons &amp; decides</span>
            </div>
          </div>
        </div>
      </div>

      <p class="anatomy-caption">
        Same model, different harness &rarr; a very different agent. That's why the six above
        feel so different despite often sharing the same underlying models.
      </p>
    </div>
  </Slide>

  <!-- Slide 4: Why it generalizes — code as universal interface (mission-control) -->
  <Slide id="how" variant="control">
    <div class="control-slide">
      <p class="overline overline--glow">Why It Generalizes</p>
      <h2 class="control-title">Code Is a <span class="control-title__accent">Universal Remote</span></h2>
      <p class="control-lead">
        The agent acts by writing <strong>code</strong> — and code can touch almost anything.
      </p>

      <!-- Three-column flow: CODE → systems → knowledge work.
           Reads left-to-right as a causal chain — no explanation needed. -->
      <div class="flow">
        <!-- Left: the code hub -->
        <div class="flow__hub">
          <span class="flow__orb">
            <span class="flow__orb-glow"></span>
            <svg class="flow__orb-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M8.5 7.5 4 12l4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.5 7.5 20 12l-4.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13.5 6 10.5 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            <span class="flow__orb-label">CODE</span>
          </span>
        </div>

        <!-- Arrow column 1 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">reaches</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Middle: systems column -->
        <div class="flow__col flow__col--sys">
          <span class="flow__col-header">Systems</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--sys" style="--i:0">APIs</span>
            <span class="flow__chip flow__chip--sys" style="--i:1">Databases</span>
            <span class="flow__chip flow__chip--sys" style="--i:2">Shell &amp; CLI</span>
            <span class="flow__chip flow__chip--sys" style="--i:3">Git &amp; PRs</span>
            <span class="flow__chip flow__chip--sys" style="--i:4">The web</span>
            <span class="flow__chip flow__chip--sys" style="--i:5">Files</span>
          </div>
        </div>

        <!-- Arrow column 2 -->
        <div class="flow__arrow">
          <span class="flow__arrow-label">enables</span>
          <svg viewBox="0 0 32 12" class="flow__arrow-svg"><path d="M0 6h26m0 0-5-4.5M26 6l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </div>

        <!-- Right: knowledge work column (the payoff — visually dominant) -->
        <div class="flow__col flow__col--work">
          <span class="flow__col-header">Knowledge Work</span>
          <div class="flow__chips">
            <span class="flow__chip flow__chip--work" style="--i:6">Research</span>
            <span class="flow__chip flow__chip--work" style="--i:7">Triage</span>
            <span class="flow__chip flow__chip--work" style="--i:8">Review</span>
            <span class="flow__chip flow__chip--work" style="--i:9">Analysis</span>
            <span class="flow__chip flow__chip--work" style="--i:10">Docs</span>
            <span class="flow__chip flow__chip--work" style="--i:11">Onboarding</span>
          </div>
        </div>
      </div>

      <p class="control-caption">
        One action language. Infinite reach.
      </p>
    </div>
  </Slide>

  <!-- Slide 5: OpenCode architecture — grounded in the actual core runtime -->
  <Slide id="workflows" variant="accent">
    <div class="content-slide runtime">
      <p class="overline">Inside OpenCode</p>
      <h2>What the Runtime <span class="highlight">Actually Looks Like</span></h2>
      <p class="lead runtime__lead">
        OpenCode is split three ways: process-global session scheduling, a cached runtime per
        location, and one durable <code>SessionRunner</code> loop that assembles context, model,
        and tools for each provider turn.
      </p>

      <div class="runtime__diagram">
        <div class="runtime__strip" aria-label="Process-global runtime control">
          <span class="runtime__strip-item"><strong>Session API</strong><small>admit / resume</small></span>
          <span class="runtime__strip-item"><strong>Drain Coordinator</strong><small>one active run</small></span>
          <span class="runtime__strip-item"><strong>Location Runtime</strong><small>cached per workspace</small></span>
        </div>

        <div class="runtime__frame">
          <span class="runtime__frame-label">Location-scoped runtime</span>
          <div class="runtime__compact">
            <div class="runtime__core">
              <span class="runtime__kicker">Per-turn loop</span>
              <span class="runtime__core-title">SessionRunner</span>
              <span class="runtime__core-sub">one <code>llm.stream(...)</code> turn at a time</span>
              <div class="runtime__pipeline">
                <span class="runtime__pill">context</span>
                <span class="runtime__pill">model</span>
                <span class="runtime__pill">tools</span>
                <span class="runtime__pill">events</span>
                <span class="runtime__pill">continue</span>
              </div>
            </div>

            <div class="runtime__support-grid">
              <div class="runtime__support">
                <span class="runtime__kicker">SessionStore</span>
                <span class="runtime__support-title">History</span>
              </div>
              <div class="runtime__support">
                <span class="runtime__kicker">Catalog</span>
                <span class="runtime__support-title">Models</span>
              </div>
              <div class="runtime__support">
                <span class="runtime__kicker">ToolRegistry</span>
                <span class="runtime__support-title">Tools</span>
              </div>
              <div class="runtime__support">
                <span class="runtime__kicker">Compaction</span>
                <span class="runtime__support-title">Memory</span>
              </div>
            </div>
          </div>
        </div>

        <div class="runtime__store-card runtime__store-card--compact">
          <span class="runtime__kicker">EventV2 &middot; SessionProjector &middot; SQLite</span>
          <span class="runtime__store-title">Replayable durable state</span>
        </div>

        <p class="runtime__caption">
          One idea: admit work globally, execute inside a location runtime, persist every turn as replayable state.
        </p>
      </div>
    </div>
  </Slide>

  <!-- Slide 6: How OpenCode loads extensions -->
  <Slide id="harness" variant="dark">
    <div class="content-slide deep-slide deep-slide--usage">
      <p class="overline">Advanced Usage</p>
      <h2>How OpenCode Loads <span class="highlight">Extensions</span></h2>
      <p class="lead deep-slide__lead">
        Skills and plugins enter OpenCode through different loading paths, but both extend the stock runtime.
      </p>

      <div class="loader-grid">
        <div class="loader-card loader-card--skill">
          <div class="loader-card__header">
            <span class="loader-card__kicker">Behavior Layer</span>
            <h3>Skills</h3>
          </div>
          <p class="loader-card__text">
            <code>skills[]</code> points to local roots or URLs. The skill loader discovers
            <code>SKILL.md</code>, parses frontmatter, and exposes those skills for intentional loading.
          </p>
          <div class="loader-flow">
            <span class="loader-step">skills[]</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">discover</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">SKILL.md</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">skill tool</span>
          </div>

          <div class="intervenes intervenes--skill">
            <span class="intervenes__label">Intervenes</span>
            <p class="intervenes__when">Model calls the built-in <code>skill</code> tool mid-conversation</p>
            <p class="intervenes__touches">Injects SKILL.md instructions + linked resources into the conversation context</p>
            <span class="intervenes__direction">pulled &middot; model-initiated, on demand</span>
          </div>

          <p class="loader-card__note">Best for recurring playbooks, checklists, and domain habits inside one agent.</p>
        </div>

        <div class="loader-card loader-card--plugin">
          <div class="loader-card__header">
            <span class="loader-card__kicker">Runtime Seam Layer</span>
            <h3>Plugins</h3>
          </div>
          <p class="loader-card__text">
            <code>PluginBoot</code> loads packages, plugins register ordered hooks,
            and those hooks mutate narrow seams like catalog defaults, SDK wiring, or review flows.
          </p>
          <div class="loader-flow">
            <span class="loader-step">PluginBoot</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">PluginV2</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">hooks</span>
            <span class="loader-connector">&#8594;</span>
            <span class="loader-step">runtime seams</span>
          </div>

          <div class="intervenes intervenes--plugin">
            <span class="intervenes__label">Intervenes</span>
            <p class="intervenes__when">Runtime fires hooks at lifecycle points</p>
            <div class="intervenes__hooks">
              <code>chat.params</code>
              <code>chat.message</code>
              <code>chat.headers</code>
              <code>tool.execute.before</code>
              <code>tool.execute.after</code>
              <code>tool.definition</code>
              <code>permission.ask</code>
              <code>experimental.session.compacting</code>
              <code>provider</code>
              <code>auth</code>
              <span class="intervenes__hooks-more">&hellip;</span>
            </div>
            <span class="intervenes__direction">pushed &middot; runtime-fired, always-on</span>
          </div>

          <p class="loader-card__example">e.g. Plannotator &mdash; plan review, annotations, feedback loop</p>
          <p class="loader-card__note">Good for provider defaults, org integrations, review UX, and workflow-layer extensions.</p>
        </div>
      </div>
    </div>
  </Slide>

  <!-- Slide 6.5: What the code actually looks like -->
  <Slide id="extensibility-code" variant="accent">
    <div class="content-slide code-interlude">
      <p class="overline">What It Actually Looks Like</p>
      <h2>Skill &amp; Plugin, <span class="highlight">in Code</span></h2>
      <p class="lead code-interlude__lead">
        A skill is markdown content. A plugin is a function that returns hook callbacks. Both wire into the same runtime &mdash; very differently.
      </p>

      <div class="code-interlude__grid">
        <!-- Skill side: SKILL.md -->
        <div class="code-pane code-pane--skill">
          <div class="code-pane__header">
            <span class="code-pane__filename">SKILL.md</span>
            <span class="code-pane__lang">markdown</span>
          </div>
          <pre class="code-pane__pre"><code><span class="code-mark code-mark--1">---
name: cloudflare
description: Comprehensive Cloudflare platform skill
  covering Workers, Pages, KV, D1, R2, AI, &hellip;
---</span>

<span class="code-mark code-mark--2"># Cloudflare Platform Skill

Consolidated skill for building on Cloudflare.
Use decision trees to pick the right product,
then load detailed references.</span></code></pre>
          <ul class="code-notes">
            <li><span class="code-notes__chip code-notes__chip--1">1</span><span class="code-notes__text"><strong>frontmatter</strong> &mdash; how the loader discovers this skill</span></li>
            <li><span class="code-notes__chip code-notes__chip--2">2</span><span class="code-notes__text"><strong>body</strong> &mdash; injected into the conversation when the model calls the <code>skill</code> tool</span></li>
          </ul>
          <div class="code-pane__caption">
            <span class="code-pane__caption-label">flow:</span>
            <span><code>skills[]</code> discovers it &middot; model decides to load it &middot; content injected as tool output</span>
          </div>
        </div>

        <!-- Plugin side: TypeScript -->
        <div class="code-pane code-pane--plugin">
          <div class="code-pane__header">
            <span class="code-pane__filename">cloudflare.ts</span>
            <span class="code-pane__lang">typescript</span>
          </div>
          <pre class="code-pane__pre"><code><Fragment set:html={`<span class="code-keyword">import</span> { Plugin } <span class="code-keyword">from</span> <span class="code-string">"@opencode-ai/plugin"</span>

<span class="code-keyword">export const</span> <span class="code-fn">CloudflarePlugin</span>: Plugin = <span class="code-keyword">async</span> () =&gt; {
  <span class="code-keyword">return</span> <span class="code-mark code-mark--1">{
    <span class="code-mark code-mark--2"><span class="code-string">"chat.params"</span></span>: <span class="code-keyword">async</span> (input, output) =&gt; {
      <span class="code-keyword">if</span> (input.model.providerID !== <span class="code-string">"cloudflare"</span>) <span class="code-keyword">return</span>
      <span class="code-mark code-mark--3">output.maxOutputTokens = <span class="code-keyword">undefined</span></span>
    },
  }</span>
}`} /></code></pre>
          <ul class="code-notes">
            <li><span class="code-notes__chip code-notes__chip--1">1</span><span class="code-notes__text"><strong>Hooks object</strong> &mdash; the contract the runtime reads</span></li>
            <li><span class="code-notes__chip code-notes__chip--2">2</span><span class="code-notes__text"><strong>hook key</strong> &mdash; the lifecycle point this fires at</span></li>
            <li><span class="code-notes__chip code-notes__chip--3">3</span><span class="code-notes__text"><strong>mutation</strong> &mdash; changes the outgoing LLM call</span></li>
          </ul>
          <div class="code-pane__caption">
            <span class="code-pane__caption-label">flow:</span>
            <span><code>PluginBoot</code> registers it &middot; runtime fires <code>chat.params</code> every turn &middot; this function mutates the outgoing call</span>
          </div>
        </div>
      </div>

      <div class="code-interlude__contrast">
        <span class="code-interlude__contrast-item code-interlude__contrast-item--skill">
          <span class="code-interlude__contrast-label">Skill</span>
          content the model can opt into
        </span>
        <span class="code-interlude__contrast-divider">vs</span>
        <span class="code-interlude__contrast-item code-interlude__contrast-item--plugin">
          <span class="code-interlude__contrast-label">Plugin</span>
          code the runtime calls into
        </span>
      </div>
    </div>
  </Slide>

  <!-- Slide 7: Deep dive — Oh-My-OpenAgent as a harness pack -->
  <Slide id="extensibility" variant="dark">
    <div class="content-slide deep-slide deep-slide--practice omo-slide">
      <p class="overline">When a Plugin Becomes a Harness</p>
      <h2>Deep Dive &mdash; <span class="highlight">Oh-My-OpenAgent</span></h2>
      <p class="lead deep-slide__lead">
        Installs as a plugin. Replaces the working style.
      </p>

      <!-- Three-layer architecture sitting on top of the runtime echo from slide 5 -->
      <div class="omo-architecture" aria-label="Oh-My-OpenAgent architecture">
        <div class="omo-layer omo-layer--planning">
          <span class="omo-layer__kicker">Planning</span>
          <div class="omo-layer__agents">
            <span class="omo-agent omo-agent--lead">Prometheus</span>
            <span class="omo-agent">Metis</span>
            <span class="omo-agent">Momus</span>
          </div>
          <span class="omo-layer__note">interview &middot; gap-check &middot; review</span>
        </div>

        <span class="omo-arrow" aria-hidden="true">&rarr;</span>

        <div class="omo-layer omo-layer--execution">
          <span class="omo-layer__kicker">Execution</span>
          <div class="omo-layer__agents">
            <span class="omo-agent omo-agent--lead">Atlas</span>
          </div>
          <span class="omo-layer__note">reads plan &middot; delegates &middot; verifies</span>
        </div>

        <span class="omo-arrow" aria-hidden="true">&rarr;</span>

        <div class="omo-layer omo-layer--workers">
          <span class="omo-layer__kicker">Workers</span>
          <div class="omo-layer__agents omo-layer__agents--grid">
            <span class="omo-agent omo-agent--lead">Hephaestus</span>
            <span class="omo-agent">Oracle</span>
            <span class="omo-agent">Explore</span>
            <span class="omo-agent">Librarian</span>
            <span class="omo-agent">Multimodal-Looker</span>
            <span class="omo-agent">+ dynamic agent</span>
          </div>
          <span class="omo-layer__note">specialized by intent, not model name</span>
        </div>
      </div>

      <div class="omo-runtime-base" aria-label="Runs inside the OpenCode runtime">
        <span class="omo-runtime-base__label">runs inside</span>
        <div class="omo-runtime-base__strip">
          <span>Session API</span>
          <span>SessionRunner</span>
          <span>ToolRegistry</span>
          <span>EventV2</span>
        </div>
        <span class="omo-runtime-base__caption">the OpenCode runtime from slide 5</span>
      </div>

      <!-- Workflow narrative (option C) -->
      <div class="omo-workflow">
        <span class="omo-workflow__kicker">How a task flows through it</span>
        <ol class="omo-workflow__steps">
          <li><span class="omo-workflow__num">1</span><span class="omo-workflow__text">User types <code>ulw</code> (Ultra Work mode)</span></li>
          <li><span class="omo-workflow__num">2</span><span class="omo-workflow__text">Prometheus interviews + explores &rarr; Metis catches gaps &rarr; Momus reviews</span></li>
          <li><span class="omo-workflow__num">3</span><span class="omo-workflow__text">Plan + session state tracked in <code>boulder.json</code></span></li>
          <li><span class="omo-workflow__num">4</span><span class="omo-workflow__text">Atlas reads the verified plan and delegates to specialists</span></li>
          <li><span class="omo-workflow__num">5</span><span class="omo-workflow__text">Workers return results + learnings; Atlas verifies, loops or reports</span></li>
        </ol>
      </div>

      <!-- Category routing strip — concrete grounding for "owns the choreography" -->
      <div class="omo-routing">
        <span class="omo-routing__label">Routing by intent:</span>
        <span class="omo-routing__chip"><code>deep</code> &rarr; GPT-5.5 Medium</span>
        <span class="omo-routing__chip"><code>visual-engineering</code> &rarr; Gemini 3.1 Pro</span>
        <span class="omo-routing__chip"><code>quick</code> &rarr; GPT-5.4 Mini</span>
        <span class="omo-routing__chip"><code>ultrabrain</code> &rarr; GPT-5.5 xHigh</span>
