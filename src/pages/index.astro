    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  .highlight {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto 3rem;
  }

  .scroll-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    animation: bounce 2s infinite;
  }

  .scroll-hint__arrow {
    font-size: 1.2rem;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Content slides */
  .content-slide h2 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 42rem;
    margin-bottom: 2.5rem;
  }

  /* Grid */
  .grid {
    display: grid;
    gap: 1.25rem;
  }

  .grid--2 {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .grid--3 {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  /* Pipeline */
  .pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .pipeline__step {
    flex: 1;
    min-width: 160px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }

  .pipeline__step h3 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }

  .pipeline__step p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .pipeline__num {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent-dim);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .pipeline__arrow {
    color: var(--color-accent);
    font-size: 1.5rem;
    padding-top: 2rem;
    flex-shrink: 0;
  }

  /* Pros/Cons */
  .pros-cons {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .pros-cons__header {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid;
  }

  .pros-cons__header--pro {
    border-color: #34d399;
    color: #34d399;
  }

  .pros-cons__header--con {
    border-color: #fb923c;
    color: #fb923c;
  }

  .pros-cons ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pros-cons li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1.2rem;
    position: relative;
  }

  .pros-cons li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-text-muted);
  }

  /* Takeaway list */
  .takeaway-list {
    list-style: none;
    counter-reset: takeaway;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 42rem;
  }

  .takeaway-list li {
    counter-increment: takeaway;
    padding-left: 2.5rem;
    position: relative;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .takeaway-list li strong {
    color: var(--color-text);
    display: block;
    margin-bottom: 0.25rem;
  }

  .takeaway-list li::before {
    content: counter(takeaway);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent-dim);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Closing */
  .closing {
    margin-top: 3rem;
    text-align: center;
  }

  .closing__text {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  /* Scatter logos */
  .scatter-slide {
    position: relative;
    width: 100%;
    height: 80vh;
  }

  .scatter-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
  }

  .scatter-text h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
  }

  .scatter-footnote {
    margin: 1.5rem auto 0;
    max-width: 26rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .scatter-footnote strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .scatter-logo {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: rotate(var(--rot));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 3;
    animation: scatter-pop 0.6s ease both;
    animation-delay: var(--delay);
    transition: transform 0.3s ease;
  }

  .scatter-logo:hover {
    transform: rotate(0deg) scale(1.15);
    z-index: 10;
  }

  .scatter-logo img {
    width: var(--size);
    height: var(--size);
    object-fit: contain;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.1));
    animation: float var(--float-dur, 5s) ease-in-out infinite;
    animation-delay: var(--float-offset, 0s);
  }

  /* Pause the ambient bob while hovering so the lift reads cleanly */
  .scatter-logo:hover img {
    animation-play-state: paused;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scatter-logo img {
      animation: none;
    }
  }

  .scatter-logo span {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .scatter-logo:hover span {
    opacity: 1;
  }

  @keyframes scatter-pop {
    from {
      opacity: 0;
      transform: rotate(var(--rot)) scale(0.5);
    }
    to {
      opacity: 1;
      transform: rotate(var(--rot)) scale(1);
    }
  }

  /* Anatomy: nested model / CodeAct / harness layers */
  .anatomy-slide {
    text-align: center;
  }

  .anatomy-slide .lead {
    margin-left: auto;
    margin-right: auto;
  }

  .anatomy-slide em {
    font-style: italic;
    color: var(--color-accent);
  }

  .anatomy {
    display: flex;
    justify-content: center;
    margin: 2.5rem 0;
    perspective: 1000px;
  }

  /*
    Each layer is a labeled box; nesting the DOM mirrors the concept.
    Depth comes from soft colored shadows (not gradient borders, which would
    flood a translucent fill). Layers cascade in outer -> inner on entry.
  */
  .layer {
    position: relative;
    border-radius: 1.25rem;
    border: 1.5px solid;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    opacity: 0;
    animation: layer-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .layer__label {
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .layer__sub {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  /* Outer shell — the harness */
  .layer--harness {
    border-color: rgba(99, 102, 241, 0.45);
    background: linear-gradient(180deg, #eef0fe, #f6f7fe);
    padding: 1.4rem 2rem 2.2rem;
    width: 100%;
    max-width: 34rem;
    box-shadow:
      0 18px 40px -12px rgba(79, 70, 229, 0.28),
      0 4px 14px rgba(79, 70, 229, 0.08);
    animation-delay: 0.05s;
  }

  .layer--harness > .layer__label {
    color: var(--color-accent);
    font-size: 0.95rem;
  }

  .layer__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    margin: 0.7rem 0 1.4rem;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-accent);
    background: rgba(79, 70, 229, 0.08);
    border: 1px solid rgba(79, 70, 229, 0.2);
    padding: 0.18rem 0.65rem;
    border-radius: 999px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .tag:hover {
    transform: translateY(-2px);
    background: rgba(79, 70, 229, 0.16);
  }

  /* Middle ring — CodeAct */
  .layer--codeact {
    border-color: rgba(124, 58, 237, 0.5);
    background: linear-gradient(180deg, #f3edfd, #faf7fe);
    padding: 1.25rem 2rem 1.9rem;
    width: 100%;
    box-shadow: 0 12px 28px -10px rgba(124, 58, 237, 0.3);
    animation-delay: 0.2s;
  }

  .layer--codeact > .layer__label {
    color: #7c3aed;
    font-size: 1rem;
  }

  /* Core — the model */
  .layer--model {
    border-color: rgba(26, 26, 46, 0.85);
    background: linear-gradient(180deg, #ffffff, #f4f4fb);
    padding: 1.4rem 2.5rem;
    margin-top: 1.1rem;
    width: 100%;
    box-shadow:
      0 10px 30px -8px rgba(0, 0, 0, 0.18),
      0 0 0 5px rgba(255, 255, 255, 0.7);
    animation-delay: 0.38s;
  }

  .layer--model > .layer__label {
    color: var(--color-text);
    font-size: 1.1rem;
  }

  @keyframes layer-in {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .layer {
      animation: none;
      opacity: 1;
    }
  }

  .anatomy-caption {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ===== Flow diagram: CODE → systems → knowledge work ===== */
  .control-slide {
    position: relative;
    text-align: center;
    max-width: 64rem;
    margin: 0 auto;
  }

  .control-slide::before,
  .control-slide::after {
    content: '';
    position: absolute;
    pointer-events: none;
    filter: blur(24px);
    z-index: 0;
    opacity: 0.45;
  }

  .control-slide::before {
    top: -4rem;
    left: 16%;
    width: 15rem;
    height: 15rem;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.09), transparent 72%);
  }

  .control-slide::after {
    right: 8%;
    bottom: -3rem;
    width: 11rem;
    height: 11rem;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.08), transparent 74%);
  }

  .control-slide > * {
    position: relative;
    z-index: 1;
  }

  .overline--glow {
    color: var(--color-accent);
    display: inline-block;
  }

  .control-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: var(--color-text);
    max-width: 13ch;
    margin: 0.95rem auto 1.1rem;
  }

  .control-title__accent {
    background: linear-gradient(100deg, #4f46e5, #7c3aed 60%, #a855f7);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .control-lead {
    font-size: clamp(1rem, 1.45vw, 1.14rem);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.55;
  }

  .control-lead strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .control-caption {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    font-weight: 500;
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Three-column flow layout */
  .flow {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.7rem, 1.5vw, 1rem);
    max-width: 64rem;
    margin: 2.75rem auto 1.5rem;
    padding: 2rem clamp(1.2rem, 3vw, 1.8rem);
    border-radius: 1.5rem;
    border: 1px solid rgba(99, 102, 241, 0.06);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 249, 255, 0.98));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 18px 40px -34px rgba(15, 23, 42, 0.12);
    overflow: hidden;
    isolation: isolate;
  }

  .flow::before {
    content: '';
    position: absolute;
    inset: 1rem;
    inset: 1.1rem;
    border-radius: 0;
    border: 0;
    pointer-events: none;
  }

  .flow::after {
    content: '';
    position: absolute;
    left: 14%;
    right: 14%;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(203, 213, 225, 0), rgba(203, 213, 225, 0.9) 28%, rgba(203, 213, 225, 0.9) 72%, rgba(203, 213, 225, 0));
    opacity: 0.8;
    pointer-events: none;
  }

  .flow > * {
    position: relative;
    z-index: 1;
  }

  /* Left hub: the code orb */
  .flow__hub {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.45rem 0 0.25rem;
  }

  .flow__orb {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    width: clamp(6.1rem, 10vw, 7rem);
    height: clamp(6.1rem, 10vw, 7rem);
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0) 42%),
      radial-gradient(circle at 38% 32%, #8b93ff 0%, #5b63e8 42%, #4338ca 78%, #3730a3 100%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.9),
      0 0 0 4px rgba(99, 102, 241, 0.05),
      0 0 28px -14px rgba(99, 102, 241, 0.18),
      0 14px 24px -18px rgba(67, 56, 202, 0.24),
      inset 0 3px 16px rgba(255, 255, 255, 0.4),
      inset 0 -8px 18px rgba(55, 48, 140, 0.5);
  }

  .flow__orb::after {
    content: '';
    position: absolute;
    inset: -7%;
    border-radius: 50%;
    border: 1px solid rgba(99, 102, 241, 0.08);
    pointer-events: none;
  }

  .flow__orb-glow {
    position: absolute;
    inset: 20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 70%);
    filter: blur(3px);
    pointer-events: none;
  }

  .flow__orb-icon {
    position: relative;
    width: clamp(2rem, 5vw, 2.6rem);
    height: clamp(2rem, 5vw, 2.6rem);
    color: #ffffff;
    filter: drop-shadow(0 2px 4px rgba(40, 33, 120, 0.5));
  }

  .flow__orb-label {
    position: relative;
    font-family: var(--font-mono);
    font-size: clamp(0.6rem, 1.4vw, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 1px 3px rgba(40, 33, 120, 0.5);
  }

  /* Arrow columns between hub → systems → work */
  .flow__arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 4.5rem;
    padding: 0 clamp(0.3rem, 1.6vw, 0.85rem);
    flex-shrink: 0;
  }

  .flow__arrow-label {
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    padding: 0;
  }

  .flow__arrow-svg {
    width: 2.35rem;
    color: #94a3b8;
    opacity: 1;
    filter: none;
  }

  /* Middle + right columns */
  .flow__col {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 1.05rem 1.05rem 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(229, 231, 235, 0.95);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 10px 24px -24px rgba(15, 23, 42, 0.16);
    min-width: min(16rem, 100%);
  }

  .flow__col--sys {
    background: #ffffff;
  }

  .flow__col--work {
    border-color: rgba(99, 102, 241, 0.1);
    background: rgba(248, 247, 255, 0.96);
    box-shadow: 0 12px 24px -24px rgba(79, 70, 229, 0.12);
    min-width: min(17rem, 100%);
  }

  .flow__col-header {
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    margin-bottom: 0.05rem;
  }

  .flow__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.55rem;
    width: 100%;
    max-width: none;
  }

  /* Base chip */
  .flow__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1;
    min-height: 2.2rem;
    padding: 0.58rem 0.92rem;
    border-radius: 999px;
    white-space: nowrap;
    transition: transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
    opacity: 0;
    animation: chip-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.3s + var(--i) * 0.06s);
  }

  .flow__chip:hover {
    transform: translateY(-2px);
  }

  /* Systems chips (the plumbing) — quieter */
  .flow__chip--sys {
    color: var(--color-text-muted);
    background: #f8fafc;
    border: 1px solid rgba(229, 231, 235, 0.95);
    box-shadow: none;
  }

  .flow__chip--sys:hover {
    box-shadow: 0 8px 18px -12px rgba(15, 23, 42, 0.22);
    color: var(--color-text);
  }

  /* Work chips (the payoff) — visually dominant */
  .flow__chip--work {
    color: var(--color-accent-dim);
    background: #f5f3ff;
    border: 1px solid rgba(99, 102, 241, 0.22);
    box-shadow: none;
  }

  .flow__chip--work:hover {
    box-shadow: 0 8px 16px -16px rgba(79, 70, 229, 0.18);
  }

  @keyframes chip-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow__chip { animation: none; opacity: 1; }
  }

  @media (max-width: 640px) {
    .flow {
      flex-direction: column;
      gap: 0.95rem;
      padding: 1.35rem 0.95rem 1.5rem;
    }

    .flow::after {
      display: none;
    }

    .flow__arrow {
      flex-direction: row;
      min-width: 0;
      padding: 0;
    }

    .flow__arrow-svg {
      transform: rotate(90deg);
      width: 2.25rem;
    }

    .flow__col {
      align-items: center;
      width: min(100%, 24rem);
    }

    .flow__col--work {
      transform: none;
    }

    .flow__col-header {
      align-self: center;
    }

    .flow__chips {
      justify-content: center;
      max-width: none;
    }
  }

  /* ===== Slide 5: OpenCode runtime architecture ===== */
  .runtime {
    position: relative;
    text-align: center;
    max-width: 64rem;
    margin: 0 auto;
  }

  .runtime::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 4.5rem;
    width: 36rem;
    height: 14rem;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12), transparent 70%);
    filter: blur(36px);
    pointer-events: none;
  }

  .runtime > * {
    position: relative;
    z-index: 1;
  }

  .runtime__lead {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0;
  }

  .runtime__diagram {
    margin-top: 1.45rem;
  }

  .runtime__strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
    width: min(100%, 44rem);
    margin: 0 auto;
    padding: 0.35rem;
    border-radius: 1.1rem;
    background: linear-gradient(180deg, #ffffff, #fbfcff);
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 12px 24px -24px rgba(15, 23, 42, 0.14);
  }

  .runtime__strip-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.08rem;
    min-height: 4rem;
    padding: 0.55rem 0.8rem;
    border-radius: 0.85rem;
    background: transparent;
    transition: background 0.2s ease;
  }

  .runtime__strip-item:hover {
    background: rgba(248, 250, 252, 0.92);
  }

  .runtime__strip-item:not(:last-child) {
    border-right: 1px solid rgba(226, 232, 240, 0.9);
  }

  .runtime__strip-item strong {
    font-size: 0.86rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .runtime__strip-item small {
    font-size: 0.67rem;
    color: var(--color-text-muted);
  }

  .runtime__strip-arrow {
    display: none;
  }

  .runtime__band {
    margin-bottom: 0.9rem;
  }

  .runtime__band-label,
  .runtime__frame-label,
  .runtime__store-label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    margin-bottom: 0.65rem;
  }

  .runtime__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 0.8rem;
  }

  .runtime__top-arrow {
    width: 2.4rem;
    height: 0.75rem;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .runtime__node,
  .runtime__support,
  .runtime__store-card {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 10px 24px -22px rgba(15, 23, 42, 0.14);
  }

  .runtime__node {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.95rem 1rem;
    border-radius: 1.05rem;
    min-height: 6.5rem;
    justify-content: center;
  }

  .runtime__node--plain {
    text-align: left;
  }

  .runtime__node-title,
  .runtime__support-title,
  .runtime__store-title,
  .runtime__core-title {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.25;
  }

  .runtime__kicker {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-accent);
  }

  .runtime__node-meta,
  .runtime__support-meta,
  .runtime__store-meta,
  .runtime__core-sub {
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .runtime__node-meta code,
  .runtime__support-meta code,
  .runtime__core-sub code {
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .runtime__frame {
    position: relative;
    margin: 1rem auto 0.75rem;
    padding: 1rem 1rem 0.95rem;
    border-radius: 1.35rem;
    border: 1px solid rgba(226, 232, 240, 0.9);
    background: linear-gradient(180deg, #fcfcff, #fafbff);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 18px 38px -34px rgba(15, 23, 42, 0.18);
    overflow: hidden;
    isolation: isolate;
  }

  .runtime__frame-label {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(99, 102, 241, 0.08);
    color: var(--color-accent-dim);
  }

  .runtime__frame::before {
    display: none;
  }

  .runtime__frame::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 46%;
    width: 28rem;
    height: 12rem;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.1), transparent 68%);
    pointer-events: none;
    z-index: 0;
  }

  .runtime__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.45fr) minmax(0, 1.05fr);
    grid-template-areas:
      '. top .'
      'left core right'
      '. bottom .';
    align-items: center;
    gap: 0.85rem;
  }

  .runtime__compact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    position: relative;
    z-index: 1;
  }

  .runtime__support-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    width: 100%;
    gap: 0.55rem;
  }

  .runtime__support {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.22rem;
    justify-content: center;
    min-height: 4rem;
    padding: 0.8rem 0.7rem;
    border-radius: 0.85rem;
    text-align: center;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    box-shadow: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .runtime__support:hover {
    transform: translateY(-1px);
    border-color: rgba(203, 213, 225, 0.95);
  }

  .runtime__support::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    border-radius: 999px;
    background: var(--runtime-support-accent, rgba(148, 163, 184, 0.5));
  }

  .runtime__support:nth-child(1) { --runtime-support-accent: rgba(99, 102, 241, 0.5); }
  .runtime__support:nth-child(2) { --runtime-support-accent: rgba(139, 92, 246, 0.45); }
  .runtime__support:nth-child(3) { --runtime-support-accent: rgba(45, 212, 191, 0.5); }
  .runtime__support:nth-child(4) { --runtime-support-accent: rgba(251, 191, 36, 0.55); }

  .runtime__support .runtime__kicker {
    color: var(--color-text-muted);
  }

  .runtime__support-title {
    font-size: 0.9rem;
  }

  .runtime__support--top { grid-area: top; }
  .runtime__support--left { grid-area: left; }
  .runtime__support--right { grid-area: right; }
  .runtime__support--bottom { grid-area: bottom; }

  .runtime__core {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    width: min(100%, 26rem);
    padding: 0.95rem 0.9rem 0.9rem;
    border-radius: 1rem;
    background: linear-gradient(180deg, #ffffff, #f8f6ff);
    border: 1px solid rgba(129, 140, 248, 0.2);
    box-shadow:
      0 20px 42px -34px rgba(79, 70, 229, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    overflow: hidden;
  }

  .runtime__core::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 35%);
    pointer-events: none;
  }

  .runtime__core .runtime__kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    position: relative;
    z-index: 1;
  }

  .runtime__core::before {
    display: none;
  }

  .runtime__pipeline {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
    max-width: 20rem;
  }

  .runtime__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.7rem;
    padding: 0.34rem 0.58rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-accent-dim);
    background: #f8f7ff;
    border: 1px solid rgba(99, 102, 241, 0.12);
  }

  .runtime__store {
    position: relative;
    margin-top: 0.95rem;
  }

  .runtime__store::before {
    display: none;
  }

  .runtime__store-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.85rem 1rem;
    border-radius: 1rem;
    max-width: 40rem;
    margin: 0 auto;
  }

  .runtime__store-card--compact {
    align-items: center;
    width: min(100%, 34rem);
    max-width: 34rem;
    padding: 0.7rem 1rem;
    background: linear-gradient(180deg, #ffffff, #fafbff);
    border-color: rgba(99, 102, 241, 0.08);
    box-shadow: 0 12px 26px -24px rgba(79, 70, 229, 0.16);
  }

  .runtime__caption {
    margin-top: 0.75rem;
    font-size: 0.86rem;
    color: #64748b;
    max-width: 44rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== Slide 6-7: Advanced usage ===== */
  .deep-slide {
    position: relative;
    max-width: 66rem;
    margin: 0 auto;
  }

  .deep-slide::before {
    content: '';
    position: absolute;
    top: 5rem;
    right: 8%;
    width: 15rem;
    height: 15rem;
    border-radius: 50%;
    filter: blur(36px);
    pointer-events: none;
    opacity: 0.72;
  }

  .deep-slide--usage::before {
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12), transparent 70%);
  }

  .deep-slide--practice::before {
    background: radial-gradient(circle, rgba(20, 184, 166, 0.12), transparent 70%);
  }

  .deep-slide > * {
    position: relative;
    z-index: 1;
  }

  .deep-slide__lead {
    max-width: 43rem;
    margin-bottom: 0;
  }

  .deep-slide__takeaway {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.8rem;
    border-radius: 999px;
    margin-top: 0.8rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-accent-dim);
    border: 1px solid rgba(99, 102, 241, 0.12);
    background: rgba(255, 255, 255, 0.82);
  }

  .deep-slide--practice .deep-slide__takeaway {
    color: #0f766e;
    border-color: rgba(20, 184, 166, 0.16);
  }

  .loader-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .loader-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1rem 1.05rem;
    border-radius: 1.15rem;
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 18px 34px -30px rgba(15, 23, 42, 0.16);
    overflow: hidden;
  }

  .loader-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--loader-accent, rgba(148, 163, 184, 0.5));
  }

  .loader-card--skill { --loader-accent: linear-gradient(90deg, #6366f1, #8b5cf6); }
  .loader-card--plugin { --loader-accent: linear-gradient(90deg, #14b8a6, #0f766e); }

  .loader-card__header {
    display: grid;
    gap: 0.3rem;
  }

  .loader-card__kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-accent);
  }

  .loader-card__header h3 {
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .loader-card__text,
  .loader-card__note {
    font-size: 0.84rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  .loader-card__text code {
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--color-text);
  }

  .loader-card__example {
    align-self: flex-start;
    padding: 0.3rem 0.6rem;
    border-radius: 0.5rem;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.18);
    font-size: 0.76rem;
    color: #0f766e;
    line-height: 1.4;
  }

  /* Intervention block: when + what + direction */
  .intervenes {
    margin-top: 0.2rem;
    padding: 0.6rem 0.7rem 0.65rem;
    border-radius: 0.7rem;
    background: rgba(15, 23, 42, 0.03);
    border: 1px solid rgba(15, 23, 42, 0.08);
    display: grid;
    gap: 0.3rem;
  }

  .intervenes__label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  .intervenes__when {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-text);
    line-height: 1.4;
    font-weight: 600;
  }

  .intervenes__when code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    padding: 0.04em 0.3em;
    border-radius: 0.3em;
    background: rgba(99, 102, 241, 0.1);
    color: var(--color-accent-dim);
    font-weight: 500;
  }

  .intervenes__touches {
    margin: 0;
    font-size: 0.76rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .intervenes__hooks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .intervenes__hooks code {
    display: inline-flex;
    align-items: center;
    padding: 0.14rem 0.4rem;
    border-radius: 0.35rem;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.16);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #0f766e;
    line-height: 1.2;
    white-space: nowrap;
  }

  .intervenes__hooks-more {
    display: inline-flex;
    align-items: center;
    padding: 0.14rem 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .intervenes__direction {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .intervenes--skill .intervenes__direction {
    color: #6366f1;
  }

  .intervenes--plugin .intervenes__direction {
    color: #0f766e;
  }

  .loader-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .loader-step,
  .loader-connector {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.85rem;
    border-radius: 999px;
    font-size: 0.73rem;
    font-weight: 600;
  }

  .loader-step {
    padding: 0.36rem 0.68rem;
    color: var(--color-accent-dim);
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.12);
  }

  .loader-card--plugin .loader-step {
    color: #0f766e;
    background: rgba(20, 184, 166, 0.08);
    border-color: rgba(20, 184, 166, 0.14);
  }

  .loader-connector {
    min-width: 1.4rem;
    color: #94a3b8;
  }

  .mini-code {
    border-radius: 0.95rem;
    overflow: hidden;
    background: #0f172a;
    border: 1px solid rgba(30, 41, 59, 0.95);
    box-shadow: 0 18px 36px -30px rgba(15, 23, 42, 0.34);
  }

  .mini-code__header {
    position: relative;
    padding: 0.6rem 0.85rem 0.6rem 3.7rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #a5b4fc;
    background: rgba(15, 23, 42, 0.96);
    border-bottom: 1px solid rgba(51, 65, 85, 0.9);
  }

  .mini-code__header::before {
    content: '';
    position: absolute;
    left: 0.95rem;
    top: 50%;
    width: 1.9rem;
    height: 0.52rem;
    transform: translateY(-50%);
    background:
      radial-gradient(circle, #fb7185 55%, transparent 56%) 0 50% / 0.52rem 0.52rem no-repeat,
      radial-gradient(circle, #fbbf24 55%, transparent 56%) 0.7rem 50% / 0.52rem 0.52rem no-repeat,
      radial-gradient(circle, #34d399 55%, transparent 56%) 1.4rem 50% / 0.52rem 0.52rem no-repeat;
  }

  .mini-code__pre {
    margin: 0;
    padding: 0.75rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.5;
    color: #e2e8f0;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(17, 24, 39, 1));
  }

  /* ===== Slide 7: Oh-My-OpenAgent deep dive ===== */
  .omo-slide {
    max-width: 70rem;
  }

  /* Three-layer architecture: planning | execution | workers (workers wider) */
  .omo-architecture {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 0.8fr) auto minmax(0, 1.6fr);
    gap: 0.7rem;
    align-items: stretch;
    margin-top: 0.85rem;
  }

  .omo-layer {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.85rem 0.9rem 0.95rem;
    border-radius: 1.1rem;
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.95);
    box-shadow: 0 18px 34px -30px rgba(15, 23, 42, 0.14);
    overflow: hidden;
  }

  .omo-layer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--omo-accent, rgba(148, 163, 184, 0.5));
  }

  .omo-layer--planning { --omo-accent: linear-gradient(90deg, #6366f1, #8b5cf6); }
  .omo-layer--execution { --omo-accent: linear-gradient(90deg, #f59e0b, #f97316); }
  .omo-layer--workers { --omo-accent: linear-gradient(90deg, #14b8a6, #0f766e); }

  .omo-layer__kicker {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .omo-layer__agents {
    display: flex;
    flex-wrap: wrap;
    gap: 0.32rem;
  }

  .omo-layer__agents--grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
    gap: 0.3rem;
  }

  .omo-agent {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.55rem;
    border-radius: 0.55rem;
    background: rgba(248, 250, 252, 0.95);
    border: 1px solid rgba(226, 232, 240, 0.9);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .omo-agent--lead {
    background: rgba(255, 255, 255, 1);
    border-color: rgba(99, 102, 241, 0.32);
    color: var(--color-text);
    font-weight: 600;
    box-shadow: 0 4px 10px -8px rgba(99, 102, 241, 0.35);
  }

  .omo-layer--execution .omo-agent--lead {
    border-color: rgba(245, 158, 11, 0.38);
    box-shadow: 0 4px 10px -8px rgba(245, 158, 11, 0.4);
  }

  .omo-layer--workers .omo-agent--lead {
    border-color: rgba(20, 184, 166, 0.38);
    box-shadow: 0 4px 10px -8px rgba(20, 184, 166, 0.4);
  }

  .omo-layer__note {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .omo-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    color: rgba(148, 163, 184, 0.85);
    font-weight: 300;
  }

  /* Runtime echo — compressed reference back to slide 5 */
  .omo-runtime-base {
    margin-top: 0.6rem;
    padding: 0.55rem 0.95rem 0.6rem;
    border-radius: 0.95rem;
    background: rgba(15, 23, 42, 0.035);
    border: 1px dashed rgba(15, 23, 42, 0.12);
    display: grid;
    gap: 0.3rem;
  }

  .omo-runtime-base__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .omo-runtime-base__strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text);
  }

  .omo-runtime-base__strip span {
    position: relative;
  }

  .omo-runtime-base__strip span:not(:last-child)::after {
    content: '·';
    position: absolute;
    right: -0.75rem;
    color: rgba(148, 163, 184, 0.7);
  }

  .omo-runtime-base__caption {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Workflow narrative — numbered steps showing how a task flows through OmO */
  .omo-workflow {
    margin-top: 0.7rem;
    padding: 0.7rem 1rem 0.8rem;
    border-radius: 1rem;
    background: rgba(99, 102, 241, 0.04);
    border: 1px solid rgba(99, 102, 241, 0.1);
  }

  .omo-workflow__kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .omo-workflow__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.3rem;
  }

  .omo-workflow__steps li {
    display: grid;
    grid-template-columns: 1.55rem 1fr;
    gap: 0.55rem;
    align-items: baseline;
    font-size: 0.84rem;
    color: var(--color-text);
    line-height: 1.45;
  }

  .omo-workflow__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #ffffff;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
  }

  .omo-workflow__text code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    padding: 0.05em 0.32em;
    border-radius: 0.3em;
    background: rgba(99, 102, 241, 0.1);
