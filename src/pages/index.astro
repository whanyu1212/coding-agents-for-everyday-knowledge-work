            <span class="core__title">CodeAct</span>
            <span class="core__sub">the action format</span>
          </div>
        </div>

        <!-- TOP: judgment steers it -->
        <div class="layer layer--judgment">
          <span class="layer__node" aria-hidden="true">01</span>
          <div class="layer__body">
            <p class="layer__verb">steers it</p>
            <h3 class="layer__title">Judgment &amp; planning</h3>
            <p class="layer__claim">Acting is easy; knowing <em>which</em> action advances the goal &mdash; decompose, route, continue, stop &mdash; lives above the model.</p>
            <p class="layer__saw"><span class="layer__saw-tag">saw it</span> OmO planners, routing, Ralph loop</p>
          </div>
        </div>

        <!-- BOTTOM-LEFT: context feeds it -->
