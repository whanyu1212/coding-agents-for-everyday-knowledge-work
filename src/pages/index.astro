  }

  /* Routing strip — concrete category→model evidence */
  .omo-routing {
    margin-top: 0.65rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.55rem;
  }

  .omo-routing__label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .omo-routing__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.18);
    font-size: 0.78rem;
    color: #0f766e;
  }

  .omo-routing__chip code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    color: #0f766e;
    font-weight: 600;
  }

  /* Punchline — replaces the inline pill takeaway for this slide only */
  .omo-takeaway {
    margin-top: 0.85rem;
    padding: 0.8rem 1.05rem 0.9rem;
    border-radius: 1.1rem;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
    color: #ffffff;
    box-shadow: 0 24px 48px -32px rgba(15, 23, 42, 0.5);
  }

  .omo-takeaway__line {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.92);
  }

  .omo-takeaway__accent {
    color: #5eead4;
  }

  .omo-takeaway__sub {
    margin: 0.35rem 0 0;
    font-size: 0.82rem;
    color: rgba(226, 232, 240, 0.7);
    line-height: 1.5;
  }

  /* ===== Slide 8: What the harness gives you ===== */
  .harness-power {
    max-width: 72rem;
  }

  .harness-power__lead {
    max-width: 48rem;
    margin-bottom: 1.4rem;
  }

  .harness-power__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }

  .pillar {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.15rem 1.05rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 18px 40px -28px rgba(15, 23, 42, 0.35);
    overflow: hidden;
  }

  .pillar::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--pillar-accent, linear-gradient(90deg, #6366f1, #8b5cf6));
  }

  .pillar--routing { --pillar-accent: linear-gradient(90deg, #06b6d4, #0891b2); --pillar-chip-bg: rgba(6, 182, 212, 0.08); --pillar-chip-border: rgba(6, 182, 212, 0.18); --pillar-chip-text: #0e7490; }
  .pillar--continuation { --pillar-accent: linear-gradient(90deg, #8b5cf6, #6d28d9); --pillar-chip-bg: rgba(139, 92, 246, 0.08); --pillar-chip-border: rgba(139, 92, 246, 0.18); --pillar-chip-text: #6d28d9; }
  .pillar--guardrails { --pillar-accent: linear-gradient(90deg, #f59e0b, #d97706); --pillar-chip-bg: rgba(245, 158, 11, 0.08); --pillar-chip-border: rgba(245, 158, 11, 0.22); --pillar-chip-text: #b45309; }

  .pillar__head {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    margin-bottom: 0.7rem;
  }

  .pillar__icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .pillar__head-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .pillar__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .pillar__sub {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .pillar__mechanism {
    margin: 0 0 0.75rem;
    padding: 0.4rem 0.55rem;
    border-radius: 0.5rem;
    background: rgba(15, 23, 42, 0.04);
    border: 1px solid rgba(15, 23, 42, 0.06);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .pillar__mechanism code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text);
    background: transparent;
    padding: 0;
  }

  .pillar__chips {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.8rem;
    flex-grow: 1;
  }

  .pillar__chip {
    display: block;
    padding: 0.35rem 0.55rem;
    border-radius: 0.45rem;
    background: var(--pillar-chip-bg);
    border: 1px solid var(--pillar-chip-border);
    font-size: 0.74rem;
    color: var(--color-text);
    line-height: 1.35;
  }

  .pillar__chip strong {
    color: var(--pillar-chip-text);
    font-weight: 600;
  }

  .pillar__chip code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.05rem 0.3rem;
    border-radius: 0.25rem;
    background: rgba(255, 255, 255, 0.6);
    color: var(--pillar-chip-text);
  }

  .pillar__before-after {
    margin: 0;
    padding-top: 0.65rem;
    border-top: 1px dashed rgba(15, 23, 42, 0.12);
    font-size: 0.78rem;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .harness-power__strip {
    margin-top: 1.1rem;
    padding: 0.9rem 1.2rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
    color: #ffffff;
    text-align: center;
    box-shadow: 0 24px 48px -32px rgba(15, 23, 42, 0.5);
  }

  .harness-power__strip-line {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.85);
  }

  .harness-power__strip-line--accent {
    color: #5eead4;
    font-size: 1.25rem;
    margin-top: 0.2rem;
  }

  /* ===== Slide 9: Personalization thesis ===== */
  .personalization {
    max-width: 70rem;
  }

  .personalization__lead {
    max-width: 46rem;
    margin-bottom: 1.5rem;
  }

  .contrast {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    gap: 1.1rem;
  }

  .contrast__col {
    padding: 1.1rem 1.25rem 1.2rem;
    border-radius: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
  }

  .contrast__col--default {
    background: rgba(15, 23, 42, 0.03);
  }

  .contrast__col--you {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.07), rgba(139, 92, 246, 0.07));
    border-color: rgba(99, 102, 241, 0.2);
  }

  .contrast__kicker {
    margin: 0 0 0.7rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
  }

  .contrast__col--you .contrast__kicker {
    color: #6d28d9;
  }

  .contrast__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .contrast__list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.86rem;
    line-height: 1.4;
    color: var(--color-text);
  }

  .contrast__col--default .contrast__list li {
    color: var(--color-text-muted);
  }

  .contrast__col--you .contrast__list li strong {
    font-weight: 700;
    color: #6d28d9;
  }

  .contrast__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
  }

  .contrast__col--default .contrast__list li::before {
    background: rgba(15, 23, 42, 0.25);
  }

  .contrast__col--you .contrast__list li::before {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
  }

  .contrast__vs {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    font-style: italic;
    color: var(--color-text-muted);
    padding: 0 0.2rem;
  }

  .contrast__bridge {
    margin-top: 1.3rem;
    padding: 1rem 1.3rem 1.1rem;
    border-radius: 1.1rem;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(30, 41, 59, 0.96));
    text-align: center;
    box-shadow: 0 24px 48px -32px rgba(15, 23, 42, 0.5);
  }

  .contrast__bridge-line {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.92);
  }

  .contrast__bridge-line em {
    font-style: normal;
    color: #5eead4;
  }

  .contrast__bridge-sub {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    color: rgba(226, 232, 240, 0.72);
    line-height: 1.5;
  }

  .contrast__bridge-sub strong {
    color: #5eead4;
    font-weight: 700;
  }

  /* ===== Slide 10: Two roads (adopt & tune / build & own) ===== */
  .personalization-how {
    max-width: 70rem;
  }

  .personalization-how__lead {
    max-width: 47rem;
    margin-bottom: 1.5rem;
  }

  .roads {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    align-items: stretch;
  }

  .road {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.2rem 1.35rem 1.3rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 18px 40px -28px rgba(15, 23, 42, 0.32);
    overflow: hidden;
  }

  .road::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--road-accent, linear-gradient(90deg, #6366f1, #8b5cf6));
  }

  .road--adopt { --road-accent: linear-gradient(90deg, #f59e0b, #d97706); --road-tint: rgba(245, 158, 11, 0.1); --road-ink: #b45309; }
  .road--build { --road-accent: linear-gradient(90deg, #6366f1, #8b5cf6); --road-tint: rgba(99, 102, 241, 0.1); --road-ink: #4338ca; }

  .road__head {
    margin-bottom: 0.85rem;
  }

  .road__badge {
    display: inline-block;
    margin-bottom: 0.45rem;
    padding: 0.16rem 0.55rem;
    border-radius: 999px;
    background: var(--road-tint);
    color: var(--road-ink);
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .road__title {
    margin: 0 0 0.3rem;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .road__example {
    display: block;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .road__list {
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .road__list li {
    position: relative;
    padding-left: 1.2rem;
    font-size: 0.88rem;
    line-height: 1.45;
