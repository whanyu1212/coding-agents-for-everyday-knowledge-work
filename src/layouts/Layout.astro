---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Coding Agents for Everyday Knowledge Work — they're not just code generators, they're coworkers that solve tasks through code." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --color-bg: #ffffff;
    --color-bg-card: #f8f9fa;
    --color-bg-code: #f1f3f5;
    --color-text: #1a1a2e;
    --color-text-muted: #6b7280;
    --color-accent: #4f46e5;
    --color-accent-dim: #4338ca;
    --color-accent-glow: rgba(79, 70, 229, 0.08);
    --color-border: #e5e7eb;
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
  }

  html {
    scroll-snap-type: y proximity;
    scroll-behavior: smooth;
    overflow-y: scroll;
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  ::selection {
    background: var(--color-accent);
    color: #ffffff;
  }
</style>
