---
interface Props {
  title?: string;
  lang?: string;
}

const { title, lang = 'text' } = Astro.props;
---

<div class="code-block">
  {title && <div class="code-block__header">{title}</div>}
  <pre class="code-block__pre"><code class={`language-${lang}`}><slot /></code></pre>
</div>

<style>
  .code-block {
    border-radius: 0.75rem;
    border: 1px solid #2a2a3a;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .code-block__header {
    background: #1e1e2e;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    color: #a1a1aa;
    border-bottom: 1px solid #2a2a3a;
    font-family: var(--font-sans);
    font-weight: 500;
  }

  .code-block__pre {
    background: #1a1a2e;
    padding: 1.25rem 1.5rem;
    margin: 0;
    overflow-x: auto;
    white-space: pre;
  }

  code {
    font-family: inherit;
    color: #e4e4e7;
  }
</style>
